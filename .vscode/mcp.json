{
  "servers": {
    "token-saver-mcp": {
      "command": "token-saver-mcp"
    },
    "codebase-memory-mcp": {
      "command": "codebase-memory-mcp"
    },
    "codegraph": {
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ]
    },
    "gitnexus": {
      "command": "gitnexus",
      "args": [
        "mcp"
      ],
      "env": {
        "GITNEXUS_SEMANTIC_EXACT_SCAN_LIMIT": "50000",
        "GITNEXUS_EMBEDDING_THREADS": "4"
      }
    },
    "repomix": {
      "command": "repomix",
      "args": [
        "--mcp"
      ]
    },
    "graphify": {
      "command": "py",
      "args": [
        "-3.14",
        "-m",
        "graphify.serve",
        "--transport",
        "stdio",
        "context/graphify-out/graph.json"
      ]
    }
  }
}
