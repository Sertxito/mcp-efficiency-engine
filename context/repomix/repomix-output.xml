<file path="scripts/setup/setup-prerequisites.ps1">
  1: param(
  2:     [switch]$SkipCodebaseMemory,
  3:     [switch]$SkipTokenSaver,
  4:     [switch]$SkipCodegraph,
  5:     [switch]$SkipGitnexus,
  6:     [switch]$SkipGraphify
  7: )
  8: 
  9: $ErrorActionPreference = 'Stop'
 10: 
 11: $repoRoot = (Resolve-Path (Join-Path $PSScriptRoot '..\..')).Path
 12: Set-Location $repoRoot
 13: 
 14: function Test-Command {
 15:     param([Parameter(Mandatory = $true)][string]$Name)
 16: 
 17:     return [bool](Get-Command -Name $Name -ErrorAction SilentlyContinue)
 18: }
 19: 
 20: function Install-NpmGlobalPackage {
 21:     param(
 22:         [Parameter(Mandatory = $true)][string]$Package,
 23:         [Parameter(Mandatory = $true)][string]$ExpectedCommand
 24:     )
 25: 
 26:     if (Test-Command $ExpectedCommand) {
 27:         Write-Host "[ok] $ExpectedCommand already installed"
 28:         return
 29:     }
 30: 
 31:     if (-not (Test-Command 'npm')) {
 32:         throw "npm is required to install $Package. Install Node.js first: https://nodejs.org/"
 33:     }
 34: 
 35:     Write-Host "[install] npm install -g $Package"
 36:     npm install -g $Package
 37: }
 38: 
 39: function Test-PythonImport {
 40:     param(
 41:         [Parameter(Mandatory = $true)][string]$PythonCommand,
 42:         [string[]]$PythonArgs = @(),
 43:         [Parameter(Mandatory = $true)][string]$Module
 44:     )
 45: 
 46:     & $PythonCommand @PythonArgs -c "import $Module" *> $null
 47:     return ($LASTEXITCODE -eq 0)
 48: }
 49: 
 50: function Resolve-PythonCommand {
 51:     if (Test-Command 'py') {
 52:         return @('py', '-3.14')
 53:     }
 54:     if (Test-Command 'python') {
 55:         return @('python')
 56:     }
 57:     throw 'Python 3.14 is required for graphify MCP. Install Python first: https://www.python.org/downloads/'
 58: }
 59: 
 60: Write-Host '== MCP platform prerequisites setup =='
 61: 
 62: if (-not $SkipCodebaseMemory) {
 63:     if (Test-Command 'codebase-memory-mcp') {
 64:         Write-Host '[ok] codebase-memory-mcp already installed'
 65:     }
 66:     else {
 67:         Write-Host '[install] codebase-memory-mcp via official Windows setup script'
 68:         Invoke-RestMethod https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/scripts/setup-windows.ps1 | Invoke-Expression
 69:     }
 70: }
 71: 
 72: if (-not $SkipTokenSaver) {
 73:     Install-NpmGlobalPackage -Package 'token-saver-mcp' -ExpectedCommand 'token-saver-mcp'
 74: }
 75: 
 76: if (-not $SkipCodegraph) {
 77:     Install-NpmGlobalPackage -Package '@colbymchenry/codegraph' -ExpectedCommand 'codegraph'
 78:     Write-Host '[setup] codegraph install'
 79:     codegraph install
 80:     if (-not (Test-Path '.codegraph')) {
 81:         Write-Host '[setup] codegraph init -i'
 82:         codegraph init -i
 83:     }
 84:     else {
 85:         Write-Host '[ok] .codegraph index already exists'
 86:     }
 87: }
 88: 
 89: if (-not $SkipGitnexus) {
 90:     Install-NpmGlobalPackage -Package 'gitnexus@latest' -ExpectedCommand 'gitnexus'
 91:     Write-Host '[setup] gitnexus setup'
 92:     gitnexus setup
 93: }
 94: 
 95: if (-not $SkipGraphify) {
 96:     $py = Resolve-PythonCommand
 97:     $pyCmd = $py[0]
 98:     $pyArgs = @()
 99:     if ($py.Length -gt 1) {
100:         $pyArgs = $py[1..($py.Length - 1)]
101:     }
102: 
103:     if ($py.Length -gt 1) {
104:         Write-Host "[setup] Using Python launcher: $($py -join ' ')"
105:     }
106:     else {
107:         Write-Host "[setup] Using Python launcher: $pyCmd"
108:     }
109: 
110:     Write-Host '[install] python -m pip install "graphifyy[mcp]"'
111:     & $pyCmd @pyArgs -m pip install "graphifyy[mcp]"
112: 
113:     if (-not (Test-PythonImport -PythonCommand $pyCmd -PythonArgs $pyArgs -Module 'graphify.serve')) {
114:         throw 'graphify.serve import failed after installation.'
115:     }
116: 
117:     if (-not (Test-PythonImport -PythonCommand $pyCmd -PythonArgs $pyArgs -Module 'mcp')) {
118:         throw 'mcp module import failed after graphify installation.'
119:     }
120: 
121:     if (-not (Test-Path 'context/graphify-out/graph.json')) {
122:         Write-Host '[setup] graphify extract scripts --no-cluster --out context'
123:         & $pyCmd @pyArgs -m graphify extract scripts --no-cluster --out context
124:     }
125:     else {
126:         Write-Host '[ok] context/graphify-out/graph.json already exists'
127:     }
128: }
129: 
130: Write-Host ''
131: Write-Host 'Setup complete. Recommended next checks:'
132: Write-Host '  1) .\scripts\setup\validate-context.ps1'
133: Write-Host '  2) .\scripts\intake\run-repo-intake.cmd'
134: Write-Host '  3) /mcp (in your agent) to verify servers are active'
</file>

