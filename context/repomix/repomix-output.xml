 61:     vkpis = value.get("kpis", {}) if isinstance(value.get("kpis", {}), dict) else {}
 62:     fallback_rate = round(get_number(kpis.get("fallback_rate")) * 100.0, 2)
 63:     grounded_rate = round(get_number(kpis.get("grounded_rate")) * 100.0, 2)
 64:     success_rate = round(get_number(kpis.get("success_rate")) * 100.0, 2)
 65:     coverage_rate = round(get_number(vkpis.get("metrics_coverage_rate")) * 100.0, 2)
 66:     tokens_per_success = get_number(vkpis.get("tokens_per_confirmed_success"))
 67:     lines = [
 68:         f"- updated_at: {utc_now()}",
 69:         f"- fallback_rate: porcentaje de rutas en fallback. valor_actual={fallback_rate}%.",
 70:         f"- grounded_rate: porcentaje de rutas con fuentes validas. valor_actual={grounded_rate}%.",
 71:         f"- confirmed_success_rate: tasa de exito con feedback confirmado. valor_actual={success_rate}%.",
 72:         f"- metrics_coverage_rate: porcentaje de eventos con metricas. valor_actual={coverage_rate}%.",
 73:         f"- tokens_per_confirmed_success: tokens medios por exito confirmado. valor_actual={tokens_per_success}.",
