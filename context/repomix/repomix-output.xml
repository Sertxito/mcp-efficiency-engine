 1839: <file path=".github/skills/human-in-the-loop/SKILL.md">
 1840:  1: # Human In The Loop (HITL)
 1841:  2: 
 1842:  3: ## Purpose
 1843:  4: 
 1844:  5: Asegurar confirmacion humana solo cuando una decision o accion tiene riesgo alto, impacto externo o potencial destructivo.
 1845:  6: 
 1846:  7: ## Scope
 1847:  8: 
 1848:  9: Aplicar en todas las rutas del sistema como capa transversal.
 1849: 10: 
 1850: 11: ## Always-On Behavior
 1851: 12: 
 1852: 13: - Deteccion automatica de riesgo desde intent/domain/source/notes de routing.
 1853: 14: - No pedir confirmacion para rutas de bajo riesgo.
 1854: 15: - Pedir confirmacion cuando exista riesgo alto o fallback de routing.
 1855: 16: - Bloquear ejecucion para acciones destructivas hasta aprobacion explicita.
 1856: 17: 
 1857: 18: ## Risk Triggers
 1858: 19: 
 1859: 20: - deploy, production
 1860: 21: - migrate, migration
 1861: 22: - delete, drop, destroy, remove
 1862: 23: - governance, policy
 1863: 24: - security, rbac, role
 1864: 25: - unresolved_dependencies
 1865: 26: - routing_fallback
 1866: 27: 
 1867: 28: ## Actions
 1868: 29: 
 1869: 30: - `none`: continuar sin aprobacion.
 1870: 31: - `request_human_confirmation`: solicitar confirmacion antes de ejecutar.
 1871: 32: - `block_until_human_approval`: bloquear hasta aprobacion humana.
 1872: 33: 
 1873: 34: ## Observability Contract
 1874: 35: 
 1875: 36: Cada evento de routing debe incluir `hitl`:
 1876: 37: 
 1877: 38: - `mode`: `always_on_auto`
 1878: 39: - `required`: `true|false`
 1879: 40: - `action`: `none|request_human_confirmation|block_until_human_approval`
 1880: 41: - `reason`: motivo legible y trazable
 1881: 42: 
 1882: 43: ## Guardrails
 1883: 44: 
 1884: 45: - Nunca cachear secretos, credenciales, tokens o PII.
 1885: 46: - Si hay duda de sensibilidad, declarar gap y no cachear.
 1886: 47: - Confirmaciones humanas solo para impacto real; evitar friccion en bajo riesgo.
 1887: </file>
 1888: <file path=".github/workflows/routing-evals.yml">
 1889:   1: name: Routing Evals Gate
 1890:   2: on:
 1891:   3:   pull_request:
 1892:   4:   push:
 1893:   5:     branches:
 1894:   6:       - main
 1895:   7:   workflow_dispatch:
 1896:   8: permissions:
 1897:   9:   contents: read
 1898:  10: concurrency:
 1899:  11:   group: routing-evals-${{ github.ref }}
 1900:  12:   cancel-in-progress: true
 1901:  13: jobs:
 1902:  14:   routing-evals:
 1903:  15:     runs-on: ubuntu-latest
 1904:  16:     timeout-minutes: 15
 1905:  17:     env:
 1906:  18:       PYTHONUNBUFFERED: '1'
 1907:  19:     steps:
 1908:  20:       - name: Checkout
 1909:  21:         uses: actions/checkout@v4
 1910:  22:         with:
 1911:  23:           fetch-depth: 1
 1912:  24:       - name: Set up Python
 1913:  25:         uses: actions/setup-python@v5
 1914:  26:         with:
 1915:  27:           python-version: '3.12'
 1916:  28:           cache: 'pip'
 1917:  29:           cache-dependency-path: requirements.txt
 1918:  30:       - name: Upgrade pip
 1919:  31:         run: python -m pip install --upgrade pip
 1920:  32:       - name: Install dependencies (if requirements.txt exists)
 1921:  33:         run: |
 1922:  34:           if [ -f requirements.txt ]; then
 1923:  35:             python -m pip install -r requirements.txt
 1924:  36:           fi
 1925:  37:       - name: Run routing evals
 1926:  38:         run: python ./scripts/intake/run-routing-evals.py
 1927:  39:       - name: Build learning loop report
 1928:  40:         run: python ./scripts/learning/learning-loop-report.py
 1929:  41:       - name: Build iteration value report
 1930:  42:         run: python ./scripts/learning/iteration-value-report.py
 1931:  43:       - name: Enforce AutoLearning gate
 1932:  44:         run: python ./scripts/learning/autolearning-gate.py
 1933:  45:       - name: Enforce zero failed cases
 1934:  46:         run: |
 1935:  47:           python - <<'PY'
 1936:  48:           import json
 1937:  49:           from pathlib import Path
 1938:  50:           report = Path('observability/evals/routing-eval-report.json')
 1939:  51:           if not report.exists():
 1940:  52:               raise SystemExit('routing-eval-report.json not found')
 1941:  53:           data = json.loads(report.read_text(encoding='utf-8'))
 1942:  54:           failed = int(data.get('cases_failed', 0))
 1943:  55:           total = int(data.get('cases_total', 0))
 1944:  56:           passed = int(data.get('cases_passed', 0))
 1945:  57:           print(f'Routing evals: {passed}/{total} passed, failed={failed}')
 1946:  58:           if failed > 0:
 1947:  59:               raise SystemExit(1)
 1948:  60:           PY
 1949:  61:       - name: Upload eval artifacts
 1950:  62:         if: always()
 1951:  63:         uses: actions/upload-artifact@v4
 1952:  64:         with:
 1953:  65:           name: routing-evals-${{ github.run_number }}
 1954:  66:           if-no-files-found: warn
 1955:  67:           path: |
 1956:  68:             observability/evals/routing-eval-report.json
 1957:  69:             observability/evals/learning-loop-report.json
 1958:  70:             observability/evals/learning-loop-report.md
 1959:  71:             observability/evals/iteration-value-report.json
 1960:  72:             observability/evals/iteration-value-report.md
 1961:  73:   publish-summary:
 1962:  74:     runs-on: ubuntu-latest
 1963:  75:     timeout-minutes: 5
 1964:  76:     needs:
 1965:  77:       - routing-evals
 1966:  78:     if: always()
 1967:  79:     steps:
 1968:  80:       - name: Download eval artifacts
 1969:  81:         id: download_artifacts
 1970:  82:         continue-on-error: true
 1971:  83:         uses: actions/download-artifact@v4
 1972:  84:         with:
 1973:  85:           name: routing-evals-${{ github.run_number }}
 1974:  86:           path: artifacts
 1975:  87:       - name: Publish workflow summary
 1976:  88:         if: always()
 1977:  89:         run: |
 1978:  90:           python - <<'PY'
 1979:  91:           import json
 1980:  92:           import os
 1981:  93:           from pathlib import Path
 1982:  94:           summary_path = Path(os.environ['GITHUB_STEP_SUMMARY'])
 1983:  95:           routing = Path('artifacts/observability/evals/routing-eval-report.json')
 1984:  96:           learning = Path('artifacts/observability/evals/learning-loop-report.json')
 1985:  97:           iteration = Path('artifacts/observability/evals/iteration-value-report.json')
 1986:  98:           lines = ['# Routing Evals Summary', '']
 1987:  99:           lines.append(f"- routing-evals result: {os.environ.get('NEEDS_ROUTING_EVALS_RESULT', 'unknown')}")
 1988: 100:           lines.append('')
 1989: 101:           if routing.exists():
 1990: 102:               data = json.loads(routing.read_text(encoding='utf-8'))
 1991: 103:               total = int(data.get('cases_total', 0))
 1992: 104:               passed = int(data.get('cases_passed', 0))
 1993: 105:               failed = int(data.get('cases_failed', 0))
 1994: 106:               lines.extend([
