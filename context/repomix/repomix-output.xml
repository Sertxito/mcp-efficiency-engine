 75: function Resolve-RepoPath {
 76:     param(
 77:         [string]$Root,
 78:         [string]$RelativePath
 79:     )
 80: 
 81:     if ([System.IO.Path]::IsPathRooted($RelativePath)) {
 82:         return (Resolve-Path $RelativePath).Path
 83:     }
 84:     return [System.IO.Path]::GetFullPath((Join-Path $Root $RelativePath))
 85: }
