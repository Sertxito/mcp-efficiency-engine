32627: 19685: <file path="scripts/discovery/discover-boost-repos.py">
32628: 19686:   1: from __future__ import annotations
32629: 19687:   2: import argparse
32630: 19688:   3: import json
32631: 19689:   4: import re
32632: 19690:   5: from datetime import datetime, timezone
32633: 19691:   6: from pathlib import Path
32634: 19692:   7: from typing import Any
32635: 19693:   8: def utc_now() -> str:
32636: 19694:   9:     return datetime.now(timezone.utc).isoformat()
32637: 19695:  10: def load_registry(path: Path) -> dict[str, Any]:
32638: 19696:  11:     content = path.read_text(encoding="utf-8")
32639: 19697:  12:     if content.lstrip().startswith("{"):
32640: 19698:  13:         return json.loads(content)
32641: 19699:  14:     raise ValueError("Registry must be JSON-first in current setup.")
32642: 19700:  15: def slug_name(folder_name: str) -> str:
32643: 19701:  16:     name = folder_name.lower().replace("-", "_")
32644: 19702:  17:     name = re.sub(r"[^a-z0-9_]+", "_", name)
32645: 19703:  18:     name = re.sub(r"_+", "_", name).strip("_")
32646: 19704:  19:     if not name.startswith("boost_"):
32647: 19705:  20:         name = f"boost_{name}"
32648: 19706:  21:     return name
32649: 19707:  22: def infer_domain(folder_name: str) -> str:
32650: 19708:  23:     token = folder_name.lower()
32651: 19709:  24:     if "dba" in token or "sql" in token or "db" in token:
32652: 19710:  25:         return "dba"
32653: 19711:  26:     if "iot" in token or "edge" in token:
32654: 19712:  27:         return "iot"
32655: 19713:  28:     if "rag" in token or "azure" in token:
32656: 19714:  29:         return "azure-rag"
32657: 19715:  30:     if "legacy" in token or "migration" in token:
32658: 19716:  31:         return "legacy"
32659: 19717:  32:     return "dev"
32660: 19718:  33: def default_engines(domain: str) -> dict[str, str]:
32661: 19719:  34:     if domain == "dba":
32662: 19720:  35:         return {"knowledge": "graphify", "execution": "none", "snapshot": "repomix"}
32663: 19721:  36:     if domain == "iot":
32664: 19722:  37:         return {"knowledge": "graphify", "execution": "gitnexus", "snapshot": "repomix"}
32665: 19723:  38:     if domain == "azure-rag":
32666: 19724:  39:         return {"knowledge": "azure-rag-builder", "execution": "none", "snapshot": "repomix"}
32667: 19725:  40:     if domain == "legacy":
32668: 19726:  41:         return {"knowledge": "gitnexus", "execution": "none", "snapshot": "repomix"}
32669: 19727:  42:     return {"knowledge": "codegraph", "execution": "none", "snapshot": "repomix"}
32670: 19728:  43: def build_candidate(folder: Path, review_ticket_prefix: str, idx: int) -> dict[str, Any]:
32671: 19729:  44:     folder_name = folder.name
32672: 19730:  45:     repo_name = slug_name(folder_name)
32673: 19731:  46:     domain = infer_domain(folder_name)
32674: 19732:  47:     return {
32675: 19733:  48:         "name": repo_name,
32676: 19734:  49:         "domain": domain,
32677: 19735:  50:         "version": "1.0.0",
32678: 19736:  51:         "location": f"../{folder_name}",
32679: 19737:  52:         "type": "local",
32680: 19738:  53:         "dependencies": [],
32681: 19739:  54:         "approval": {
32682: 19740:  55:             "status": "approved",
32683: 19741:  56:             "approved_by": "platform-team",
32684: 19742:  57:             "approved_date": datetime.now().date().isoformat(),
32685: 19743:  58:             "review_ticket": f"{review_ticket_prefix}-{1000 + idx}",
32686: 19744:  59:         },
32687: 19745:  60:         "engines": default_engines(domain),
32688: 19746:  61:     }
32689: 19747:  62: def main() -> int:
32690: 19748:  63:     parser = argparse.ArgumentParser(description="Discover sibling boost_* repos and generate onboarding proposal.")
32691: 19749:  64:     parser.add_argument("--root", default="C:/repo", help="Parent folder containing sibling repos")
32692: 19750:  65:     parser.add_argument("--registry", default="repo-registry/repos.yml", help="Registry file path")
32693: 19751:  66:     parser.add_argument("--output", default="repo-intake/generated/reports/boost-discovery-proposal.json")
32694: 19752:  67:     parser.add_argument("--apply", action="store_true", help="Apply candidates directly to registry")
32695: 19753:  68:     parser.add_argument("--review-ticket-prefix", default="PLATFORM", help="Prefix used for generated review tickets")
32696: 19754:  69:     args = parser.parse_args()
32697: 19755:  70:     repo_root = Path(__file__).resolve().parents[2]
32698: 19756:  71:     registry_path = (repo_root / args.registry).resolve()
32699: 19757:  72:     registry = load_registry(registry_path)
32700: 19758:  73:     prefix = str(registry.get("governance", {}).get("repo_name_prefix", "boost_"))
32701: 19759:  74:     root = Path(args.root)
32702: 19760:  75:     if not root.exists():
32703: 19761:  76:         print(f"Root path not found: {root}")
32704: 19762:  77:         return 1
32705: 19763:  78:     existing_names = {
32706: 19764:  79:         str(r.get("name", ""))
32707: 19765:  80:         for r in registry.get("repos", [])
32708: 19766:  81:         if isinstance(r, dict)
32709: 19767:  82:     }
32710: 19768:  83:     existing_locations = {
32711: 19769:  84:         str(r.get("location", ""))
32712: 19770:  85:         for r in registry.get("repos", [])
32713: 19771:  86:         if isinstance(r, dict)
32714: 19772:  87:     }
32715: 19773:  88:     siblings = [
32716: 19774:  89:         p for p in root.iterdir()
32717: 19775:  90:         if p.is_dir() and p.name.startswith(prefix) and p.name != repo_root.name
32718: 19776:  91:     ]
32719: 19777:  92:     candidates: list[dict[str, Any]] = []
32720: 19778:  93:     skipped: list[dict[str, str]] = []
32721: 19779:  94:     idx = 1
32722: 19780:  95:     for folder in sorted(siblings, key=lambda x: x.name.lower()):
32723: 19781:  96:         candidate = build_candidate(folder=folder, review_ticket_prefix=args.review_ticket_prefix, idx=idx)
32724: 19782:  97:         idx += 1
32725: 19783:  98:         if candidate["name"] in existing_names:
32726: 19784:  99:             skipped.append({"folder": folder.name, "reason": "already_registered_name"})
32727: 19785: 100:             continue
32728: 19786: 101:         if candidate["location"] in existing_locations:
32729: 19787: 102:             skipped.append({"folder": folder.name, "reason": "already_registered_location"})
32730: 19788: 103:             continue
32731: 19789: 104:         candidates.append(candidate)
32732: 19790: 105:     proposal = {
32733: 19791: 106:         "timestamp": utc_now(),
32734: 19792: 107:         "root": str(root).replace("\\", "/"),
32735: 19793: 108:         "prefix": prefix,
32736: 19794: 109:         "registry": str(registry_path).replace("\\", "/"),
32737: 19795: 110:         "existing_count": len(existing_names),
32738: 19796: 111:         "candidates_count": len(candidates),
32739: 19797: 112:         "skipped_count": len(skipped),
32740: 19798: 113:         "candidates": candidates,
32741: 19799: 114:         "skipped": skipped,
32742: 19800: 115:         "apply_mode": bool(args.apply),
32743: 19801: 116:     }
32744: 19802: 117:     out_path = (repo_root / args.output).resolve()
32745: 19803: 118:     out_path.parent.mkdir(parents=True, exist_ok=True)
32746: 19804: 119:     out_path.write_text(json.dumps(proposal, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
32747: 19805: 120:     md_path = out_path.with_suffix(".md")
32748: 19806: 121:     lines = [
32749: 19807: 122:         "# Boost Discovery Proposal",
32750: 19808: 123:         "",
32751: 19809: 124:         f"- timestamp: {proposal['timestamp']}",
32752: 19810: 125:         f"- candidates: {proposal['candidates_count']}",
32753: 19811: 126:         f"- skipped: {proposal['skipped_count']}",
32754: 19812: 127:         "",
32755: 19813: 128:         "## Candidates",
32756: 19814: 129:         "",
32757: 19815: 130:     ]
32758: 19816: 131:     if candidates:
32759: 19817: 132:         for c in candidates:
32760: 19818: 133:             lines.append(f"- {c['name']} ({c['domain']}) -> {c['location']}")
32761: 19819: 134:     else:
32762: 19820: 135:         lines.append("- none")
32763: 19821: 136:     lines.extend(["", "## Skipped", ""])
32764: 19822: 137:     if skipped:
32765: 19823: 138:         for s in skipped:
32766: 19824: 139:             lines.append(f"- {s['folder']}: {s['reason']}")
32767: 19825: 140:     else:
32768: 19826: 141:         lines.append("- none")
32769: 19827: 142:     md_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
32770: 19828: 143:     if args.apply and candidates:
32771: 19829: 144:         registry_repos = registry.get("repos", [])
32772: 19830: 145:         if not isinstance(registry_repos, list):
32773: 19831: 146:             print("Registry repos field is invalid.")
32774: 19832: 147:             return 1
32775: 19833: 148:         registry_repos.extend(candidates)
32776: 19834: 149:         registry["repos"] = registry_repos
32777: 19835: 150:         registry_path.write_text(json.dumps(registry, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
32778: 19836: 151:         print(f"Applied {len(candidates)} candidates to registry.")
32779: 19837: 152:     else:
32780: 19838: 153:         print("Dry-run mode. No registry changes applied.")
32781: 19839: 154:     print(f"Proposal JSON: {out_path}")
32782: 19840: 155:     print(f"Proposal MD: {md_path}")
32783: 19841: 156:     return 0
32784: 19842: 157: if __name__ == "__main__":
32785: 19843: 158:     raise SystemExit(main())
32786: 19844: </file>
