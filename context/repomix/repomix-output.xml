 8775:  4316: 139: def profile_for_source(source_type: str) -> tuple[str, str, str]:
 8776:  4317: 140:     if source_type == "corporate-docs":
 8777:  4318: 141:         return "evidence-first", "evidence-first", "chunk"
 8778:  4319: 142:     if source_type == "code":
 8779:  4320: 143:         return "strict", "full", "symbol"
 8780:  4321: 144:     if source_type == "snapshot":
 8781:  4322: 145:         return "strict", "lite", "snapshot-scope"
 8782:  4323: 146:     return "balanced", "lite", "manifest"
 8783:  4324: 147: def memory_selection_for_source(source_type: str) -> tuple[list[str], str]:
 8784:  4325: 148:     if source_type == "code":
 8785:  4326: 149:         return ["repo-memory", "routing-memory", "code-memory"], "code route uses structural retrieval"
 8786:  4327: 150:     if source_type == "corporate-docs":
 8787:  4328: 151:         return ["repo-memory", "routing-memory", "enterprise-memory"], "corporate evidence route"
 8788:  4329: 152:     if source_type == "technical-docs":
 8789:  4330: 153:         return ["repo-memory", "routing-memory", "knowledge-memory"], "technical docs route"
 8790:  4331: 154:     return ["repo-memory", "routing-memory"], "capability-aware routing"
 8791:  4332: 155: def runtime_requirements_for_route(source_type: str, engine: str) -> list[str]:
 8792:  4333: 156:     base = ["token-saver-mcp", "codebase-memory-mcp"]
 8793:  4334: 157:     requirements: list[str] = list(base)
 8794:  4335: 158:     engine_l = engine.lower()
 8795:  4336: 159:     if "codegraph" in engine_l:
 8796:  4337: 160:         requirements.extend(["codegraph-command", "codegraph-index"])
 8797:  4338: 161:     if "gitnexus" in engine_l:
 8798:  4339: 162:         requirements.append("gitnexus-command")
 8799:  4340: 163:     if "graphify" in engine_l:
 8800:  4341: 164:         requirements.append("graphify-index")
 8801:  4342: 165:     if "azure rag" in engine_l:
 8802:  4343: 166:         requirements.append("azure-rag-connector")
 8803:  4344: 167:     if "repomix" in engine_l:
 8804:  4345: 168:         requirements.append("repomix-command")
 8805:  4346: 169:     # Keep source-specific connector requirement explicit for evidence routes.
 8806:  4347: 170:     if source_type == "corporate-docs" and "azure-rag-connector" not in requirements:
 8807:  4348: 171:         requirements.append("azure-rag-connector")
 8808:  4349: 172:     seen: set[str] = set()
 8809:  4350: 173:     deduped: list[str] = []
 8810:  4351: 174:     for req in requirements:
 8811:  4352: 175:         if req in seen:
 8812:  4353: 176:             continue
 8813:  4354: 177:         seen.add(req)
 8814:  4355: 178:         deduped.append(req)
 8815:  4356: 179:     return deduped
 8816:  4357: 180: def hitl_policy_for_event(*, intent: str, domain: str, source_type: str, fallback: bool, notes: list[str]) -> dict[str, Any]:
 8817:  4358: 181:     text = f"{intent} {domain} {source_type} {' '.join(notes)}".lower()
 8818:  4359: 182:     high_impact_keywords = [
 8819:  4360: 183:         "deploy",
 8820:  4361: 184:         "production",
 8821:  4362: 185:         "migrate",
 8822:  4363: 186:         "migration",
 8823:  4364: 187:         "delete",
 8824:  4365: 188:         "drop",
 8825:  4366: 189:         "remove",
 8826:  4367: 190:         "destroy",
 8827:  4368: 191:         "governance",
 8828:  4369: 192:         "policy",
 8829:  4370: 193:         "rbac",
 8830:  4371: 194:         "security",
 8831:  4372: 195:         "role",
 8832:  4373: 196:     ]
 8833:  4374: 197:     destructive_keywords = ["delete", "drop", "destroy", "remove"]
 8834:  4375: 198:     triggered = [k for k in high_impact_keywords if k in text]
 8835:  4376: 199:     destructive = any(k in text for k in destructive_keywords)
 8836:  4377: 200:     unresolved_deps = any(n.startswith("unresolved_dependencies=") for n in notes)
 8837:  4378: 201:     required = bool(triggered) or fallback or unresolved_deps
 8838:  4379: 202:     if required:
 8839:  4380: 203:         reasons: list[str] = []
 8840:  4381: 204:         if triggered:
 8841:  4382: 205:             reasons.append("high_impact:" + ",".join(sorted(set(triggered))))
 8842:  4383: 206:         if fallback:
 8843:  4384: 207:             reasons.append("routing_fallback")
 8844:  4385: 208:         if unresolved_deps:
 8845:  4386: 209:             reasons.append("unresolved_dependencies")
 8846:  4387: 210:         action = "block_until_human_approval" if destructive else "request_human_confirmation"
 8847:  4388: 211:         return {
 8848:  4389: 212:             "mode": "always_on_auto",
 8849:  4390: 213:             "required": True,
 8850:  4391: 214:             "action": action,
 8851:  4392: 215:             "reason": ";".join(reasons),
 8852:  4393: 216:         }
 8853:  4394: 217:     return {
 8854:  4395: 218:         "mode": "always_on_auto",
 8855:  4396: 219:         "required": False,
 8856:  4397: 220:         "action": "none",
 8857:  4398: 221:         "reason": "low_risk_route",
 8858:  4399: 222:     }
 8859:  4400: 223: def select_prompt_for_route(
