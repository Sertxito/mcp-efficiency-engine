 44: function Invoke-Step {
 45:     param(
 46:         [string]$Name,
 47:         [scriptblock]$Action,
 48:         [bool]$Required = $true
 49:     )
 50: 
 51:     $start = Get-Date
 52:     $success = $false
 53:     $message = 'ok'
 54: 
 55:     try {
 56:         & $Action
 57:         $success = $true
 58:         Write-Host "[ok] $Name" -ForegroundColor Green
 59:     }
 60:     catch {
 61:         $message = $_.Exception.Message
 62:         if ($Required) {
 63:             $script:HasFailures = $true
 64:             Write-Host "[fail] $Name -> $message" -ForegroundColor Red
 65:         }
 66:         else {
 67:             Write-Host "[warn] $Name -> $message" -ForegroundColor Yellow
 68:         }
 69:     }
 70: 
 71:     $duration = ((Get-Date) - $start).TotalSeconds
 72:     $script:Steps += (New-StepResult -Name $Name -Required $Required -Success $success -DurationSec $duration -Message $message)
 73: }
