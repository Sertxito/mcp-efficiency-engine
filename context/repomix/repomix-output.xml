<file path="scripts/bootstrap-portable.ps1">
 1: param(
 2:   [switch]$ForceTemplateRegistry,
 3:   [switch]$SkipCodebaseMemory,
 4:   [switch]$SkipTokenSaver,
 5:   [switch]$SkipCodegraph,
 6:   [switch]$SkipGitnexus,
 7:   [switch]$SkipGraphify,
 8:   [switch]$SkipRepomix,
 9:   [string]$Owner,
10:   [string]$RepoNamePrefix,
11:   [string]$InitialRepoName,
12:   [string]$InitialRepoDomain,
13:   [string]$InitialRepoLocation,
14:   [switch]$SkipInitialRepo
15: )
16: 
17: Set-StrictMode -Version Latest
18: $ErrorActionPreference = "Stop"
19: 
20: $repoRoot = (Resolve-Path (Join-Path $PSScriptRoot '..')).Path
21: Set-Location $repoRoot
22: 
23: $registryPath = Join-Path $repoRoot 'repo-registry\repos.yml'
24: $summaryReportPath = Join-Path $repoRoot 'repo-intake\generated\reports\SUMMARY.json'
25: $initRegistryArgs = @('.\scripts\intake\init-template-registry.ps1')
26: if (-not [string]::IsNullOrWhiteSpace($Owner)) { $initRegistryArgs += @('-Owner', $Owner) }
27: if (-not [string]::IsNullOrWhiteSpace($RepoNamePrefix)) { $initRegistryArgs += @('-RepoNamePrefix', $RepoNamePrefix) }
28: if (-not [string]::IsNullOrWhiteSpace($InitialRepoName)) { $initRegistryArgs += @('-InitialRepoName', $InitialRepoName) }
29: if (-not [string]::IsNullOrWhiteSpace($InitialRepoDomain)) { $initRegistryArgs += @('-InitialRepoDomain', $InitialRepoDomain) }
30: if (-not [string]::IsNullOrWhiteSpace($InitialRepoLocation)) { $initRegistryArgs += @('-InitialRepoLocation', $InitialRepoLocation) }
31: if ($SkipInitialRepo) { $initRegistryArgs += '-SkipInitialRepo' }
32: 
33: Write-Host '== Portable bootstrap ==' 
34: 
35: pwsh -NoProfile -ExecutionPolicy Bypass -File .\scripts\setup\setup-prerequisites.ps1 `
36:   -PortableMode `
37:   -SkipCodebaseMemory:$SkipCodebaseMemory `
38:   -SkipTokenSaver:$SkipTokenSaver `
39:   -SkipCodegraph:$SkipCodegraph `
40:   -SkipGitnexus:$SkipGitnexus `
41:   -SkipGraphify:$SkipGraphify `
42:   -SkipRepomix:$SkipRepomix
43: if ($LASTEXITCODE -ne 0) {
44:   throw 'Portable setup prerequisites failed.'
45: }
46: 
47: pwsh -NoProfile -ExecutionPolicy Bypass -File .\scripts\setup\validate-context.ps1 -PortableMode
48: if ($LASTEXITCODE -ne 0) {
49:   throw 'Portable context validation failed.'
50: }
51: 
52: if (-not (Test-Path $registryPath)) {
53:   Write-Host 'No repo registry found. Initializing portable template registry...'
54:   pwsh -NoProfile -ExecutionPolicy Bypass -File @initRegistryArgs
55:   if ($LASTEXITCODE -ne 0) {
56:     throw 'Template registry initialization failed.'
57:   }
58: }
59: elseif ($ForceTemplateRegistry) {
60:   Write-Host 'Forcing template registry initialization...'
61:   pwsh -NoProfile -ExecutionPolicy Bypass -File @($initRegistryArgs + '-Force')
62:   if ($LASTEXITCODE -ne 0) {
63:     throw 'Forced template registry initialization failed.'
64:   }
65: }
66: else {
67:   Write-Host 'Registry already exists. Reusing current repo-registry\repos.yml.'
68: }
69: 
70: pwsh -NoProfile -ExecutionPolicy Bypass -File .\scripts\intake\run-repo-intake.ps1
71: if ($LASTEXITCODE -ne 0) {
72:   throw 'Repo intake failed during portable bootstrap.'
73: }
74: 
75: Write-Host ''
76: Write-Host 'Portable bootstrap completed.'
77: if (Test-Path $registryPath) {
78:   $registry = Get-Content -Raw -Path $registryPath | ConvertFrom-Json -Depth 20
79:   $registryMode = if (($registry.PSObject.Properties.Name -contains 'registry_mode') -and -not [string]::IsNullOrWhiteSpace([string]$registry.registry_mode)) { [string]$registry.registry_mode } else { 'enterprise' }
80:   $repoCount = if (($registry.PSObject.Properties.Name -contains 'repos') -and $null -ne $registry.repos) { @($registry.repos).Count } else { 0 }
81:   Write-Host "Registry summary: mode=$registryMode, repos=$repoCount"
82: }
83: if (Test-Path $summaryReportPath) {
84:   $summary = Get-Content -Raw -Path $summaryReportPath | ConvertFrom-Json -Depth 20
85:   Write-Host "Intake summary: generated for $($summary.repos_count) repos"
86: }
87: Write-Host 'Artifacts:'
88: Write-Host '  - repo-intake/generated/reports/setup-validation.json'
89: Write-Host '  - repo-intake/generated/reports/repo-registry-validation.json'
90: Write-Host '  - repo-intake/generated/reports/SUMMARY.json'
</file>

