499: }
500: 
501: if (-not $SkipCodegraphStatus) {
502:     Invoke-Step -Name 'Check codegraph status' -Action {
503:         if (-not (Get-Command codegraph -ErrorAction SilentlyContinue)) {
504:             throw 'codegraph command not found'
505:         }
506: 
507:         & codegraph status
