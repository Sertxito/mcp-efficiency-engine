<file path="scripts/intake/validate-repo-registry.py">
  1: from __future__ import annotations
  2: import argparse
  3: import json
  4: import re
  5: from dataclasses import dataclass
  6: from datetime import datetime, timezone
  7: from pathlib import Path
  8: from typing import Any
  9: try:
 10:     import yaml  # type: ignore
 11: except Exception:
 12:     yaml = None
 13: def utc_now() -> str:
 14:     return datetime.now(timezone.utc).isoformat()
 15: def parse_simple_yml(path: Path) -> dict[str, Any]:
 16:     repos: list[dict[str, Any]] = []
 17:     current: dict[str, Any] | None = None
 18:     for line in path.read_text(encoding="utf-8").splitlines():
 19:         st = line.strip()
 20:         if st.startswith("- name:"):
 21:             if current:
 22:                 repos.append(current)
 23:             current = {"name": st.split(":", 1)[1].strip()}
 24:         elif current and ":" in st and not st.startswith("#"):
 25:             k, v = st.split(":", 1)
 26:             k = k.strip()
 27:             v = v.strip().strip('"')
 28:             if k in {"domain", "location", "type"}:
 29:                 current[k] = v
 30:     if current:
 31:         repos.append(current)
 32:     return {"schema_version": "1.0", "repos": repos}
 33: def load_registry(path: Path) -> dict[str, Any]:
 34:     content = path.read_text(encoding="utf-8")
 35:     # JSON-first support (JSON is valid YAML, but this path avoids extra deps).
 36:     if content.lstrip().startswith("{"):
 37:         return json.loads(content)
 38:     if yaml is not None:
 39:         data = yaml.safe_load(content) or {}
 40:         if isinstance(data, dict):
 41:             return data
 42:     return parse_simple_yml(path)
 43: @dataclass
 44: class ValidationResult:
 45:     errors: list[str]
 46:     warnings: list[str]
 47: def validate(registry: dict[str, Any], strict: bool, repo_root: Path) -> ValidationResult:
 48:     errors: list[str] = []
 49:     warnings: list[str] = []
 50:     registry_mode = str(registry.get("registry_mode", "enterprise")).strip().lower() or "enterprise"
 51:     repos = registry.get("repos")
 52:     if not isinstance(repos, list):
 53:         return ValidationResult(errors=["Registry must define a repos list."], warnings=[])
 54:     if not repos:
 55:         if strict or registry_mode != "template":
 56:             return ValidationResult(errors=["Registry must define a non-empty repos list."], warnings=[])
 57:         warnings.append("Template registry has no repos yet.")
 58:         return ValidationResult(errors=[], warnings=warnings)
 59:     schema_version = str(registry.get("schema_version", "1.0"))
 60:     is_v2 = schema_version >= "2.0"
 61:     governance = registry.get("governance", {}) if isinstance(registry.get("governance", {}), dict) else {}
 62:     repo_name_prefix = str(governance.get("repo_name_prefix", "boost_")).strip() or "boost_"
 63:     names: set[str] = set()
 64:     graph: dict[str, list[str]] = {}
 65:     for repo in repos:
 66:         if not isinstance(repo, dict):
 67:             errors.append("Each repo entry must be an object.")
 68:             continue
 69:         name = str(repo.get("name", "")).strip()
 70:         if not name:
 71:             errors.append("Repo is missing required field: name")
 72:             continue
 73:         if strict or is_v2:
 74:             if not name.startswith(repo_name_prefix):
 75:                 errors.append(
 76:                     f"Repo '{name}' does not satisfy naming contract. Expected prefix '{repo_name_prefix}'."
 77:                 )
 78:         if name in names:
 79:             errors.append(f"Duplicate repo name: {name}")
 80:             continue
 81:         names.add(name)
 82:         for field in ("domain", "location", "type"):
 83:             if not str(repo.get(field, "")).strip():
 84:                 errors.append(f"Repo '{name}' is missing required field: {field}")
 85:         if str(repo.get("type", "")).strip() and repo.get("type") != "local":
 86:             errors.append(f"Repo '{name}' type must be 'local' in this phase.")
 87:         location = str(repo.get("location", "")).strip()
 88:         if location:
 89:             resolved = (repo_root / location).resolve()
 90:             if not resolved.exists():
 91:                 if bool(repo.get("optional", False)):
 92:                     warnings.append(f"Optional repo '{name}' location does not exist: {location}")
 93:                 else:
 94:                     errors.append(f"Repo '{name}' location does not exist: {location}")
 95:         deps = repo.get("dependencies", [])
 96:         dep_refs: list[str] = []
 97:         if deps:
 98:             if not isinstance(deps, list):
 99:                 errors.append(f"Repo '{name}' dependencies must be a list.")
100:             else:
101:                 for dep in deps:
102:                     if not isinstance(dep, dict) or not str(dep.get("ref", "")).strip():
103:                         errors.append(f"Repo '{name}' has a dependency without ref.")
104:                         continue
105:                     dep_refs.append(str(dep["ref"]))
106:         graph[name] = dep_refs
107:         if strict or is_v2:
108:             approval = repo.get("approval")
109:             if not isinstance(approval, dict):
110:                 errors.append(f"Repo '{name}' requires approval block in v2/strict mode.")
111:             else:
112:                 if approval.get("status") != "approved":
113:                     errors.append(f"Repo '{name}' is not approved (approval.status must be 'approved').")
114:                 if not str(approval.get("approved_by", "")).strip():
115:                     errors.append(f"Repo '{name}' missing approval.approved_by")
116:                 if not str(approval.get("approved_date", "")).strip():
117:                     errors.append(f"Repo '{name}' missing approval.approved_date")
118:                 if not str(approval.get("review_ticket", "")).strip():
119:                     warnings.append(f"Repo '{name}' missing approval.review_ticket")
120:     for src, dep_refs in graph.items():
121:         for dep in dep_refs:
122:             if dep not in names:
123:                 errors.append(f"Repo '{src}' depends on unknown repo '{dep}'.")
124:     # Cycle detection via DFS colors: 0=unseen, 1=visiting, 2=done
125:     state: dict[str, int] = {name: 0 for name in names}
126:     def visit(node: str) -> None:
127:         if state[node] == 1:
128:             errors.append(f"Dependency cycle detected at '{node}'.")
129:             return
130:         if state[node] == 2:
131:             return
132:         state[node] = 1
133:         for nxt in graph.get(node, []):
134:             if nxt in state:
135:                 visit(nxt)
136:         state[node] = 2
137:     for name in names:
138:         visit(name)
139:     return ValidationResult(errors=errors, warnings=warnings)
140: def write_report(
141:     path: Path,
142:     registry_path: Path,
143:     registry_mode: str,
144:     schema_version: str,
145:     strict: bool,
146:     result: ValidationResult,
147:     repos_count: int,
148: ) -> None:
149:     report = {
150:         "timestamp": utc_now(),
151:         "registry_path": str(registry_path).replace("\\", "/"),
152:         "registry_mode": str(registry_mode),
153:         "schema_version": schema_version,
154:         "strict_mode": strict,
155:         "repos_count": repos_count,
156:         "errors_count": len(result.errors),
157:         "warnings_count": len(result.warnings),
158:         "errors": result.errors,
159:         "warnings": result.warnings,
160:     }
161:     path.parent.mkdir(parents=True, exist_ok=True)
162:     path.write_text(json.dumps(report, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
163: def main() -> int:
164:     parser = argparse.ArgumentParser(description="Validate repo-registry with strict governance checks.")
165:     parser.add_argument("--registry", default="repo-registry/repos.yml", help="Registry file path")
166:     parser.add_argument("--strict", action="store_true", help="Enable strict governance checks")
167:     args = parser.parse_args()
168:     repo_root = Path(__file__).resolve().parents[2]
169:     registry_path = (repo_root / args.registry).resolve()
170:     if not registry_path.exists():
171:         print(f"Missing registry file: {registry_path}")
172:         return 1
173:     try:
174:         registry = load_registry(registry_path)
175:     except Exception as exc:
176:         print(f"Failed to parse registry file: {exc}")
177:         return 1
178:     registry_mode = str(registry.get("registry_mode", "enterprise")).strip().lower() or "enterprise"
179:     schema_version = str(registry.get("schema_version", "1.0"))
180:     repos_count = len(registry.get("repos", [])) if isinstance(registry.get("repos", []), list) else 0
181:     result = validate(registry=registry, strict=args.strict, repo_root=repo_root)
182:     report_path = repo_root / "repo-intake/generated/reports/repo-registry-validation.json"
183:     write_report(
184:         path=report_path,
185:         registry_path=registry_path,
186:         registry_mode=registry_mode,
187:         schema_version=schema_version,
188:         strict=args.strict,
189:         result=result,
190:         repos_count=repos_count,
191:     )
192:     if result.errors:
193:         print("Repo registry validation failed.")
194:         for err in result.errors:
195:             print(f"- {err}")
196:         print(f"Report: {report_path}")
197:         return 1
198:     print("Repo registry validation OK.")
199:     if result.warnings:
200:         print("Warnings:")
201:         for warn in result.warnings:
202:             print(f"- {warn}")
203:     print(f"Report: {report_path}")
204:     return 0
205: if __name__ == "__main__":
206:     raise SystemExit(main())
</file>

