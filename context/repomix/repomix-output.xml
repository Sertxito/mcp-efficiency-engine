 89:             if str(c.get("capability", "")).strip() == capability:
 90:                 candidates.append((c, "selected_by=capability"))
 91:     for c in capabilities:
 92:         if str(c.get("domain", "")).strip() == domain:
 93:             candidates.append((c, "selected_by=domain_capability_index"))
 94:     candidate: dict[str, Any] | None = None
 95:     for item, reason in candidates:
 96:         repo_name = str(item.get("repo", "")).strip()
 97:         registry_repo = repo_by_name.get(repo_name)
 98:         if not registry_repo:
 99:             notes.append(f"repo_not_found_in_registry={repo_name}")
100:             continue
101:         if not is_repo_approved(registry_repo):
102:             notes.append(f"repo_not_approved={repo_name}")
103:             continue
104:         manifest = manifests.get(repo_name, {})
105:         deps = manifest.get("dependencies", []) if isinstance(manifest, dict) else []
106:         unresolved: list[str] = []
107:         for dep in deps:
108:             if not isinstance(dep, dict):
109:                 continue
110:             dep_ref = str(dep.get("ref", "")).strip()
111:             if not dep_ref:
112:                 continue
113:             dep_repo = repo_by_name.get(dep_ref)
114:             dep_manifest_exists = dep_ref in manifests
115:             dep_ok = dep_repo is not None and is_repo_approved(dep_repo) and dep_manifest_exists
116:             if not dep_ok:
117:                 unresolved.append(dep_ref)
118:         if unresolved:
119:             notes.append("unresolved_dependencies=" + ",".join(unresolved))
120:             continue
121:         candidate = item
122:         notes.append(reason)
123:         break
124:     if candidate is not None:
125:         route = {
126:             "agent": str(candidate.get("agent", "dev-agent")),
127:             "engine": str(candidate.get("engine", "CodeGraph")),
128:             "capability": str(candidate.get("capability", "dev-coding")),
129:             "repo": str(candidate.get("repo", "")),
130:         }
131:         return route, notes
132:     fallback = domain_defaults(domain)
133:     notes.append("selected_by=domain_default")
134:     return {
135:         "agent": fallback["agent"],
136:         "engine": fallback["engine"],
137:         "capability": fallback["capability"],
138:         "repo": "",
139:     }, notes
140: def profile_for_source(source_type: str) -> tuple[str, str, str]:
141:     if source_type == "corporate-docs":
142:         return "evidence-first", "evidence-first", "chunk"
143:     if source_type == "code":
144:         return "strict", "full", "symbol"
145:     if source_type == "snapshot":
146:         return "strict", "lite", "snapshot-scope"
147:     return "balanced", "lite", "manifest"
148: def memory_selection_for_source(source_type: str) -> tuple[list[str], str]:
149:     if source_type == "code":
150:         return ["repo-memory", "routing-memory", "code-memory"], "code route uses structural retrieval"
151:     if source_type == "corporate-docs":
152:         return ["repo-memory", "routing-memory", "enterprise-memory"], "corporate evidence route"
153:     if source_type == "technical-docs":
154:         return ["repo-memory", "routing-memory", "knowledge-memory"], "technical docs route"
155:     return ["repo-memory", "routing-memory"], "capability-aware routing"
156: def runtime_requirements_for_route(source_type: str, engine: str) -> list[str]:
157:     base = ["token-saver-mcp", "codebase-memory-mcp"]
158:     requirements: list[str] = list(base)
159:     engine_l = engine.lower()
160:     if "codegraph" in engine_l:
161:         requirements.extend(["codegraph-command", "codegraph-index"])
162:     if "gitnexus" in engine_l:
163:         requirements.append("gitnexus-command")
164:     if "graphify" in engine_l:
165:         requirements.append("graphify-index")
166:     if "azure rag" in engine_l:
167:         requirements.append("azure-rag-connector")
168:     if "repomix" in engine_l:
169:         requirements.append("repomix-command")
170:     # Keep source-specific connector requirement explicit for evidence routes.
171:     if source_type == "corporate-docs" and "azure-rag-connector" not in requirements:
172:         requirements.append("azure-rag-connector")
173:     seen: set[str] = set()
174:     deduped: list[str] = []
175:     for req in requirements:
176:         if req in seen:
177:             continue
178:         seen.add(req)
179:         deduped.append(req)
180:     return deduped
181: def hitl_policy_for_event(*, intent: str, domain: str, source_type: str, fallback: bool, notes: list[str]) -> dict[str, Any]:
182:     text = f"{intent} {domain} {source_type} {' '.join(notes)}".lower()
183:     high_impact_keywords = [
184:         "deploy",
185:         "production",
186:         "migrate",
187:         "migration",
188:         "delete",
189:         "drop",
190:         "remove",
191:         "destroy",
192:         "governance",
193:         "policy",
194:         "rbac",
195:         "security",
196:         "role",
197:     ]
198:     destructive_keywords = ["delete", "drop", "destroy", "remove"]
199:     triggered = [k for k in high_impact_keywords if k in text]
200:     destructive = any(k in text for k in destructive_keywords)
201:     unresolved_deps = any(n.startswith("unresolved_dependencies=") for n in notes)
202:     required = bool(triggered) or fallback or unresolved_deps
203:     if required:
204:         reasons: list[str] = []
205:         if triggered:
206:             reasons.append("high_impact:" + ",".join(sorted(set(triggered))))
207:         if fallback:
208:             reasons.append("routing_fallback")
209:         if unresolved_deps:
210:             reasons.append("unresolved_dependencies")
211:         action = "block_until_human_approval" if destructive else "request_human_confirmation"
212:         return {
213:             "mode": "always_on_auto",
214:             "required": True,
215:             "action": action,
216:             "reason": ";".join(reasons),
217:         }
218:     return {
219:         "mode": "always_on_auto",
220:         "required": False,
221:         "action": "none",
222:         "reason": "low_risk_route",
223:     }
224: def select_prompt_for_route(
225:     *,
226:     intent: str,
227:     domain: str,
228:     source_type: str,
229:     agent: str,
230:     prompt_root: Path,
231: ) -> tuple[str, bool]:
232:     """Return prompt path relative to repo root and whether it exists."""
233:     # Highest-priority route: corporate evidence questions.
234:     if source_type == "corporate-docs" or domain == "azure-rag" or agent == "rag-azure-agent":
235:         candidate = ".github/prompts/azure-rag.query.prompt.md"
236:     # Code-centric workflows.
237:     elif domain == "dev" and ("bug" in intent or intent == "bug-fix"):
238:         candidate = ".github/prompts/dev.fix-bug.prompt.md"
239:     elif domain == "legacy":
240:         candidate = ".github/prompts/legacy.impact-analysis.prompt.md"
241:     # Data/document technical flows.
242:     elif domain == "dba":
243:         candidate = ".github/prompts/dba.query-review.prompt.md"
244:     elif agent == "rag-local-agent" or source_type == "technical-docs":
245:         candidate = ".github/prompts/rag.knowledge-answer.prompt.md"
246:     elif domain == "snapshot" or source_type == "snapshot":
247:         candidate = ".github/prompts/cavecrew.prompt.md"
248:     else:
249:         candidate = ".github/prompts/auto-route.prompt.md"
250:     exists = (prompt_root / candidate).exists()
251:     return candidate, exists
252: def select_skill_for_route(*, capability: str, skill_root: Path) -> tuple[str, bool]:
253:     """Return skill file path relative to repo root and whether it exists."""
254:     normalized = capability.strip()
255:     candidate = f".github/skills/{normalized}/SKILL.md" if normalized else ".github/skills/token-saver/SKILL.md"
256:     exists = (skill_root / candidate).exists()
257:     if exists:
258:         return candidate, True
259:     # Safe fallback: always-on optimization skill.
260:     fallback = ".github/skills/token-saver/SKILL.md"
261:     return fallback, (skill_root / fallback).exists()
262: def append_jsonl(path: Path, event: dict[str, Any]) -> None:
263:     path.parent.mkdir(parents=True, exist_ok=True)
264:     with path.open("a", encoding="utf-8") as fh:
265:         fh.write(json.dumps(event, ensure_ascii=False) + "\n")
266: def main() -> int:
267:     parser = argparse.ArgumentParser(description="Resolve routing with capability-aware local-first policy.")
268:     parser.add_argument("--input", required=True, help="Original user input for routing event")
269:     parser.add_argument("--intent", required=True, help="Detected intent")
270:     parser.add_argument("--domain", required=True, help="Detected domain")
271:     parser.add_argument("--source-type", required=True, help="code|technical-docs|corporate-docs|snapshot")
272:     parser.add_argument("--capability", default="", help="Optional requested capability")
273:     parser.add_argument("--registry", default="repo-registry/repos.yml")
274:     parser.add_argument("--generated-root", default="repo-intake/generated")
275:     parser.add_argument("--output", default="observability/logs/routing-decisions.jsonl")
276:     args = parser.parse_args()
277:     repo_root = Path(__file__).resolve().parents[2]
278:     registry = load_registry((repo_root / args.registry).resolve())
279:     capabilities = load_capability_index((repo_root / args.generated_root).resolve())
280:     manifests = load_manifest_index((repo_root / args.generated_root).resolve())
281:     route, notes = pick_route(
282:         registry=registry,
283:         capabilities=capabilities,
284:         manifests=manifests,
285:         domain=args.domain,
286:         capability=args.capability.strip() or None,
287:     )
288:     token_saver_profile, caveman_profile, context_strategy = profile_for_source(args.source_type)
289:     fallback = any(n.startswith("selected_by=domain_default") for n in notes)
290:     # Grounding is strict in production: no source reference means not grounded.
291:     grounded = route["repo"] != ""
292:     selected_memories, memory_reason = memory_selection_for_source(args.source_type)
293:     selected_prompt, prompt_exists = select_prompt_for_route(
294:         intent=args.intent,
295:         domain=args.domain,
296:         source_type=args.source_type,
297:         agent=route["agent"],
298:         prompt_root=repo_root,
299:     )
300:     if not prompt_exists:
301:         notes.append(f"prompt_not_found={selected_prompt}")
302:     selected_skill, skill_exists = select_skill_for_route(
303:         capability=route["capability"],
304:         skill_root=repo_root,
305:     )
306:     if not skill_exists:
307:         notes.append(f"skill_not_found={selected_skill}")
308:     event_id = str(uuid.uuid4())
309:     hitl = hitl_policy_for_event(
310:         intent=args.intent,
311:         domain=args.domain,
312:         source_type=args.source_type,
313:         fallback=fallback,
314:         notes=notes,
315:     )
316:     event = {
317:         "event_id": event_id,
318:         "timestamp": utc_now(),
319:         "input": args.input,
320:         "intent": args.intent,
321:         "source_type": args.source_type,
322:         "agent": route["agent"],
323:         "engine": route["engine"],
324:         "optimization_profile": f"{token_saver_profile}+{caveman_profile}",
325:         "fallback": fallback,
326:         "grounded": grounded,
327:         "sources": [f"repo:{route['repo']}"] if route["repo"] else [],
328:         "notes": ";".join(notes) if notes else "",
329:         "prompt": {
330:             "selected": selected_prompt,
331:             "exists": prompt_exists,
332:             "selection_mode": "auto",
333:         },
334:         "skill": {
335:             "selected": selected_skill,
336:             "exists": skill_exists,
337:             "selection_mode": "auto",
338:         },
339:         "optimization": {
340:             "token_saver": "always_on",
341:             "token_saver_profile": token_saver_profile,
342:             "caveman": "always_on",
343:             "caveman_profile": caveman_profile,
344:             "sources_preserved": True,
345:             "context_reduction_strategy": context_strategy,
346:         },
347:         "memory": {
348:             "selected": selected_memories,
349:             "reason": memory_reason,
350:         },
351:         "requirements": runtime_requirements_for_route(args.source_type, route["engine"]),
352:         "learning": {
353:             "used_pattern": f"{args.domain}+{args.intent}",
354:             # Real success must be written post-execution by the feedback updater.
355:             "success": None,
356:             "outcome_status": "pending",
357:             "fallback": fallback,
358:             "confidence": 0.9 if not fallback else 0.7,
359:         },
360:         "hitl": hitl,
361:     }
362:     output_path = (repo_root / args.output).resolve()
363:     append_jsonl(output_path, event)
364:     print(json.dumps(event, indent=2, ensure_ascii=False))
365:     print(f"Event appended to: {output_path}")
366:     return 0
367: if __name__ == "__main__":
368:     raise SystemExit(main())
