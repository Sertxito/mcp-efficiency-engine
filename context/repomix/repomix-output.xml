87:         },
88:         "notes": args.notes,
89:     }
90:     output_path.parent.mkdir(parents=True, exist_ok=True)
91:     with output_path.open("a", encoding="utf-8") as fh:
92:         fh.write(json.dumps(metric, ensure_ascii=False) + "\n")
93:     print(f"Iteration metrics recorded for event_id: {event_id}")
94:     print(f"Output: {output_path}")
