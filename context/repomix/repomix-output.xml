129:   $errors += "Missing Python launcher (py/python) required for graphify MCP"
130: }
131: else {
132:   $pythonCmd = "python"
133:   $pythonArgs = @("-c", "import graphify.serve, mcp; print('ok')")
134:   if (Get-Command py -ErrorAction SilentlyContinue) {
135:     $pythonCmd = "py"
136:     $pythonArgs = @("-3.14", "-c", "import graphify.serve, mcp; print('ok')")
137:   }
