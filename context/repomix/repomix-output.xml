 26: function New-StepResult {
 27:     param(
 28:         [string]$Name,
 29:         [bool]$Required,
 30:         [bool]$Success,
 31:         [double]$DurationSec,
 32:         [string]$Message
 33:     )
 34: 
 35:     return [ordered]@{
 36:         name = $Name
 37:         required = $Required
 38:         success = $Success
 39:         duration_sec = [math]::Round($DurationSec, 2)
 40:         message = $Message
 41:     }
 42: }
