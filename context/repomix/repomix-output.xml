17901:  4959:   500:  29:           cache-dependency-path: requirements.txt
17902:  4960:   501:  30:       - name: Upgrade pip
17903:  4961:   502:  31:         run: python -m pip install --upgrade pip
17904:  4962:   503:  32:       - name: Install dependencies (if requirements.txt exists)
17905:  4963:   504:  33:         run: |
17906:  4964:   505:  34:           if [ -f requirements.txt ]; then
17907:  4965:   506:  35:             python -m pip install -r requirements.txt
17908:  4966:   507:  36:           fi
17909:  4967:   508:  37:       - name: Run routing evals
17910:  4968:   509:  38:         run: python ./scripts/intake/run-routing-evals.py
17911:  4969:   510:  39:       - name: Build learning loop report
17912:  4970:   511:  40:         run: python ./scripts/learning/learning-loop-report.py
17913:  4971:   512:  41:       - name: Build iteration value report
17914:  4972:   513:  42:         run: python ./scripts/learning/iteration-value-report.py
17915:  4973:   514:  43:       - name: Enforce AutoLearning gate
17916:  4974:   515:  44:         run: python ./scripts/learning/autolearning-gate.py
17917:  4975:   516:  45:       - name: Enforce zero failed cases
17918:  4976:   517:  46:         run: |
17919:  4977:   518:  47:           python - <<'PY'
17920:  4978:   519:  48:           import json
17921:  4979:   520:  49:           from pathlib import Path
17922:  4980:   521:  50:           report = Path('observability/evals/routing-eval-report.json')
17923:  4981:   522:  51:           if not report.exists():
17924:  4982:   523:  52:               raise SystemExit('routing-eval-report.json not found')
17925:  4983:   524:  53:           data = json.loads(report.read_text(encoding='utf-8'))
17926:  4984:   525:  54:           failed = int(data.get('cases_failed', 0))
17927:  4985:   526:  55:           total = int(data.get('cases_total', 0))
17928:  4986:   527:  56:           passed = int(data.get('cases_passed', 0))
17929:  4987:   528:  57:           print(f'Routing evals: {passed}/{total} passed, failed={failed}')
17930:  4988:   529:  58:           if failed > 0:
17931:  4989:   530:  59:               raise SystemExit(1)
17932:  4990:   531:  60:           PY
17933:  4991:   532:  61:       - name: Upload eval artifacts
17934:  4992:   533:  62:         if: always()
17935:  4993:   534:  63:         uses: actions/upload-artifact@v4
17936:  4994:   535:  64:         with:
17937:  4995:   536:  65:           name: routing-evals-${{ github.run_number }}
17938:  4996:   537:  66:           if-no-files-found: warn
17939:  4997:   538:  67:           path: |
17940:  4998:   539:  68:             observability/evals/routing-eval-report.json
17941:  4999:   540:  69:             observability/evals/learning-loop-report.json
17942:  5000:   541:  70:             observability/evals/learning-loop-report.md
17943:  5001:   542:  71:             observability/evals/iteration-value-report.json
17944:  5002:   543:  72:             observability/evals/iteration-value-report.md
17945:  5003:   544:  73:   publish-summary:
17946:  5004:   545:  74:     runs-on: ubuntu-latest
17947:  5005:   546:  75:     timeout-minutes: 5
17948:  5006:   547:  76:     needs:
17949:  5007:   548:  77:       - routing-evals
17950:  5008:   549:  78:     if: always()
17951:  5009:   550:  79:     steps:
17952:  5010:   551:  80:       - name: Download eval artifacts
17953:  5011:   552:  81:         id: download_artifacts
17954:  5012:   553:  82:         continue-on-error: true
17955:  5013:   554:  83:         uses: actions/download-artifact@v4
17956:  5014:   555:  84:         with:
17957:  5015:   556:  85:           name: routing-evals-${{ github.run_number }}
17958:  5016:   557:  86:           path: artifacts
17959:  5017:   558:  87:       - name: Publish workflow summary
17960:  5018:   559:  88:         if: always()
17961:  5019:   560:  89:         run: |
17962:  5020:   561:  90:           python - <<'PY'
17963:  5021:   562:  91:           import json
17964:  5022:   563:  92:           import os
17965:  5023:   564:  93:           from pathlib import Path
17966:  5024:   565:  94:           summary_path = Path(os.environ['GITHUB_STEP_SUMMARY'])
