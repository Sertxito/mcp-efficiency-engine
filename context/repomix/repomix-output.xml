38:     parser.add_argument("--estimated-cost-usd", type=float, default=0.0)
39:     parser.add_argument("--notes", default="")
40:     parser.add_argument("--routing-log", default="observability/logs/routing-decisions.jsonl")
41:     parser.add_argument("--output", default="observability/logs/iteration-metrics.jsonl")
42:     args = parser.parse_args()
