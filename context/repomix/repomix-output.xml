 14: function Test-Command {
 15:     param([Parameter(Mandatory = $true)][string]$Name)
 16: 
 17:     return [bool](Get-Command -Name $Name -ErrorAction SilentlyContinue)
 18: }
 19: 
 20: function Install-NpmGlobalPackage {
 21:     param(
 22:         [Parameter(Mandatory = $true)][string]$Package,
 23:         [Parameter(Mandatory = $true)][string]$ExpectedCommand
 24:     )
 25: 
 26:     if (Test-Command $ExpectedCommand) {
 27:         Write-Host "[ok] $ExpectedCommand already installed"
 28:         return
 29:     }
 30: 
 31:     if (-not (Test-Command 'npm')) {
 32:         throw "npm is required to install $Package. Install Node.js first: https://nodejs.org/"
 33:     }
 34: 
 35:     Write-Host "[install] npm install -g $Package"
 36:     npm install -g $Package
 37: }
 38: 
 39: function Test-PythonImport {
 40:     param(
 41:         [Parameter(Mandatory = $true)][string]$PythonCommand,
 42:         [string[]]$PythonArgs = @(),
 43:         [Parameter(Mandatory = $true)][string]$Module
 44:     )
 45: 
 46:     & $PythonCommand @PythonArgs -c "import $Module" *> $null
 47:     return ($LASTEXITCODE -eq 0)
 48: }
 49: 
 50: function Resolve-PythonCommand {
 51:     if (Test-Command 'py') {
 52:         return @('py', '-3.14')
 53:     }
 54:     if (Test-Command 'python') {
 55:         return @('python')
 56:     }
 57:     throw 'Python 3.14 is required for graphify MCP. Install Python first: https://www.python.org/downloads/'
 58: }
 59: 
 60: Write-Host '== MCP platform prerequisites setup =='
 61: 
 62: if (-not $SkipCodebaseMemory) {
 63:     if (Test-Command 'codebase-memory-mcp') {
 64:         Write-Host '[ok] codebase-memory-mcp already installed'
 65:     }
 66:     else {
 67:         Write-Host '[install] codebase-memory-mcp via official Windows setup script'
 68:         Invoke-RestMethod https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/scripts/setup-windows.ps1 | Invoke-Expression
 69:     }
 70: }
 71: 
 72: if (-not $SkipTokenSaver) {
 73:     Install-NpmGlobalPackage -Package 'token-saver-mcp' -ExpectedCommand 'token-saver-mcp'
 74: }
 75: 
 76: if (-not $SkipCodegraph) {
 77:     Install-NpmGlobalPackage -Package '@colbymchenry/codegraph' -ExpectedCommand 'codegraph'
 78:     Write-Host '[setup] codegraph install'
 79:     codegraph install
 80:     if (-not (Test-Path '.codegraph')) {
 81:         Write-Host '[setup] codegraph init -i'
 82:         codegraph init -i
 83:     }
 84:     else {
