<file path="scripts/setup/validate-context.ps1">
  1: param(
  2:   [switch]$PortableMode
  3: )
  4: 
  5: Set-StrictMode -Version Latest
  6: $ErrorActionPreference = 'Stop'
  7: 
  8: $repoRoot = (Resolve-Path (Join-Path $PSScriptRoot '..\..')).Path
  9: Set-Location $repoRoot
 10: $toolingManifestPath = Join-Path $repoRoot 'tooling/tooling.manifest.json'
 11: $setupValidationReportPath = Join-Path $repoRoot 'repo-intake/generated/reports/setup-validation.json'
 12: 
 13: function Get-ToolingManifest {
 14:   param([Parameter(Mandatory = $true)][string]$Path)
 15: 
 16:   if (-not (Test-Path $Path)) {
 17:     throw "Missing tooling manifest: $Path"
 18:   }
 19: 
 20:   return Get-Content -Raw -Path $Path | ConvertFrom-Json -Depth 20
 21: }
 22: 
 23: function Test-RequiredInMode {
 24:   param(
 25:     [Parameter(Mandatory = $true)][object]$Tool,
 26:     [Parameter(Mandatory = $true)][string]$Mode
 27:   )
 28: 
 29:   if (-not ($Tool.PSObject.Properties.Name -contains 'required_in')) {
 30:     return $true
 31:   }
 32: 
 33:   foreach ($entry in @($Tool.required_in)) {
 34:     if ([string]$entry -eq $Mode) {
 35:       return $true
 36:     }
 37:   }
 38: 
 39:   return $false
 40: }
 41: 
 42: function Write-SetupValidationReport {
 43:   param(
 44:     [Parameter(Mandatory = $true)][string]$Path,
 45:     [Parameter(Mandatory = $true)][hashtable]$Report
 46:   )
 47: 
 48:   $reportDir = Split-Path -Parent $Path
 49:   if (-not (Test-Path $reportDir)) {
 50:     New-Item -ItemType Directory -Path $reportDir -Force | Out-Null
 51:   }
 52: 
 53:   $Report | ConvertTo-Json -Depth 20 | Set-Content -Path $Path -Encoding utf8
 54: }
 55: 
 56: if ($PortableMode) {
 57:   Write-Host "Validating portable core..."
 58: }
 59: else {
