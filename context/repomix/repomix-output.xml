<file path="scripts/discovery/discover-boost-repos.py">
  1: from __future__ import annotations
  2: import argparse
  3: import json
  4: import re
  5: from datetime import datetime, timezone
  6: from pathlib import Path
  7: from typing import Any
  8: def utc_now() -> str:
  9:     return datetime.now(timezone.utc).isoformat()
 10: def load_registry(path: Path) -> dict[str, Any]:
 11:     content = path.read_text(encoding="utf-8")
 12:     if content.lstrip().startswith("{"):
 13:         return json.loads(content)
 14:     raise ValueError("Registry must be JSON-first in current setup.")
 15: def slug_name(folder_name: str) -> str:
 16:     name = folder_name.lower().replace("-", "_")
 17:     name = re.sub(r"[^a-z0-9_]+", "_", name)
 18:     name = re.sub(r"_+", "_", name).strip("_")
 19:     if not name.startswith("boost_"):
 20:         name = f"boost_{name}"
 21:     return name
 22: def infer_domain(folder_name: str) -> str:
 23:     token = folder_name.lower()
 24:     if "dba" in token or "sql" in token or "db" in token:
 25:         return "dba"
 26:     if "iot" in token or "edge" in token:
 27:         return "iot"
 28:     if "rag" in token or "azure" in token:
 29:         return "azure-rag"
 30:     if "legacy" in token or "migration" in token:
 31:         return "legacy"
 32:     return "dev"
 33: def default_engines(domain: str) -> dict[str, str]:
 34:     if domain == "dba":
 35:         return {"knowledge": "graphify", "execution": "none", "snapshot": "repomix"}
 36:     if domain == "iot":
 37:         return {"knowledge": "graphify", "execution": "gitnexus", "snapshot": "repomix"}
 38:     if domain == "azure-rag":
 39:         return {"knowledge": "azure-rag-builder", "execution": "none", "snapshot": "repomix"}
 40:     if domain == "legacy":
 41:         return {"knowledge": "gitnexus", "execution": "none", "snapshot": "repomix"}
 42:     return {"knowledge": "codegraph", "execution": "none", "snapshot": "repomix"}
 43: def build_candidate(folder: Path, review_ticket_prefix: str, idx: int) -> dict[str, Any]:
 44:     folder_name = folder.name
 45:     repo_name = slug_name(folder_name)
 46:     domain = infer_domain(folder_name)
 47:     return {
 48:         "name": repo_name,
 49:         "domain": domain,
 50:         "version": "1.0.0",
 51:         "location": f"../{folder_name}",
 52:         "type": "local",
 53:         "dependencies": [],
 54:         "approval": {
 55:             "status": "approved",
 56:             "approved_by": "platform-team",
 57:             "approved_date": datetime.now().date().isoformat(),
 58:             "review_ticket": f"{review_ticket_prefix}-{1000 + idx}",
 59:         },
 60:         "engines": default_engines(domain),
 61:     }
 62: def main() -> int:
 63:     parser = argparse.ArgumentParser(description="Discover sibling boost_* repos and generate onboarding proposal.")
 64:     parser.add_argument("--root", default="C:/repo", help="Parent folder containing sibling repos")
 65:     parser.add_argument("--registry", default="repo-registry/repos.yml", help="Registry file path")
 66:     parser.add_argument("--output", default="repo-intake/generated/reports/boost-discovery-proposal.json")
 67:     parser.add_argument("--apply", action="store_true", help="Apply candidates directly to registry")
 68:     parser.add_argument("--review-ticket-prefix", default="PLATFORM", help="Prefix used for generated review tickets")
 69:     args = parser.parse_args()
 70:     repo_root = Path(__file__).resolve().parents[2]
 71:     registry_path = (repo_root / args.registry).resolve()
 72:     registry = load_registry(registry_path)
 73:     prefix = str(registry.get("governance", {}).get("repo_name_prefix", "boost_"))
 74:     root = Path(args.root)
 75:     if not root.exists():
 76:         print(f"Root path not found: {root}")
 77:         return 1
 78:     existing_names = {
 79:         str(r.get("name", ""))
 80:         for r in registry.get("repos", [])
 81:         if isinstance(r, dict)
 82:     }
 83:     existing_locations = {
 84:         str(r.get("location", ""))
 85:         for r in registry.get("repos", [])
 86:         if isinstance(r, dict)
 87:     }
 88:     siblings = [
 89:         p for p in root.iterdir()
 90:         if p.is_dir() and p.name.startswith(prefix) and p.name != repo_root.name
 91:     ]
 92:     candidates: list[dict[str, Any]] = []
 93:     skipped: list[dict[str, str]] = []
 94:     idx = 1
 95:     for folder in sorted(siblings, key=lambda x: x.name.lower()):
 96:         candidate = build_candidate(folder=folder, review_ticket_prefix=args.review_ticket_prefix, idx=idx)
 97:         idx += 1
 98:         if candidate["name"] in existing_names:
 99:             skipped.append({"folder": folder.name, "reason": "already_registered_name"})
100:             continue
101:         if candidate["location"] in existing_locations:
102:             skipped.append({"folder": folder.name, "reason": "already_registered_location"})
103:             continue
104:         candidates.append(candidate)
105:     proposal = {
106:         "timestamp": utc_now(),
107:         "root": str(root).replace("\\", "/"),
108:         "prefix": prefix,
109:         "registry": str(registry_path).replace("\\", "/"),
110:         "existing_count": len(existing_names),
111:         "candidates_count": len(candidates),
112:         "skipped_count": len(skipped),
113:         "candidates": candidates,
114:         "skipped": skipped,
115:         "apply_mode": bool(args.apply),
116:     }
117:     out_path = (repo_root / args.output).resolve()
118:     out_path.parent.mkdir(parents=True, exist_ok=True)
119:     out_path.write_text(json.dumps(proposal, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
120:     md_path = out_path.with_suffix(".md")
121:     lines = [
122:         "# Boost Discovery Proposal",
123:         "",
124:         f"- timestamp: {proposal['timestamp']}",
125:         f"- candidates: {proposal['candidates_count']}",
126:         f"- skipped: {proposal['skipped_count']}",
127:         "",
128:         "## Candidates",
129:         "",
130:     ]
131:     if candidates:
132:         for c in candidates:
133:             lines.append(f"- {c['name']} ({c['domain']}) -> {c['location']}")
134:     else:
135:         lines.append("- none")
136:     lines.extend(["", "## Skipped", ""])
137:     if skipped:
138:         for s in skipped:
139:             lines.append(f"- {s['folder']}: {s['reason']}")
140:     else:
141:         lines.append("- none")
142:     md_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
143:     if args.apply and candidates:
144:         registry_repos = registry.get("repos", [])
145:         if not isinstance(registry_repos, list):
146:             print("Registry repos field is invalid.")
147:             return 1
148:         registry_repos.extend(candidates)
149:         registry["repos"] = registry_repos
150:         registry_path.write_text(json.dumps(registry, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
151:         print(f"Applied {len(candidates)} candidates to registry.")
152:     else:
153:         print("Dry-run mode. No registry changes applied.")
154:     print(f"Proposal JSON: {out_path}")
155:     print(f"Proposal MD: {md_path}")
156:     return 0
157: if __name__ == "__main__":
158:     raise SystemExit(main())
</file>

