151:   Write-Host "Running strict repo registry validation..."
152:   pwsh -NoProfile -File .\scripts\intake\validate-repo-registry.ps1 -Strict
153: }
154: else {
155:   $errors | ForEach-Object { Write-Host $_ }
156: }
