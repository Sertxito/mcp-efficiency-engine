509:             throw "codegraph status failed with exit code $LASTEXITCODE"
510:         }
511:     } -Required $false
512: }
513: else {
514:     Write-Host '[skip] Check codegraph status'
515: }
516: 
517: $endedAt = Get-Date
518: $report = [ordered]@{
519:     session = 'hi'
520:     started_at = $startedAt.ToString('o')
521:     ended_at = $endedAt.ToString('o')
522:     duration_sec = [math]::Round((($endedAt - $startedAt).TotalSeconds), 2)
523:     repo = $repoRoot
