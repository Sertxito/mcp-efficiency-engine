  1: from __future__ import annotations
  2: import argparse
  3: import json
  4: from collections import defaultdict
  5: from datetime import datetime, timezone
  6: from pathlib import Path
  7: from typing import Any
  8: def utc_now() -> str:
  9:     return datetime.now(timezone.utc).isoformat()
 10: def safe_rate(num: int, den: int) -> float:
 11:     if den <= 0:
 12:         return 0.0
 13:     return num / den
 14: def parse_jsonl(path: Path) -> list[dict[str, Any]]:
 15:     if not path.exists():
 16:         return []
 17:     rows: list[dict[str, Any]] = []
 18:     for line in path.read_text(encoding="utf-8").splitlines():
 19:         line = line.strip()
 20:         if not line:
 21:             continue
 22:         try:
 23:             obj = json.loads(line)
 24:         except Exception:
 25:             continue
 26:         if isinstance(obj, dict):
 27:             rows.append(obj)
 28:     return rows
 29: def latest_by_event(rows: list[dict[str, Any]]) -> dict[str, dict[str, Any]]:
 30:     out: dict[str, dict[str, Any]] = {}
 31:     for row in rows:
 32:         event_id = str(row.get("event_id", "")).strip()
 33:         if not event_id:
 34:             continue
 35:         out[event_id] = row
 36:     return out
 37: def build_report(
 38:     events: list[dict[str, Any]],
 39:     feedback_map: dict[str, dict[str, Any]],
 40:     metrics_map: dict[str, dict[str, Any]],
 41:     sources: dict[str, str],
 42: ) -> dict[str, Any]:
 43:     total = len(events)
 44:     with_event_id = 0
 45:     metrics_covered = 0
 46:     confirmed = 0
 47:     confirmed_success = 0
 48:     total_tokens = 0
 49:     total_cost_usd = 0.0
 50:     by_mode = defaultdict(lambda: {"count": 0, "tokens": 0, "cost_usd": 0.0})
 51:     by_model = defaultdict(lambda: {"count": 0, "tokens": 0, "cost_usd": 0.0})
 52:     by_engine = defaultdict(lambda: {"count": 0, "tokens": 0, "cost_usd": 0.0})
 53:     for event in events:
 54:         event_id = str(event.get("event_id", "")).strip()
 55:         if not event_id:
 56:             continue
 57:         with_event_id += 1
 58:         fb = feedback_map.get(event_id, {})
 59:         fb_learning = fb.get("learning", {}) if isinstance(fb.get("learning", {}), dict) else {}
 60:         if str(fb_learning.get("outcome_status", "")) == "confirmed" and isinstance(fb_learning.get("success"), bool):
 61:             confirmed += 1
 62:             if bool(fb_learning.get("success")):
 63:                 confirmed_success += 1
 64:         metric = metrics_map.get(event_id)
 65:         if not metric:
 66:             continue
 67:         metrics_covered += 1
 68:         cost = metric.get("cost", {}) if isinstance(metric.get("cost", {}), dict) else {}
 69:         exec_data = metric.get("execution", {}) if isinstance(metric.get("execution", {}), dict) else {}
 70:         tokens = int(cost.get("total_tokens", 0) or 0)
 71:         cost_usd = float(cost.get("estimated_cost_usd", 0.0) or 0.0)
 72:         mode = str(exec_data.get("tool_mode", "unknown"))
 73:         model = str(metric.get("model", "unknown"))
 74:         engine = str(event.get("engine", "unknown"))
 75:         total_tokens += tokens
 76:         total_cost_usd += cost_usd
 77:         by_mode[mode]["count"] += 1
 78:         by_mode[mode]["tokens"] += tokens
 79:         by_mode[mode]["cost_usd"] += cost_usd
 80:         by_model[model]["count"] += 1
 81:         by_model[model]["tokens"] += tokens
 82:         by_model[model]["cost_usd"] += cost_usd
 83:         by_engine[engine]["count"] += 1
 84:         by_engine[engine]["tokens"] += tokens
 85:         by_engine[engine]["cost_usd"] += cost_usd
 86:     tokens_per_confirmed_success = 0.0
 87:     cost_per_confirmed_success = 0.0
 88:     if confirmed_success > 0:
 89:         tokens_per_confirmed_success = round(total_tokens / confirmed_success, 2)
 90:         cost_per_confirmed_success = round(total_cost_usd / confirmed_success, 6)
 91:     report = {
 92:         "timestamp": utc_now(),
 93:         "sources": sources,
 94:         "totals": {
 95:             "events": total,
 96:             "events_with_event_id": with_event_id,
 97:             "metrics_covered": metrics_covered,
 98:             "feedback_confirmed": confirmed,
 99:             "confirmed_success": confirmed_success,
100:         },
