  1: from __future__ import annotations
  2: import argparse
  3: import json
  4: from datetime import datetime, timezone
  5: from pathlib import Path
  6: from typing import Any
  7: AUTO_START = "<!-- AUTO-GENERATED:START -->"
  8: AUTO_END = "<!-- AUTO-GENERATED:END -->"
  9: def utc_now() -> str:
 10:     return datetime.now(timezone.utc).isoformat()
 11: def load_json(path: Path) -> dict[str, Any]:
 12:     if not path.exists():
 13:         return {}
 14:     try:
 15:         data = json.loads(path.read_text(encoding="utf-8"))
 16:     except Exception:
 17:         return {}
 18:     return data if isinstance(data, dict) else {}
 19: def get_number(value: Any, default: float = 0.0) -> float:
 20:     if isinstance(value, (int, float)):
 21:         return float(value)
 22:     return default
 23: def upsert_auto_section(path: Path, title: str, body_lines: list[str]) -> None:
 24:     header = f"# {title}\n\n"
 25:     auto_block = [AUTO_START, *body_lines, AUTO_END, ""]
 26:     auto_text = "\n".join(auto_block)
 27:     if not path.exists():
 28:         path.parent.mkdir(parents=True, exist_ok=True)
 29:         path.write_text(header + auto_text, encoding="utf-8")
 30:         return
 31:     text = path.read_text(encoding="utf-8")
 32:     if not text.strip():
 33:         text = header
 34:     if AUTO_START in text and AUTO_END in text:
 35:         start = text.index(AUTO_START)
 36:         end = text.index(AUTO_END) + len(AUTO_END)
 37:         new_text = text[:start].rstrip() + "\n\n" + auto_text
 38:     else:
 39:         new_text = text.rstrip() + "\n\n" + auto_text
 40:     path.write_text(new_text, encoding="utf-8")
 41: def build_decisions_lines(routing: dict[str, Any], learning: dict[str, Any], value: dict[str, Any]) -> list[str]:
 42:     cases_total = int(routing.get("cases_total", 0) or 0)
 43:     cases_passed = int(routing.get("cases_passed", 0) or 0)
 44:     health = learning.get("health", {}) if isinstance(learning.get("health", {}), dict) else {}
 45:     fallback_ok = bool(health.get("fallback_ok", False))
 46:     grounded_ok = bool(health.get("grounded_ok", False))
 47:     confidence_ok = bool(health.get("confidence_ok", False))
 48:     assessment = value.get("assessment", {}) if isinstance(value.get("assessment", {}), dict) else {}
 49:     has_value_signal = bool(assessment.get("has_value_signal", False))
 50:     lines = [
 51:         f"- updated_at: {utc_now()}",
 52:         f"- decision: mantener routing gate activo (routing-evals {cases_passed}/{cases_total} passed).",
 53:         f"- decision: priorizar reduccion de fallback si health.fallback_ok={fallback_ok}.",
 54:         f"- decision: mantener evidencia obligatoria mientras health.grounded_ok={grounded_ok}.",
 55:         f"- decision: mantener confidence floor mientras health.confidence_ok={confidence_ok}.",
 56:         f"- decision: usar value-per-iteration para priorizacion (has_value_signal={has_value_signal}).",
 57:     ]
 58:     return lines
 59: def build_glossary_lines(learning: dict[str, Any], value: dict[str, Any]) -> list[str]:
 60:     kpis = learning.get("kpis", {}) if isinstance(learning.get("kpis", {}), dict) else {}
 61:     vkpis = value.get("kpis", {}) if isinstance(value.get("kpis", {}), dict) else {}
 62:     fallback_rate = round(get_number(kpis.get("fallback_rate")) * 100.0, 2)
 63:     grounded_rate = round(get_number(kpis.get("grounded_rate")) * 100.0, 2)
 64:     success_rate = round(get_number(kpis.get("success_rate")) * 100.0, 2)
 65:     coverage_rate = round(get_number(vkpis.get("metrics_coverage_rate")) * 100.0, 2)
 66:     tokens_per_success = get_number(vkpis.get("tokens_per_confirmed_success"))
 67:     lines = [
 68:         f"- updated_at: {utc_now()}",
 69:         f"- fallback_rate: porcentaje de rutas en fallback. valor_actual={fallback_rate}%.",
 70:         f"- grounded_rate: porcentaje de rutas con fuentes validas. valor_actual={grounded_rate}%.",
 71:         f"- confirmed_success_rate: tasa de exito con feedback confirmado. valor_actual={success_rate}%.",
 72:         f"- metrics_coverage_rate: porcentaje de eventos con metricas. valor_actual={coverage_rate}%.",
 73:         f"- tokens_per_confirmed_success: tokens medios por exito confirmado. valor_actual={tokens_per_success}.",
 74:         "- value_signal: indicador de que hay datos suficientes para optimizacion por iteracion.",
 75:     ]
 76:     return lines
 77: def build_risks_lines(learning: dict[str, Any], value: dict[str, Any]) -> list[str]:
 78:     total_events = int(learning.get("total_events", 0) or 0)
 79:     pending_events = int(learning.get("pending_events", 0) or 0)
 80:     kpis = learning.get("kpis", {}) if isinstance(learning.get("kpis", {}), dict) else {}
 81:     thresholds = learning.get("thresholds", {}) if isinstance(learning.get("thresholds", {}), dict) else {}
 82:     fallback_rate = get_number(kpis.get("fallback_rate"))
 83:     grounded_rate = get_number(kpis.get("grounded_rate"))
 84:     confidence_avg = get_number(kpis.get("confidence_avg"))
 85:     fallback_max = get_number(thresholds.get("fallback_rate_max"), 0.2)
 86:     grounded_min = get_number(thresholds.get("grounded_rate_min"), 0.8)
 87:     confidence_min = get_number(thresholds.get("confidence_avg_min"), 0.8)
 88:     vkpis = value.get("kpis", {}) if isinstance(value.get("kpis", {}), dict) else {}
 89:     metrics_coverage_rate = get_number(vkpis.get("metrics_coverage_rate"))
 90:     confirmed_feedback_rate = get_number(vkpis.get("confirmed_feedback_rate"))
 91:     risks: list[str] = [f"- updated_at: {utc_now()}"]
 92:     if fallback_rate > fallback_max:
 93:         risks.append(
 94:             f"- high_fallback: fallback_rate={round(fallback_rate * 100.0, 2)}% supera max={round(fallback_max * 100.0, 2)}%."
 95:         )
 96:     if grounded_rate < grounded_min:
 97:         risks.append(
 98:             f"- low_grounding: grounded_rate={round(grounded_rate * 100.0, 2)}% por debajo de min={round(grounded_min * 100.0, 2)}%."
 99:         )
100:     if confidence_avg < confidence_min:
101:         risks.append(f"- low_confidence: confidence_avg={round(confidence_avg, 3)} por debajo de min={confidence_min}.")
102:     if pending_events > 0:
103:         pending_pct = round((pending_events / total_events) * 100.0, 2) if total_events > 0 else 0.0
104:         risks.append(f"- pending_feedback: pending_events={pending_events}/{total_events} ({pending_pct}%).")
105:     if metrics_coverage_rate < 1.0:
106:         risks.append(f"- incomplete_metrics: metrics_coverage_rate={round(metrics_coverage_rate * 100.0, 2)}%.")
107:     if confirmed_feedback_rate < 1.0:
108:         risks.append(f"- incomplete_feedback: confirmed_feedback_rate={round(confirmed_feedback_rate * 100.0, 2)}%.")
109:     if len(risks) == 1:
110:         risks.append("- no_critical_risks_detected: umbrales clave en rango.")
111:     return risks
112: def main() -> int:
113:     parser = argparse.ArgumentParser(description="Refresh context/project-notes from observability reports.")
114:     parser.add_argument("--routing", default="observability/evals/routing-eval-report.json")
115:     parser.add_argument("--learning", default="observability/evals/learning-loop-report.json")
