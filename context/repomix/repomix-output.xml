22179: 150:         $structureMtime = (Get-Item $structurePath).LastWriteTimeUtc
22180: 151:         $structureData = Get-Content $structurePath -Raw | ConvertFrom-Json -Depth 20
22181: 152:         $cacheFingerprint = [string]$structureData.cache_fingerprint
22182: 153:         $structureRepoExists = [bool]$structureData.exists
