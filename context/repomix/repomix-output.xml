17995:  5053:   594: 123:                   f"- confidence_avg: {kpis.get('confidence_avg', 0.0)}",
17996:  5054:   595: 124:                   ''
17997:  5055:   596: 125:               ])
17998:  5056:   597: 126:           else:
17999:  5057:   598: 127:               lines.extend(['## Learning Loop', '- report missing', ''])
18000:  5058:   599: 128:           if iteration.exists():
18001:  5059:   600: 129:               data = json.loads(iteration.read_text(encoding='utf-8'))
18002:  5060:   601: 130:               kpis = data.get('kpis', {}) if isinstance(data.get('kpis', {}), dict) else {}
18003:  5061:   602: 131:               lines.extend([
