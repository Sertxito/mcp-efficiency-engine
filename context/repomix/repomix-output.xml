 7986:  3527:   3: import json
 7987:  3528:   4: import re
 7988:  3529:   5: from datetime import datetime, timezone
 7989:  3530:   6: from pathlib import Path
 7990:  3531:   7: from typing import Any
 7991:  3532:   8: def utc_now() -> str:
 7992:  3533:   9:     return datetime.now(timezone.utc).isoformat()
 7993:  3534:  10: def load_registry(path: Path) -> dict[str, Any]:
 7994:  3535:  11:     content = path.read_text(encoding="utf-8")
 7995:  3536:  12:     if content.lstrip().startswith("{"):
 7996:  3537:  13:         return json.loads(content)
 7997:  3538:  14:     raise ValueError("Registry must be JSON-first in current setup.")
 7998:  3539:  15: def slug_name(folder_name: str) -> str:
 7999:  3540:  16:     name = folder_name.lower().replace("-", "_")
 8000:  3541:  17:     name = re.sub(r"[^a-z0-9_]+", "_", name)
 8001:  3542:  18:     name = re.sub(r"_+", "_", name).strip("_")
 8002:  3543:  19:     if not name.startswith("boost_"):
 8003:  3544:  20:         name = f"boost_{name}"
 8004:  3545:  21:     return name
 8005:  3546:  22: def infer_domain(folder_name: str) -> str:
 8006:  3547:  23:     token = folder_name.lower()
 8007:  3548:  24:     if "dba" in token or "sql" in token or "db" in token:
 8008:  3549:  25:         return "dba"
 8009:  3550:  26:     if "iot" in token or "edge" in token:
 8010:  3551:  27:         return "iot"
 8011:  3552:  28:     if "rag" in token or "azure" in token:
 8012:  3553:  29:         return "azure-rag"
 8013:  3554:  30:     if "legacy" in token or "migration" in token:
 8014:  3555:  31:         return "legacy"
 8015:  3556:  32:     return "dev"
 8016:  3557:  33: def default_engines(domain: str) -> dict[str, str]:
 8017:  3558:  34:     if domain == "dba":
 8018:  3559:  35:         return {"knowledge": "graphify", "execution": "none", "snapshot": "repomix"}
 8019:  3560:  36:     if domain == "iot":
 8020:  3561:  37:         return {"knowledge": "graphify", "execution": "gitnexus", "snapshot": "repomix"}
 8021:  3562:  38:     if domain == "azure-rag":
 8022:  3563:  39:         return {"knowledge": "azure-rag-builder", "execution": "none", "snapshot": "repomix"}
 8023:  3564:  40:     if domain == "legacy":
 8024:  3565:  41:         return {"knowledge": "gitnexus", "execution": "none", "snapshot": "repomix"}
 8025:  3566:  42:     return {"knowledge": "codegraph", "execution": "none", "snapshot": "repomix"}
 8026:  3567:  43: def build_candidate(folder: Path, review_ticket_prefix: str, idx: int) -> dict[str, Any]:
 8027:  3568:  44:     folder_name = folder.name
 8028:  3569:  45:     repo_name = slug_name(folder_name)
 8029:  3570:  46:     domain = infer_domain(folder_name)
 8030:  3571:  47:     return {
 8031:  3572:  48:         "name": repo_name,
 8032:  3573:  49:         "domain": domain,
 8033:  3574:  50:         "version": "1.0.0",
 8034:  3575:  51:         "location": f"../{folder_name}",
 8035:  3576:  52:         "type": "local",
 8036:  3577:  53:         "dependencies": [],
 8037:  3578:  54:         "approval": {
 8038:  3579:  55:             "status": "approved",
 8039:  3580:  56:             "approved_by": "platform-team",
 8040:  3581:  57:             "approved_date": datetime.now().date().isoformat(),
 8041:  3582:  58:             "review_ticket": f"{review_ticket_prefix}-{1000 + idx}",
 8042:  3583:  59:         },
 8043:  3584:  60:         "engines": default_engines(domain),
 8044:  3585:  61:     }
 8045:  3586:  62: def main() -> int:
 8046:  3587:  63:     parser = argparse.ArgumentParser(description="Discover sibling boost_* repos and generate onboarding proposal.")
 8047:  3588:  64:     parser.add_argument("--root", default="C:/repo", help="Parent folder containing sibling repos")
 8048:  3589:  65:     parser.add_argument("--registry", default="repo-registry/repos.yml", help="Registry file path")
 8049:  3590:  66:     parser.add_argument("--output", default="repo-intake/generated/reports/boost-discovery-proposal.json")
 8050:  3591:  67:     parser.add_argument("--apply", action="store_true", help="Apply candidates directly to registry")
 8051:  3592:  68:     parser.add_argument("--review-ticket-prefix", default="PLATFORM", help="Prefix used for generated review tickets")
 8052:  3593:  69:     args = parser.parse_args()
 8053:  3594:  70:     repo_root = Path(__file__).resolve().parents[2]
 8054:  3595:  71:     registry_path = (repo_root / args.registry).resolve()
 8055:  3596:  72:     registry = load_registry(registry_path)
 8056:  3597:  73:     prefix = str(registry.get("governance", {}).get("repo_name_prefix", "boost_"))
 8057:  3598:  74:     root = Path(args.root)
 8058:  3599:  75:     if not root.exists():
 8059:  3600:  76:         print(f"Root path not found: {root}")
 8060:  3601:  77:         return 1
 8061:  3602:  78:     existing_names = {
 8062:  3603:  79:         str(r.get("name", ""))
 8063:  3604:  80:         for r in registry.get("repos", [])
 8064:  3605:  81:         if isinstance(r, dict)
 8065:  3606:  82:     }
 8066:  3607:  83:     existing_locations = {
 8067:  3608:  84:         str(r.get("location", ""))
 8068:  3609:  85:         for r in registry.get("repos", [])
 8069:  3610:  86:         if isinstance(r, dict)
 8070:  3611:  87:     }
 8071:  3612:  88:     siblings = [
 8072:  3613:  89:         p for p in root.iterdir()
 8073:  3614:  90:         if p.is_dir() and p.name.startswith(prefix) and p.name != repo_root.name
 8074:  3615:  91:     ]
 8075:  3616:  92:     candidates: list[dict[str, Any]] = []
 8076:  3617:  93:     skipped: list[dict[str, str]] = []
 8077:  3618:  94:     idx = 1
 8078:  3619:  95:     for folder in sorted(siblings, key=lambda x: x.name.lower()):
 8079:  3620:  96:         candidate = build_candidate(folder=folder, review_ticket_prefix=args.review_ticket_prefix, idx=idx)
 8080:  3621:  97:         idx += 1
 8081:  3622:  98:         if candidate["name"] in existing_names:
 8082:  3623:  99:             skipped.append({"folder": folder.name, "reason": "already_registered_name"})
 8083:  3624: 100:             continue
 8084:  3625: 101:         if candidate["location"] in existing_locations:
 8085:  3626: 102:             skipped.append({"folder": folder.name, "reason": "already_registered_location"})
 8086:  3627: 103:             continue
 8087:  3628: 104:         candidates.append(candidate)
 8088:  3629: 105:     proposal = {
 8089:  3630: 106:         "timestamp": utc_now(),
 8090:  3631: 107:         "root": str(root).replace("\\", "/"),
 8091:  3632: 108:         "prefix": prefix,
 8092:  3633: 109:         "registry": str(registry_path).replace("\\", "/"),
 8093:  3634: 110:         "existing_count": len(existing_names),
 8094:  3635: 111:         "candidates_count": len(candidates),
 8095:  3636: 112:         "skipped_count": len(skipped),
 8096:  3637: 113:         "candidates": candidates,
 8097:  3638: 114:         "skipped": skipped,
 8098:  3639: 115:         "apply_mode": bool(args.apply),
 8099:  3640: 116:     }
