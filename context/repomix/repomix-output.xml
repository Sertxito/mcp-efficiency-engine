33:     parser.add_argument("--model", required=True, help="Model used in the iteration, e.g. GPT-5.3-Codex")
34:     parser.add_argument("--input-tokens", type=int, required=True)
35:     parser.add_argument("--output-tokens", type=int, required=True)
36:     parser.add_argument("--local-tools", type=int, default=0, help="Count of local tools used")
37:     parser.add_argument("--remote-tools", type=int, default=0, help="Count of remote/cloud tools used")
38:     parser.add_argument("--estimated-cost-usd", type=float, default=0.0)
39:     parser.add_argument("--notes", default="")
40:     parser.add_argument("--routing-log", default="observability/logs/routing-decisions.jsonl")
41:     parser.add_argument("--output", default="observability/logs/iteration-metrics.jsonl")
42:     args = parser.parse_args()
43:     if args.input_tokens < 0 or args.output_tokens < 0:
44:         print("input/output tokens must be >= 0")
45:         return 1
46:     if args.local_tools < 0 or args.remote_tools < 0:
47:         print("tool counters must be >= 0")
48:         return 1
49:     if args.estimated_cost_usd < 0:
50:         print("estimated-cost-usd must be >= 0")
51:         return 1
52:     repo_root = Path(__file__).resolve().parents[2]
53:     routing_log = (repo_root / args.routing_log).resolve()
54:     output_path = (repo_root / args.output).resolve()
