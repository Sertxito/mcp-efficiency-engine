35150: 22208: 179: function Test-LongRunningCommand {
35151: 22209: 180:     param(
35152: 22210: 181:         [string]$Name,
35153: 22211: 182:         [string]$Command,
35154: 22212: 183:         [int]$WarmupSec = 4,
35155: 22213: 184:         [int]$TimeoutSec = 25
35156: 22214: 185:     )
35157: 22215: 186: 
35158: 22216: 187:     $outFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.out" -f $Name, ([guid]::NewGuid().ToString('N')))
35159: 22217: 188:     $errFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.err" -f $Name, ([guid]::NewGuid().ToString('N')))
35160: 22218: 189: 
35161: 22219: 190:     $proc = Start-Process -FilePath 'pwsh' -ArgumentList @('-NoProfile', '-ExecutionPolicy', 'Bypass', '-Command', $Command) -PassThru -RedirectStandardOutput $outFile -RedirectStandardError $errFile
35162: 22220: 191:     $start = Get-Date
35163: 22221: 192:     $deadline = $start.AddSeconds($TimeoutSec)
35164: 22222: 193:     $isReady = $false
35165: 22223: 194: 
35166: 22224: 195:     while ((Get-Date) -lt $deadline) {
35167: 22225: 196:         if ($proc.HasExited) {
35168: 22226: 197:             if ($proc.ExitCode -eq 0) {
35169: 22227: 198:                 $isReady = $true
35170: 22228: 199:                 break
35171: 22229: 200:             }
35172: 22230: 201: 
35173: 22231: 202:             $errText = ''
35174: 22232: 203:             if (Test-Path $errFile) {
35175: 22233: 204:                 $errText = (Get-Content $errFile -Raw)
35176: 22234: 205:             }
35177: 22235: 206:             throw "$Name failed to start. ExitCode=$($proc.ExitCode). $errText"
35178: 22236: 207:         }
35179: 22237: 208: 
35180: 22238: 209:         if (((Get-Date) - $start).TotalSeconds -ge $WarmupSec) {
35181: 22239: 210:             $isReady = $true
35182: 22240: 211:             break
35183: 22241: 212:         }
35184: 22242: 213: 
35185: 22243: 214:         Start-Sleep -Milliseconds 250
35186: 22244: 215:     }
35187: 22245: 216: 
35188: 22246: 217:     if (-not $isReady) {
35189: 22247: 218:         throw "$Name did not become ready within ${TimeoutSec}s"
35190: 22248: 219:     }
35191: 22249: 220: 
35192: 22250: 221:     if (-not $proc.HasExited) {
35193: 22251: 222:         Stop-Process -Id $proc.Id -Force
35194: 22252: 223:     }
35195: 22253: 224: 
35196: 22254: 225:     Remove-Item $outFile, $errFile -ErrorAction SilentlyContinue
35197: 22255: 226: }
