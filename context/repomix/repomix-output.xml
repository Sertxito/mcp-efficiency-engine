22155: 126:             $repoPath,
22156: 127:             (Join-Path $repoPath 'AGENTS.md'),
22157: 128:             (Join-Path $repoPath 'README.md'),
22158: 129:             (Join-Path $repoPath 'ARCHITECTURE.md'),
22159: 130:             (Join-Path $repoPath '.github/skills'),
22160: 131:             (Join-Path $repoPath '.github/prompts'),
22161: 132:             (Join-Path $repoPath 'scripts'),
22162: 133:             (Join-Path $repoPath 'specs')
22163: 134:         )
22164: 135: 
22165: 136:         foreach ($path in $pathsToCheck) {
22166: 137:             $lastWrite = Get-PathLastWriteUtc -Path $path
22167: 138:             if ($lastWrite -gt $repoLatest) {
22168: 139:                 $repoLatest = $lastWrite
22169: 140:             }
