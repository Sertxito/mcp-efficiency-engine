22220: 191:     $start = Get-Date
22221: 192:     $deadline = $start.AddSeconds($TimeoutSec)
22222: 193:     $isReady = $false
22223: 194: 
22224: 195:     while ((Get-Date) -lt $deadline) {
22225: 196:         if ($proc.HasExited) {
22226: 197:             if ($proc.ExitCode -eq 0) {
22227: 198:                 $isReady = $true
22228: 199:                 break
22229: 200:             }
22230: 201: 
22231: 202:             $errText = ''
22232: 203:             if (Test-Path $errFile) {
22233: 204:                 $errText = (Get-Content $errFile -Raw)
22234: 205:             }
22235: 206:             throw "$Name failed to start. ExitCode=$($proc.ExitCode). $errText"
22236: 207:         }
22237: 208: 
22238: 209:         if (((Get-Date) - $start).TotalSeconds -ge $WarmupSec) {
22239: 210:             $isReady = $true
22240: 211:             break
22241: 212:         }
22242: 213: 
22243: 214:         Start-Sleep -Milliseconds 250
22244: 215:     }
22245: 216: 
22246: 217:     if (-not $isReady) {
22247: 218:         throw "$Name did not become ready within ${TimeoutSec}s"
22248: 219:     }
22249: 220: 
22250: 221:     if (-not $proc.HasExited) {
22251: 222:         Stop-Process -Id $proc.Id -Force
22252: 223:     }
22253: 224: 
22254: 225:     Remove-Item $outFile, $errFile -ErrorAction SilentlyContinue
22255: 226: }
