22006:  9064:  4605: 34: def main() -> int:
22007:  9065:  4606: 35:     parser = argparse.ArgumentParser(description="Run routing eval cases and write JSON report.")
22008:  9066:  4607: 36:     parser.add_argument("--cases", default="observability/evals/routing-eval-cases.json")
