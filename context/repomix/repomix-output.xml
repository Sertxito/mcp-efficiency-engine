<file path="scripts/learning/record-learning-feedback.py">
 1: from __future__ import annotations
 2: import argparse
 3: import json
 4: from datetime import datetime, timezone
 5: from pathlib import Path
 6: from typing import Any
 7: def utc_now() -> str:
 8:     return datetime.now(timezone.utc).isoformat()
 9: def parse_jsonl(path: Path) -> list[dict[str, Any]]:
10:     if not path.exists():
11:         return []
12:     rows: list[dict[str, Any]] = []
13:     for line in path.read_text(encoding="utf-8").splitlines():
14:         line = line.strip()
15:         if not line:
16:             continue
17:         try:
18:             obj = json.loads(line)
19:         except Exception:
20:             continue
21:         if isinstance(obj, dict):
22:             rows.append(obj)
23:     return rows
24: def latest_event_id(events: list[dict[str, Any]]) -> str | None:
25:     for e in reversed(events):
26:         event_id = str(e.get("event_id", "")).strip()
27:         if event_id:
28:             return event_id
29:     return None
30: def main() -> int:
31:     parser = argparse.ArgumentParser(description="Record real execution feedback for a routing event.")
32:     parser.add_argument("--event-id", default="", help="Routing event_id to confirm. If omitted, uses latest event with event_id.")
33:     parser.add_argument("--success", required=True, choices=["true", "false"], help="Real execution outcome.")
34:     parser.add_argument("--confidence", type=float, default=0.9, help="Confidence in the feedback (0..1).")
35:     parser.add_argument("--source", default="human", help="Feedback source: human|ci|runtime|other")
36:     parser.add_argument("--notes", default="", help="Optional notes")
37:     parser.add_argument("--routing-log", default="observability/logs/routing-decisions.jsonl")
38:     parser.add_argument("--output", default="observability/logs/learning-feedback.jsonl")
39:     args = parser.parse_args()
40:     if args.confidence < 0 or args.confidence > 1:
41:         print("confidence must be between 0 and 1")
42:         return 1
43:     repo_root = Path(__file__).resolve().parents[2]
44:     routing_log = (repo_root / args.routing_log).resolve()
45:     output_path = (repo_root / args.output).resolve()
46:     events = parse_jsonl(routing_log)
47:     event_id = args.event_id.strip() or (latest_event_id(events) or "")
48:     if not event_id:
49:         print("No event_id provided and no eligible routing events found.")
50:         return 1
51:     exists = any(str(e.get("event_id", "")).strip() == event_id for e in events)
52:     if not exists:
53:         print(f"event_id not found in routing log: {event_id}")
54:         return 1
55:     feedback = {
56:         "timestamp": utc_now(),
57:         "event_id": event_id,
58:         "learning": {
59:             "success": True if args.success == "true" else False,
60:             "outcome_status": "confirmed",
61:             "confidence": round(float(args.confidence), 3),
62:             "feedback_source": args.source,
63:             "notes": args.notes,
64:         },
65:     }
66:     output_path.parent.mkdir(parents=True, exist_ok=True)
67:     with output_path.open("a", encoding="utf-8") as fh:
68:         fh.write(json.dumps(feedback, ensure_ascii=False) + "\n")
69:     print(f"Feedback recorded for event_id: {event_id}")
70:     print(f"Output: {output_path}")
71:     return 0
72: if __name__ == "__main__":
73:     raise SystemExit(main())
