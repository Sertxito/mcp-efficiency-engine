 9030: 100:             continue
 9031: 101:         if candidate["location"] in existing_locations:
 9032: 102:             skipped.append({"folder": folder.name, "reason": "already_registered_location"})
 9033: 103:             continue
 9034: 104:         candidates.append(candidate)
