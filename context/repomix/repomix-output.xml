35070: 22128:  99:     }
35071: 22129: 100: 
35072: 22130: 101:     $max = $item.LastWriteTimeUtc
35073: 22131: 102:     $children = Get-ChildItem -Path $Path -Recurse -File -ErrorAction SilentlyContinue
35074: 22132: 103:     foreach ($child in $children) {
35075: 22133: 104:         if ($child.LastWriteTimeUtc -gt $max) {
35076: 22134: 105:             $max = $child.LastWriteTimeUtc
35077: 22135: 106:         }
35078: 22136: 107:     }
35079: 22137: 108: 
35080: 22138: 109:     return $max
35081: 22139: 110: }
