22083:  9141:  4682:  15: def parse_simple_yml(path: Path) -> dict[str, Any]:
22084:  9142:  4683:  16:     repos: list[dict[str, Any]] = []
22085:  9143:  4684:  17:     current: dict[str, Any] | None = None
22086:  9144:  4685:  18:     for line in path.read_text(encoding="utf-8").splitlines():
22087:  9145:  4686:  19:         st = line.strip()
22088:  9146:  4687:  20:         if st.startswith("- name:"):
22089:  9147:  4688:  21:             if current:
22090:  9148:  4689:  22:                 repos.append(current)
22091:  9149:  4690:  23:             current = {"name": st.split(":", 1)[1].strip()}
22092:  9150:  4691:  24:         elif current and ":" in st and not st.startswith("#"):
22093:  9151:  4692:  25:             k, v = st.split(":", 1)
22094:  9152:  4693:  26:             k = k.strip()
22095:  9153:  4694:  27:             v = v.strip().strip('"')
22096:  9154:  4695:  28:             if k in {"domain", "location", "type"}:
22097:  9155:  4696:  29:                 current[k] = v
22098:  9156:  4697:  30:     if current:
22099:  9157:  4698:  31:         repos.append(current)
22100:  9158:  4699:  32:     return {"schema_version": "1.0", "repos": repos}
22101:  9159:  4700:  33: def load_registry(path: Path) -> dict[str, Any]:
22102:  9160:  4701:  34:     content = path.read_text(encoding="utf-8")
22103:  9161:  4702:  35:     # JSON-first support (JSON is valid YAML, but this path avoids extra deps).
22104:  9162:  4703:  36:     if content.lstrip().startswith("{"):
22105:  9163:  4704:  37:         return json.loads(content)
22106:  9164:  4705:  38:     if yaml is not None:
22107:  9165:  4706:  39:         data = yaml.safe_load(content) or {}
22108:  9166:  4707:  40:         if isinstance(data, dict):
22109:  9167:  4708:  41:             return data
22110:  9168:  4709:  42:     return parse_simple_yml(path)
22111:  9169:  4710:  43: @dataclass
22112:  9170:  4711:  44: class ValidationResult:
22113:  9171:  4712:  45:     errors: list[str]
22114:  9172:  4713:  46:     warnings: list[str]
22115:  9173:  4714:  47: def validate(registry: dict[str, Any], strict: bool, repo_root: Path) -> ValidationResult:
22116:  9174:  4715:  48:     errors: list[str] = []
22117:  9175:  4716:  49:     warnings: list[str] = []
22118:  9176:  4717:  50:     repos = registry.get("repos")
22119:  9177:  4718:  51:     if not isinstance(repos, list) or not repos:
22120:  9178:  4719:  52:         return ValidationResult(errors=["Registry must define a non-empty repos list."], warnings=[])
22121:  9179:  4720:  53:     schema_version = str(registry.get("schema_version", "1.0"))
22122:  9180:  4721:  54:     is_v2 = schema_version >= "2.0"
22123:  9181:  4722:  55:     governance = registry.get("governance", {}) if isinstance(registry.get("governance", {}), dict) else {}
22124:  9182:  4723:  56:     repo_name_prefix = str(governance.get("repo_name_prefix", "boost_")).strip() or "boost_"
22125:  9183:  4724:  57:     names: set[str] = set()
22126:  9184:  4725:  58:     graph: dict[str, list[str]] = {}
22127:  9185:  4726:  59:     for repo in repos:
22128:  9186:  4727:  60:         if not isinstance(repo, dict):
22129:  9187:  4728:  61:             errors.append("Each repo entry must be an object.")
22130:  9188:  4729:  62:             continue
22131:  9189:  4730:  63:         name = str(repo.get("name", "")).strip()
22132:  9190:  4731:  64:         if not name:
22133:  9191:  4732:  65:             errors.append("Repo is missing required field: name")
22134:  9192:  4733:  66:             continue
22135:  9193:  4734:  67:         if strict or is_v2:
22136:  9194:  4735:  68:             if not name.startswith(repo_name_prefix):
22137:  9195:  4736:  69:                 errors.append(
22138:  9196:  4737:  70:                     f"Repo '{name}' does not satisfy naming contract. Expected prefix '{repo_name_prefix}'."
22139:  9197:  4738:  71:                 )
22140:  9198:  4739:  72:         if name in names:
22141:  9199:  4740:  73:             errors.append(f"Duplicate repo name: {name}")
22142:  9200:  4741:  74:             continue
22143:  9201:  4742:  75:         names.add(name)
22144:  9202:  4743:  76:         for field in ("domain", "location", "type"):
22145:  9203:  4744:  77:             if not str(repo.get(field, "")).strip():
22146:  9204:  4745:  78:                 errors.append(f"Repo '{name}' is missing required field: {field}")
22147:  9205:  4746:  79:         if str(repo.get("type", "")).strip() and repo.get("type") != "local":
22148:  9206:  4747:  80:             errors.append(f"Repo '{name}' type must be 'local' in this phase.")
22149:  9207:  4748:  81:         location = str(repo.get("location", "")).strip()
22150:  9208:  4749:  82:         if location:
22151:  9209:  4750:  83:             resolved = (repo_root / location).resolve()
22152:  9210:  4751:  84:             if not resolved.exists():
22153:  9211:  4752:  85:                 if bool(repo.get("optional", False)):
22154:  9212:  4753:  86:                     warnings.append(f"Optional repo '{name}' location does not exist: {location}")
22155:  9213:  4754:  87:                 else:
22156:  9214:  4755:  88:                     errors.append(f"Repo '{name}' location does not exist: {location}")
22157:  9215:  4756:  89:         deps = repo.get("dependencies", [])
22158:  9216:  4757:  90:         dep_refs: list[str] = []
22159:  9217:  4758:  91:         if deps:
22160:  9218:  4759:  92:             if not isinstance(deps, list):
22161:  9219:  4760:  93:                 errors.append(f"Repo '{name}' dependencies must be a list.")
22162:  9220:  4761:  94:             else:
22163:  9221:  4762:  95:                 for dep in deps:
22164:  9222:  4763:  96:                     if not isinstance(dep, dict) or not str(dep.get("ref", "")).strip():
22165:  9223:  4764:  97:                         errors.append(f"Repo '{name}' has a dependency without ref.")
22166:  9224:  4765:  98:                         continue
22167:  9225:  4766:  99:                     dep_refs.append(str(dep["ref"]))
22168:  9226:  4767: 100:         graph[name] = dep_refs
22169:  9227:  4768: 101:         if strict or is_v2:
22170:  9228:  4769: 102:             approval = repo.get("approval")
22171:  9229:  4770: 103:             if not isinstance(approval, dict):
22172:  9230:  4771: 104:                 errors.append(f"Repo '{name}' requires approval block in v2/strict mode.")
22173:  9231:  4772: 105:             else:
22174:  9232:  4773: 106:                 if approval.get("status") != "approved":
22175:  9233:  4774: 107:                     errors.append(f"Repo '{name}' is not approved (approval.status must be 'approved').")
22176:  9234:  4775: 108:                 if not str(approval.get("approved_by", "")).strip():
22177:  9235:  4776: 109:                     errors.append(f"Repo '{name}' missing approval.approved_by")
22178:  9236:  4777: 110:                 if not str(approval.get("approved_date", "")).strip():
22179:  9237:  4778: 111:                     errors.append(f"Repo '{name}' missing approval.approved_date")
22180:  9238:  4779: 112:                 if not str(approval.get("review_ticket", "")).strip():
22181:  9239:  4780: 113:                     warnings.append(f"Repo '{name}' missing approval.review_ticket")
22182:  9240:  4781: 114:     for src, dep_refs in graph.items():
22183:  9241:  4782: 115:         for dep in dep_refs:
