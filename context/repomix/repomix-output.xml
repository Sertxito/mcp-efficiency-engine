138:         "timestamp": utc_now(),
139:         "source": source_path,
140:         "feedback_source": feedback_source,
141:         "total_events": total,
142:         "pending_events": pending_count,
143:         "confirmed_events": confirmed_count,
144:         "kpis": {
145:             "fallback_rate": round(safe_rate(fallback_count, total), 4),
146:             "grounded_rate": round(safe_rate(grounded_count, total), 4),
147:             "success_rate": round(safe_rate(success_count, confirmed_count), 4),
148:             "confidence_avg": global_confidence_avg,
149:         },
150:         "thresholds": {
151:             "fallback_rate_max": 0.20,
152:             "grounded_rate_min": 0.80,
153:             "confidence_avg_min": 0.80,
154:         },
155:         "health": {
156:             "fallback_ok": round(safe_rate(fallback_count, total), 4) <= 0.20,
157:             "grounded_ok": round(safe_rate(grounded_count, total), 4) >= 0.80,
158:             "confidence_ok": global_confidence_avg >= 0.80,
159:         },
160:         "patterns": patterns_out,
161:     }
162:     return report
163: def report_to_markdown(report: dict[str, Any]) -> str:
164:     total = int(report.get("total_events", 0))
165:     pending = int(report.get("pending_events", 0))
166:     confirmed = int(report.get("confirmed_events", 0))
167:     kpis = report.get("kpis", {}) if isinstance(report.get("kpis", {}), dict) else {}
168:     health = report.get("health", {}) if isinstance(report.get("health", {}), dict) else {}
169:     patterns = report.get("patterns", []) if isinstance(report.get("patterns", []), list) else []
170:     lines = [
171:         "# Learning Loop Report",
172:         "",
173:         f"- timestamp: {report.get('timestamp', '')}",
174:         f"- total_events: {total}",
175:         f"- pending_events: {pending}",
176:         f"- confirmed_events: {confirmed}",
177:         "",
178:         "## Global KPIs",
179:         "",
180:         f"- fallback_rate: {pct(float(kpis.get('fallback_rate', 0.0)))}%",
181:         f"- grounded_rate: {pct(float(kpis.get('grounded_rate', 0.0)))}%",
182:         f"- success_rate: {pct(float(kpis.get('success_rate', 0.0)))}%",
183:         f"- confidence_avg: {kpis.get('confidence_avg', 0.0)}",
184:         "",
185:         "## Health",
186:         "",
187:         f"- fallback_ok: {health.get('fallback_ok', False)}",
188:         f"- grounded_ok: {health.get('grounded_ok', False)}",
189:         f"- confidence_ok: {health.get('confidence_ok', False)}",
190:         "",
191:         "## Patterns",
192:         "",
193:     ]
194:     if not patterns:
195:         lines.append("- none")
196:     else:
197:         for p in patterns:
198:             lines.append(
199:                 f"- {p.get('pattern', 'unknown')}: total={p.get('total', 0)}, "
200:                 f"pending={p.get('pending_count', 0)}, "
201:                 f"confirmed={p.get('confirmed_count', 0)}, "
202:                 f"fallback={pct(float(p.get('fallback_rate', 0.0)))}%, "
203:                 f"grounded={pct(float(p.get('grounded_rate', 0.0)))}%, "
204:                 f"confidence={p.get('confidence_avg', 0.0)}"
205:             )
206:     lines.append("")
207:     return "\n".join(lines)
208: def main() -> int:
209:     parser = argparse.ArgumentParser(description="Build learning loop report from routing decisions log.")
210:     parser.add_argument("--input", default="observability/logs/routing-decisions.jsonl")
211:     parser.add_argument("--feedback", default="observability/logs/learning-feedback.jsonl")
212:     parser.add_argument("--out-json", default="observability/evals/learning-loop-report.json")
213:     parser.add_argument("--out-md", default="observability/evals/learning-loop-report.md")
214:     args = parser.parse_args()
215:     repo_root = Path(__file__).resolve().parents[2]
216:     in_path = (repo_root / args.input).resolve()
217:     feedback_path = (repo_root / args.feedback).resolve()
218:     out_json = (repo_root / args.out_json).resolve()
219:     out_md = (repo_root / args.out_md).resolve()
220:     events = parse_events(in_path)
221:     feedback = parse_feedback(feedback_path)
222:     report = build_report(events, str(in_path), feedback, str(feedback_path))
223:     out_json.parent.mkdir(parents=True, exist_ok=True)
224:     out_md.parent.mkdir(parents=True, exist_ok=True)
225:     out_json.write_text(json.dumps(report, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
226:     out_md.write_text(report_to_markdown(report), encoding="utf-8")
227:     print(f"Learning events processed: {len(events)}")
228:     print(f"Report JSON: {out_json}")
229:     print(f"Report MD: {out_md}")
