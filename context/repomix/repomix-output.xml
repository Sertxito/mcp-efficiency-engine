  514:  43:       - name: Enforce AutoLearning gate
  515:  44:         run: python ./scripts/learning/autolearning-gate.py
  516:  45:       - name: Enforce zero failed cases
  517:  46:         run: |
  518:  47:           python - <<'PY'
