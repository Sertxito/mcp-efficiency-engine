111:     & $pyCmd @pyArgs -m pip install "graphifyy[mcp]"
112: 
113:     if (-not (Test-PythonImport -PythonCommand $pyCmd -PythonArgs $pyArgs -Module 'graphify.serve')) {
114:         throw 'graphify.serve import failed after installation.'
