 3524: <file path="scripts/discovery/discover-boost-repos.py">
 3525:   1: from __future__ import annotations
 3526:   2: import argparse
 3527:   3: import json
 3528:   4: import re
 3529:   5: from datetime import datetime, timezone
 3530:   6: from pathlib import Path
 3531:   7: from typing import Any
 3532:   8: def utc_now() -> str:
 3533:   9:     return datetime.now(timezone.utc).isoformat()
 3534:  10: def load_registry(path: Path) -> dict[str, Any]:
 3535:  11:     content = path.read_text(encoding="utf-8")
 3536:  12:     if content.lstrip().startswith("{"):
 3537:  13:         return json.loads(content)
 3538:  14:     raise ValueError("Registry must be JSON-first in current setup.")
 3539:  15: def slug_name(folder_name: str) -> str:
 3540:  16:     name = folder_name.lower().replace("-", "_")
 3541:  17:     name = re.sub(r"[^a-z0-9_]+", "_", name)
 3542:  18:     name = re.sub(r"_+", "_", name).strip("_")
 3543:  19:     if not name.startswith("boost_"):
 3544:  20:         name = f"boost_{name}"
 3545:  21:     return name
 3546:  22: def infer_domain(folder_name: str) -> str:
 3547:  23:     token = folder_name.lower()
 3548:  24:     if "dba" in token or "sql" in token or "db" in token:
 3549:  25:         return "dba"
 3550:  26:     if "iot" in token or "edge" in token:
 3551:  27:         return "iot"
 3552:  28:     if "rag" in token or "azure" in token:
 3553:  29:         return "azure-rag"
 3554:  30:     if "legacy" in token or "migration" in token:
 3555:  31:         return "legacy"
 3556:  32:     return "dev"
 3557:  33: def default_engines(domain: str) -> dict[str, str]:
 3558:  34:     if domain == "dba":
 3559:  35:         return {"knowledge": "graphify", "execution": "none", "snapshot": "repomix"}
 3560:  36:     if domain == "iot":
 3561:  37:         return {"knowledge": "graphify", "execution": "gitnexus", "snapshot": "repomix"}
 3562:  38:     if domain == "azure-rag":
 3563:  39:         return {"knowledge": "azure-rag-builder", "execution": "none", "snapshot": "repomix"}
 3564:  40:     if domain == "legacy":
 3565:  41:         return {"knowledge": "gitnexus", "execution": "none", "snapshot": "repomix"}
 3566:  42:     return {"knowledge": "codegraph", "execution": "none", "snapshot": "repomix"}
 3567:  43: def build_candidate(folder: Path, review_ticket_prefix: str, idx: int) -> dict[str, Any]:
 3568:  44:     folder_name = folder.name
 3569:  45:     repo_name = slug_name(folder_name)
 3570:  46:     domain = infer_domain(folder_name)
 3571:  47:     return {
 3572:  48:         "name": repo_name,
 3573:  49:         "domain": domain,
 3574:  50:         "version": "1.0.0",
 3575:  51:         "location": f"../{folder_name}",
 3576:  52:         "type": "local",
 3577:  53:         "dependencies": [],
 3578:  54:         "approval": {
 3579:  55:             "status": "approved",
 3580:  56:             "approved_by": "platform-team",
 3581:  57:             "approved_date": datetime.now().date().isoformat(),
 3582:  58:             "review_ticket": f"{review_ticket_prefix}-{1000 + idx}",
 3583:  59:         },
 3584:  60:         "engines": default_engines(domain),
 3585:  61:     }
 3586:  62: def main() -> int:
 3587:  63:     parser = argparse.ArgumentParser(description="Discover sibling boost_* repos and generate onboarding proposal.")
 3588:  64:     parser.add_argument("--root", default="C:/repo", help="Parent folder containing sibling repos")
 3589:  65:     parser.add_argument("--registry", default="repo-registry/repos.yml", help="Registry file path")
 3590:  66:     parser.add_argument("--output", default="repo-intake/generated/reports/boost-discovery-proposal.json")
 3591:  67:     parser.add_argument("--apply", action="store_true", help="Apply candidates directly to registry")
 3592:  68:     parser.add_argument("--review-ticket-prefix", default="PLATFORM", help="Prefix used for generated review tickets")
 3593:  69:     args = parser.parse_args()
 3594:  70:     repo_root = Path(__file__).resolve().parents[2]
 3595:  71:     registry_path = (repo_root / args.registry).resolve()
 3596:  72:     registry = load_registry(registry_path)
 3597:  73:     prefix = str(registry.get("governance", {}).get("repo_name_prefix", "boost_"))
 3598:  74:     root = Path(args.root)
 3599:  75:     if not root.exists():
 3600:  76:         print(f"Root path not found: {root}")
 3601:  77:         return 1
 3602:  78:     existing_names = {
 3603:  79:         str(r.get("name", ""))
 3604:  80:         for r in registry.get("repos", [])
 3605:  81:         if isinstance(r, dict)
 3606:  82:     }
 3607:  83:     existing_locations = {
 3608:  84:         str(r.get("location", ""))
 3609:  85:         for r in registry.get("repos", [])
 3610:  86:         if isinstance(r, dict)
 3611:  87:     }
 3612:  88:     siblings = [
 3613:  89:         p for p in root.iterdir()
 3614:  90:         if p.is_dir() and p.name.startswith(prefix) and p.name != repo_root.name
 3615:  91:     ]
 3616:  92:     candidates: list[dict[str, Any]] = []
 3617:  93:     skipped: list[dict[str, str]] = []
 3618:  94:     idx = 1
 3619:  95:     for folder in sorted(siblings, key=lambda x: x.name.lower()):
 3620:  96:         candidate = build_candidate(folder=folder, review_ticket_prefix=args.review_ticket_prefix, idx=idx)
 3621:  97:         idx += 1
 3622:  98:         if candidate["name"] in existing_names:
 3623:  99:             skipped.append({"folder": folder.name, "reason": "already_registered_name"})
 3624: 100:             continue
 3625: 101:         if candidate["location"] in existing_locations:
 3626: 102:             skipped.append({"folder": folder.name, "reason": "already_registered_location"})
 3627: 103:             continue
 3628: 104:         candidates.append(candidate)
 3629: 105:     proposal = {
 3630: 106:         "timestamp": utc_now(),
 3631: 107:         "root": str(root).replace("\\", "/"),
 3632: 108:         "prefix": prefix,
 3633: 109:         "registry": str(registry_path).replace("\\", "/"),
 3634: 110:         "existing_count": len(existing_names),
 3635: 111:         "candidates_count": len(candidates),
 3636: 112:         "skipped_count": len(skipped),
 3637: 113:         "candidates": candidates,
 3638: 114:         "skipped": skipped,
 3639: 115:         "apply_mode": bool(args.apply),
 3640: 116:     }
 3641: 117:     out_path = (repo_root / args.output).resolve()
 3642: 118:     out_path.parent.mkdir(parents=True, exist_ok=True)
 3643: 119:     out_path.write_text(json.dumps(proposal, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
 3644: 120:     md_path = out_path.with_suffix(".md")
 3645: 121:     lines = [
 3646: 122:         "# Boost Discovery Proposal",
 3647: 123:         "",
 3648: 124:         f"- timestamp: {proposal['timestamp']}",
 3649: 125:         f"- candidates: {proposal['candidates_count']}",
 3650: 126:         f"- skipped: {proposal['skipped_count']}",
 3651: 127:         "",
 3652: 128:         "## Candidates",
 3653: 129:         "",
 3654: 130:     ]
 3655: 131:     if candidates:
 3656: 132:         for c in candidates:
 3657: 133:             lines.append(f"- {c['name']} ({c['domain']}) -> {c['location']}")
 3658: 134:     else:
 3659: 135:         lines.append("- none")
 3660: 136:     lines.extend(["", "## Skipped", ""])
 3661: 137:     if skipped:
 3662: 138:         for s in skipped:
 3663: 139:             lines.append(f"- {s['folder']}: {s['reason']}")
 3664: 140:     else:
 3665: 141:         lines.append("- none")
 3666: 142:     md_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
 3667: 143:     if args.apply and candidates:
 3668: 144:         registry_repos = registry.get("repos", [])
 3669: 145:         if not isinstance(registry_repos, list):
 3670: 146:             print("Registry repos field is invalid.")
 3671: 147:             return 1
 3672: 148:         registry_repos.extend(candidates)
 3673: 149:         registry["repos"] = registry_repos
 3674: 150:         registry_path.write_text(json.dumps(registry, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
 3675: 151:         print(f"Applied {len(candidates)} candidates to registry.")
 3676: 152:     else:
 3677: 153:         print("Dry-run mode. No registry changes applied.")
 3678: 154:     print(f"Proposal JSON: {out_path}")
 3679: 155:     print(f"Proposal MD: {md_path}")
 3680: 156:     return 0
 3681: 157: if __name__ == "__main__":
 3682: 158:     raise SystemExit(main())
 3683: </file>
