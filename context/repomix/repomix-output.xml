<file path="scripts/intake/validate-repo-registry.py">
  1: from __future__ import annotations
  2: import argparse
  3: import json
  4: import re
  5: from dataclasses import dataclass
  6: from datetime import datetime, timezone
  7: from pathlib import Path
  8: from typing import Any
  9: try:
 10:     import yaml  # type: ignore
 11: except Exception:
 12:     yaml = None
 13: def utc_now() -> str:
 14:     return datetime.now(timezone.utc).isoformat()
 15: def parse_simple_yml(path: Path) -> dict[str, Any]:
 16:     repos: list[dict[str, Any]] = []
 17:     current: dict[str, Any] | None = None
 18:     for line in path.read_text(encoding="utf-8").splitlines():
 19:         st = line.strip()
 20:         if st.startswith("- name:"):
 21:             if current:
 22:                 repos.append(current)
 23:             current = {"name": st.split(":", 1)[1].strip()}
 24:         elif current and ":" in st and not st.startswith("#"):
 25:             k, v = st.split(":", 1)
 26:             k = k.strip()
 27:             v = v.strip().strip('"')
 28:             if k in {"domain", "location", "type"}:
 29:                 current[k] = v
 30:     if current:
 31:         repos.append(current)
 32:     return {"schema_version": "1.0", "repos": repos}
 33: def load_registry(path: Path) -> dict[str, Any]:
 34:     content = path.read_text(encoding="utf-8")
 35:     # JSON-first support (JSON is valid YAML, but this path avoids extra deps).
 36:     if content.lstrip().startswith("{"):
 37:         return json.loads(content)
 38:     if yaml is not None:
 39:         data = yaml.safe_load(content) or {}
 40:         if isinstance(data, dict):
 41:             return data
 42:     return parse_simple_yml(path)
 43: @dataclass
 44: class ValidationResult:
 45:     errors: list[str]
 46:     warnings: list[str]
 47: def validate(registry: dict[str, Any], strict: bool, repo_root: Path) -> ValidationResult:
 48:     errors: list[str] = []
 49:     warnings: list[str] = []
 50:     repos = registry.get("repos")
 51:     if not isinstance(repos, list) or not repos:
 52:         return ValidationResult(errors=["Registry must define a non-empty repos list."], warnings=[])
 53:     schema_version = str(registry.get("schema_version", "1.0"))
 54:     is_v2 = schema_version >= "2.0"
 55:     governance = registry.get("governance", {}) if isinstance(registry.get("governance", {}), dict) else {}
 56:     repo_name_prefix = str(governance.get("repo_name_prefix", "boost_")).strip() or "boost_"
 57:     names: set[str] = set()
 58:     graph: dict[str, list[str]] = {}
 59:     for repo in repos:
 60:         if not isinstance(repo, dict):
 61:             errors.append("Each repo entry must be an object.")
 62:             continue
 63:         name = str(repo.get("name", "")).strip()
 64:         if not name:
 65:             errors.append("Repo is missing required field: name")
 66:             continue
 67:         if strict or is_v2:
 68:             if not name.startswith(repo_name_prefix):
 69:                 errors.append(
 70:                     f"Repo '{name}' does not satisfy naming contract. Expected prefix '{repo_name_prefix}'."
 71:                 )
 72:         if name in names:
 73:             errors.append(f"Duplicate repo name: {name}")
 74:             continue
 75:         names.add(name)
 76:         for field in ("domain", "location", "type"):
 77:             if not str(repo.get(field, "")).strip():
 78:                 errors.append(f"Repo '{name}' is missing required field: {field}")
 79:         if str(repo.get("type", "")).strip() and repo.get("type") != "local":
 80:             errors.append(f"Repo '{name}' type must be 'local' in this phase.")
 81:         location = str(repo.get("location", "")).strip()
 82:         if location:
 83:             resolved = (repo_root / location).resolve()
 84:             if not resolved.exists():
 85:                 if bool(repo.get("optional", False)):
 86:                     warnings.append(f"Optional repo '{name}' location does not exist: {location}")
 87:                 else:
 88:                     errors.append(f"Repo '{name}' location does not exist: {location}")
 89:         deps = repo.get("dependencies", [])
 90:         dep_refs: list[str] = []
 91:         if deps:
 92:             if not isinstance(deps, list):
 93:                 errors.append(f"Repo '{name}' dependencies must be a list.")
 94:             else:
 95:                 for dep in deps:
 96:                     if not isinstance(dep, dict) or not str(dep.get("ref", "")).strip():
 97:                         errors.append(f"Repo '{name}' has a dependency without ref.")
 98:                         continue
 99:                     dep_refs.append(str(dep["ref"]))
100:         graph[name] = dep_refs
101:         if strict or is_v2:
102:             approval = repo.get("approval")
103:             if not isinstance(approval, dict):
104:                 errors.append(f"Repo '{name}' requires approval block in v2/strict mode.")
105:             else:
106:                 if approval.get("status") != "approved":
107:                     errors.append(f"Repo '{name}' is not approved (approval.status must be 'approved').")
108:                 if not str(approval.get("approved_by", "")).strip():
109:                     errors.append(f"Repo '{name}' missing approval.approved_by")
110:                 if not str(approval.get("approved_date", "")).strip():
111:                     errors.append(f"Repo '{name}' missing approval.approved_date")
112:                 if not str(approval.get("review_ticket", "")).strip():
113:                     warnings.append(f"Repo '{name}' missing approval.review_ticket")
114:     for src, dep_refs in graph.items():
115:         for dep in dep_refs:
116:             if dep not in names:
117:                 errors.append(f"Repo '{src}' depends on unknown repo '{dep}'.")
118:     # Cycle detection via DFS colors: 0=unseen, 1=visiting, 2=done
119:     state: dict[str, int] = {name: 0 for name in names}
120:     def visit(node: str) -> None:
121:         if state[node] == 1:
122:             errors.append(f"Dependency cycle detected at '{node}'.")
123:             return
124:         if state[node] == 2:
125:             return
126:         state[node] = 1
127:         for nxt in graph.get(node, []):
128:             if nxt in state:
129:                 visit(nxt)
130:         state[node] = 2
131:     for name in names:
132:         visit(name)
