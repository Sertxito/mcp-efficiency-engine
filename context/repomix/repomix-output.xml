 9050: 120:     md_path = out_path.with_suffix(".md")
 9051: 121:     lines = [
 9052: 122:         "# Boost Discovery Proposal",
 9053: 123:         "",
 9054: 124:         f"- timestamp: {proposal['timestamp']}",
 9055: 125:         f"- candidates: {proposal['candidates_count']}",
 9056: 126:         f"- skipped: {proposal['skipped_count']}",
 9057: 127:         "",
 9058: 128:         "## Candidates",
 9059: 129:         "",
 9060: 130:     ]
