531: $stamp = Get-Date -Format 'yyyyMMdd-HHmmss'
532: $reportPath = Join-Path $reportDir "hi-$stamp.json"
533: $report | ConvertTo-Json -Depth 8 | Set-Content -Path $reportPath -Encoding UTF8
534: 
535: Write-Host "Report: $reportPath"
536: 
537: if ($script:HasFailures) {
538:     Write-Host 'HI startup finished with errors.' -ForegroundColor Red
539:     exit 1
540: }
541: 
542: Write-Host 'HI startup completed successfully.' -ForegroundColor Green
543: exit 0
