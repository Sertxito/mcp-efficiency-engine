271:         'context/graphify-out/manifest.json',
272:         'repo-intake/generated/reports/repo-registry-validation.json'
273:     )
274: 
275:     foreach ($item in $requiredPaths) {
276:         if (-not (Test-Path $item)) {
277:             throw "Missing required artifact: $item"
278:         }
279:     }
280: 
281:     if (-not (Get-Command codebase-memory-mcp -ErrorAction SilentlyContinue)) {
282:         throw 'codebase-memory-mcp command not found (memory layer unavailable)'
283:     }
284: } -Required $true
285: 
286: Invoke-Step -Name 'Check structure cache freshness' -Action {
287:     $registryPath = Join-Path $repoRoot 'repo-registry/repos.yml'
288:     $registry = Get-Content $registryPath -Raw | ConvertFrom-Json -Depth 20
289:     $before = @()
290: 
291:     foreach ($repo in $registry.repos) {
292:         $before += (Get-StructureSnapshot -RepoRoot $repoRoot -Repo $repo)
293:     }
294: 
295:     $missing = @($before | Where-Object { $_.status -eq 'missing' }).Count
296:     $stale = @($before | Where-Object { $_.status -eq 'stale' }).Count
297:     $needsRefresh = ($missing -gt 0 -or $stale -gt 0)
298: 
299:     $script:StructureCacheReport.before = $before
300:     $script:StructureCacheReport.refresh_reason = if ($needsRefresh) {
301:         "missing=$missing, stale=$stale"
302:     }
303:     else {
304:         'none'
305:     }
306: 
307:     if ($needsRefresh -and -not $SkipIntake) {
308:         & .\scripts\intake\run-repo-intake.cmd
309:         if ($LASTEXITCODE -ne 0) {
310:             throw "run-repo-intake failed during structure cache refresh with exit code $LASTEXITCODE"
311:         }
312:         $script:StructureCacheReport.refreshed = $true
313:     }
314: 
315:     $after = @()
316:     foreach ($repo in $registry.repos) {
317:         $after += (Get-StructureSnapshot -RepoRoot $repoRoot -Repo $repo)
318:     }
319:     $script:StructureCacheReport.after = $after
320: 
321:     $changedRepos = @()
322:     foreach ($beforeEntry in $before) {
323:         $afterEntry = $after | Where-Object { $_.repo -eq $beforeEntry.repo } | Select-Object -First 1
324:         if ($null -eq $afterEntry) {
325:             continue
326:         }
327: 
328:         if ($beforeEntry.cache_fingerprint -ne $afterEntry.cache_fingerprint -or $beforeEntry.status -ne $afterEntry.status) {
329:             $changedRepos += [ordered]@{
330:                 repo = $beforeEntry.repo
331:                 before_status = $beforeEntry.status
332:                 after_status = $afterEntry.status
333:                 before_fingerprint = $beforeEntry.cache_fingerprint
334:                 after_fingerprint = $afterEntry.cache_fingerprint
335:             }
336:         }
337:     }
338:     $script:StructureCacheReport.changed_repos = $changedRepos
339: 
340:     Write-Host ("Structure cache status: missing={0}, stale={1}, refreshed={2}" -f $missing, $stale, $script:StructureCacheReport.refreshed)
341: } -Required $true
342: 
343: if (-not $SkipSiblingReposChecks) {
344:     Invoke-Step -Name 'Validate sibling repos operability' -Action {
345:         $registryPath = Join-Path $repoRoot 'repo-registry/repos.yml'
346:         $registry = Get-Content $registryPath -Raw | ConvertFrom-Json -Depth 20
347: 
348:         foreach ($repo in $registry.repos) {
349:             $location = Resolve-RepoPath -Root $repoRoot -RelativePath ([string]$repo.location)
350:             if (-not (Test-Path $location)) {
351:                 throw "Sibling repo path not found: $($repo.name) -> $location"
352:             }
353: 
354:             $slug = ([string]$repo.name).ToLower() -replace '[^a-z0-9_-]+', '-'
355:             $manifest = Join-Path $repoRoot ("repo-intake/generated/{0}/context-manifests/manifest.json" -f $slug)
356:             $structure = Join-Path $repoRoot ("repo-intake/generated/{0}/context-manifests/structure-min.json" -f $slug)
357:             $capability = Join-Path $repoRoot ("repo-intake/generated/{0}/capabilities/capability.json" -f $slug)
358: 
359:             if (-not (Test-Path $manifest)) {
360:                 throw "Missing sibling manifest: $manifest"
361:             }
362:             if (-not (Test-Path $structure)) {
363:                 throw "Missing sibling structure cache: $structure"
364:             }
365:             if (-not (Test-Path $capability)) {
366:                 throw "Missing sibling capability: $capability"
367:             }
368: 
369:             $structureData = Get-Content $structure -Raw | ConvertFrom-Json -Depth 20
370:             if ([string]$structureData.repo -ne [string]$repo.name) {
371:                 throw "Structure cache repo mismatch for $($repo.name): found '$($structureData.repo)'"
372:             }
373:             if (-not [bool]$structureData.exists -and -not [bool]$repo.optional) {
374:                 throw "Structure cache indicates missing path for required repo '$($repo.name)'"
375:             }
376:         }
377:     } -Required $true
378: }
379: else {
380:     Write-Host '[skip] Validate sibling repos operability'
381: }
382: 
383: if (-not $SkipAgentPipelinePreflight) {
384:     Invoke-Step -Name 'Validate agent pipeline preflight' -Action {
385:         $py = Get-PythonCommand
386:         $cmd = $py[0]
387:         $pyParts = @()
388:         if ($py.Length -gt 1) {
389:             $pyParts = $py[1..($py.Length - 1)]
390:         }
391: 
392:         & $cmd @pyParts .\scripts\intake\agent-pipeline-preflight.py
393:         if ($LASTEXITCODE -ne 0) {
394:             throw "agent-pipeline-preflight failed with exit code $LASTEXITCODE"
395:         }
396:     } -Required $true
397: }
398: else {
399:     Write-Host '[skip] Validate agent pipeline preflight'
400: }
401: 
402: if (-not $SkipMcpStartupChecks) {
403:     Invoke-Step -Name 'Validate MCP servers start/listen capability' -Action {
404:         $py = Get-PythonCommand
405:         $pyCmd = $py[0]
406:         $pyParts = @()
407:         if ($py.Length -gt 1) {
408:             $pyParts = $py[1..($py.Length - 1)]
409:         }
410: 
411:         $graphifyCmd = "$pyCmd"
412:         if ($pyParts.Count -gt 0) {
413:             $graphifyCmd += " " + ($pyParts -join ' ')
414:         }
415:         $graphifyCmd += ' -m graphify.serve --transport stdio context/graphify-out/graph.json'
416: 
417:         $checks = @(
418:             @{ name = 'token-saver-mcp'; command = 'token-saver-mcp' },
419:             @{ name = 'codebase-memory-mcp'; command = 'codebase-memory-mcp' },
420:             @{ name = 'codegraph'; command = 'codegraph serve --mcp' },
421:             @{ name = 'gitnexus'; command = 'npx -y gitnexus@latest mcp' },
422:             @{ name = 'repomix'; command = 'npx -y repomix@latest --mcp' },
423:             @{ name = 'graphify'; command = $graphifyCmd }
424:         )
425: 
426:         foreach ($check in $checks) {
427:             Test-LongRunningCommand -Name $check.name -Command $check.command
428:         }
429:     } -Required $true
430: }
431: else {
432:     Write-Host '[skip] Validate MCP servers start/listen capability'
433: }
434: 
435: if (-not $SkipGraphRefresh) {
436:     Invoke-Step -Name 'Refresh codegraph index sync' -Action {
437:         if (-not (Get-Command codegraph -ErrorAction SilentlyContinue)) {
438:             throw 'codegraph command not found'
