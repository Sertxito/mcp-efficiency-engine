 6046: 179: function Test-LongRunningCommand {
 6047: 180:     param(
 6048: 181:         [string]$Name,
 6049: 182:         [string]$Command,
 6050: 183:         [int]$WarmupSec = 4,
 6051: 184:         [int]$TimeoutSec = 25
 6052: 185:     )
 6053: 186: 
 6054: 187:     $outFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.out" -f $Name, ([guid]::NewGuid().ToString('N')))
 6055: 188:     $errFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.err" -f $Name, ([guid]::NewGuid().ToString('N')))
 6056: 189: 
 6057: 190:     $proc = Start-Process -FilePath 'pwsh' -ArgumentList @('-NoProfile', '-ExecutionPolicy', 'Bypass', '-Command', $Command) -PassThru -RedirectStandardOutput $outFile -RedirectStandardError $errFile
 6058: 191:     $start = Get-Date
 6059: 192:     $deadline = $start.AddSeconds($TimeoutSec)
 6060: 193:     $isReady = $false
 6061: 194: 
 6062: 195:     while ((Get-Date) -lt $deadline) {
 6063: 196:         if ($proc.HasExited) {
 6064: 197:             if ($proc.ExitCode -eq 0) {
 6065: 198:                 $isReady = $true
 6066: 199:                 break
 6067: 200:             }
 6068: 201: 
 6069: 202:             $errText = ''
 6070: 203:             if (Test-Path $errFile) {
 6071: 204:                 $errText = (Get-Content $errFile -Raw)
 6072: 205:             }
 6073: 206:             throw "$Name failed to start. ExitCode=$($proc.ExitCode). $errText"
 6074: 207:         }
 6075: 208: 
 6076: 209:         if (((Get-Date) - $start).TotalSeconds -ge $WarmupSec) {
 6077: 210:             $isReady = $true
 6078: 211:             break
 6079: 212:         }
 6080: 213: 
 6081: 214:         Start-Sleep -Milliseconds 250
 6082: 215:     }
 6083: 216: 
 6084: 217:     if (-not $isReady) {
 6085: 218:         throw "$Name did not become ready within ${TimeoutSec}s"
 6086: 219:     }
 6087: 220: 
 6088: 221:     if (-not $proc.HasExited) {
 6089: 222:         Stop-Process -Id $proc.Id -Force
 6090: 223:     }
 6091: 224: 
 6092: 225:     Remove-Item $outFile, $errFile -ErrorAction SilentlyContinue
 6093: 226: }
