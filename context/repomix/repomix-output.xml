 9055:  4596: 25:         "--domain",
 9056:  4597: 26:         str(case.get("domain", "")),
 9057:  4598: 27:         "--source-type",
 9058:  4599: 28:         str(case.get("source_type", "technical-docs")),
 9059:  4600: 29:         "--capability",
 9060:  4601: 30:         str(case.get("capability", "")),
 9061:  4602: 31:     ]
 9062:  4603: 32:     proc = subprocess.run(cmd, cwd=str(repo_root), capture_output=True, text=True)
 9063:  4604: 33:     return proc.returncode == 0, (proc.stdout or "") + (proc.stderr or "")
 9064:  4605: 34: def main() -> int:
 9065:  4606: 35:     parser = argparse.ArgumentParser(description="Run routing eval cases and write JSON report.")
 9066:  4607: 36:     parser.add_argument("--cases", default="observability/evals/routing-eval-cases.json")
 9067:  4608: 37:     parser.add_argument("--report", default="observability/evals/routing-eval-report.json")
 9068:  4609: 38:     args = parser.parse_args()
