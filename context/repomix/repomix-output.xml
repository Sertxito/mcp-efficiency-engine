112: function Get-StructureSnapshot {
113:     param(
114:         [string]$RepoRoot,
115:         [object]$Repo
116:     )
117: 
118:     $repoName = [string]$Repo.name
119:     $slug = $repoName.ToLower() -replace '[^a-z0-9_-]+', '-'
120:     $repoPath = Resolve-RepoPath -Root $RepoRoot -RelativePath ([string]$Repo.location)
121:     $structurePath = Join-Path $RepoRoot ("repo-intake/generated/{0}/context-manifests/structure-min.json" -f $slug)
122: 
123:     $repoLatest = [datetime]::MinValue
124:     if (Test-Path $repoPath) {
125:         $pathsToCheck = @(
126:             $repoPath,
127:             (Join-Path $repoPath 'AGENTS.md'),
128:             (Join-Path $repoPath 'README.md'),
129:             (Join-Path $repoPath 'ARCHITECTURE.md'),
130:             (Join-Path $repoPath '.github/skills'),
131:             (Join-Path $repoPath '.github/prompts'),
132:             (Join-Path $repoPath 'scripts'),
133:             (Join-Path $repoPath 'specs')
134:         )
135: 
136:         foreach ($path in $pathsToCheck) {
137:             $lastWrite = Get-PathLastWriteUtc -Path $path
138:             if ($lastWrite -gt $repoLatest) {
139:                 $repoLatest = $lastWrite
140:             }
141:         }
142:     }
143: 
144:     $exists = Test-Path $structurePath
145:     $structureMtime = [datetime]::MinValue
146:     $cacheFingerprint = ''
147:     $structureRepoExists = $false
148: 
149:     if ($exists) {
150:         $structureMtime = (Get-Item $structurePath).LastWriteTimeUtc
151:         $structureData = Get-Content $structurePath -Raw | ConvertFrom-Json -Depth 20
152:         $cacheFingerprint = [string]$structureData.cache_fingerprint
153:         $structureRepoExists = [bool]$structureData.exists
154:     }
155: 
156:     $status = 'fresh'
157:     if (-not $exists) {
158:         $status = 'missing'
159:     }
160:     elseif ((Test-Path $repoPath) -and $repoLatest -gt $structureMtime) {
161:         $status = 'stale'
162:     }
163: 
164:     return [ordered]@{
165:         repo = $repoName
166:         slug = $slug
167:         version = '0'
168:         repo_path = $repoPath
169:         structure_path = $structurePath
170:         structure_exists = $exists
171:         structure_reports_repo_exists = $structureRepoExists
172:         cache_fingerprint = $cacheFingerprint
173:         repo_latest_change_utc = if ($repoLatest -eq [datetime]::MinValue) { '' } else { $repoLatest.ToString('o') }
174:         structure_mtime_utc = if ($structureMtime -eq [datetime]::MinValue) { '' } else { $structureMtime.ToString('o') }
175:         status = $status
176:     }
177: }
