32818: 19876:  31:     text = path.read_text(encoding="utf-8")
32819: 19877:  32:     if not text.strip():
32820: 19878:  33:         text = header
32821: 19879:  34:     if AUTO_START in text and AUTO_END in text:
32822: 19880:  35:         start = text.index(AUTO_START)
32823: 19881:  36:         end = text.index(AUTO_END) + len(AUTO_END)
32824: 19882:  37:         new_text = text[:start].rstrip() + "\n\n" + auto_text
