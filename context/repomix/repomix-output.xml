63:   if (Get-Command py -ErrorAction SilentlyContinue) {
64:     $pythonCmd = "py"
65:     $pythonArgs = @("-3.14", "-c", "import graphify.serve, mcp; print('ok')")
66:   }
67: 
68:   & $pythonCmd @pythonArgs *> $null
69:   if ($LASTEXITCODE -ne 0) {
70:     $errors += 'Graphify MCP runtime missing. Run: py -3.14 -m pip install graphifyy and mcp'
71:   }
72: }
73: 
74: if (-not (Test-Path "context/graphify-out/graph.json")) {
75:   $errors += "Missing context/graphify-out/graph.json. Run: py -3.14 -m graphify extract scripts --no-cluster --out context"
76: }
77: 
78: if($errors.Count -eq 0){
79:   Write-Host "Validation OK. Always-on optimization documented."
80:   Write-Host "Running strict repo registry validation..."
81:   pwsh -NoProfile -File .\scripts\intake\validate-repo-registry.ps1 -Strict
82: }
83: else {
84:   $errors | ForEach-Object { Write-Host $_ }
85: }
</file>

