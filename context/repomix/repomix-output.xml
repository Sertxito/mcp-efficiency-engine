 14: 
 15: function Test-Command {
 16:     param([Parameter(Mandatory = $true)][string]$Name)
 17: 
 18:     return [bool](Get-Command -Name $Name -ErrorAction SilentlyContinue)
 19: }
 20: 
 21: function Install-NpmGlobalPackage {
 22:     param(
 23:         [Parameter(Mandatory = $true)][string]$Package,
 24:         [Parameter(Mandatory = $true)][string]$ExpectedCommand
 25:     )
 26: 
 27:     if (Test-Command $ExpectedCommand) {
 28:         Write-Host "[ok] $ExpectedCommand already installed"
 29:         return
 30:     }
 31: 
 32:     if (-not (Test-Command 'npm')) {
 33:         throw "npm is required to install $Package. Install Node.js first: https://nodejs.org/"
 34:     }
 35: 
 36:     Write-Host "[install] npm install -g $Package"
 37:     npm install -g $Package
 38: }
 39: 
 40: function Test-PythonImport {
 41:     param(
 42:         [Parameter(Mandatory = $true)][string]$PythonCommand,
 43:         [string[]]$PythonArgs = @(),
 44:         [Parameter(Mandatory = $true)][string]$Module
 45:     )
 46: 
 47:     & $PythonCommand @PythonArgs -c "import $Module" *> $null
 48:     return ($LASTEXITCODE -eq 0)
 49: }
 50: 
 51: function Resolve-PythonCommand {
 52:     if (Test-Command 'py') {
 53:         return @('py', '-3.14')
 54:     }
 55:     if (Test-Command 'python') {
 56:         return @('python')
 57:     }
 58:     throw 'Python 3.14 is required for graphify MCP. Install Python first: https://www.python.org/downloads/'
 59: }
 60: 
 61: Write-Host '== MCP platform prerequisites setup =='
 62: 
 63: if (-not $SkipCodebaseMemory) {
 64:     if (Test-Command 'codebase-memory-mcp') {
 65:         Write-Host '[ok] codebase-memory-mcp already installed'
 66:     }
 67:     else {
 68:         Write-Host '[install] codebase-memory-mcp via official Windows setup script'
 69:         Invoke-RestMethod https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/scripts/setup-windows.ps1 | Invoke-Expression
 70:     }
 71: }
 72: 
 73: if (-not $SkipTokenSaver) {
 74:     Install-NpmGlobalPackage -Package 'token-saver-mcp' -ExpectedCommand 'token-saver-mcp'
 75: }
 76: 
 77: if (-not $SkipCodegraph) {
 78:     Install-NpmGlobalPackage -Package '@colbymchenry/codegraph' -ExpectedCommand 'codegraph'
 79:     Write-Host '[setup] codegraph install'
 80:     codegraph install
 81:     if (-not (Test-Path '.codegraph')) {
 82:         Write-Host '[setup] codegraph init -i'
 83:         codegraph init -i
 84:     }
 85:     else {
 86:         Write-Host '[ok] .codegraph index already exists'
 87:     }
 88: }
 89: 
 90: if (-not $SkipGitnexus) {
 91:     Install-NpmGlobalPackage -Package 'gitnexus@latest' -ExpectedCommand 'gitnexus'
 92:     Write-Host '[setup] gitnexus setup'
 93:     gitnexus setup
 94: }
 95: 
 96: if (-not $SkipRepomix) {
 97:     Install-NpmGlobalPackage -Package 'repomix@latest' -ExpectedCommand 'repomix'
 98: }
 99: 
100: if (-not $SkipGraphify) {
101:     $py = Resolve-PythonCommand
102:     $pyCmd = $py[0]
103:     $pyArgs = @()
104:     if ($py.Length -gt 1) {
105:         $pyArgs = $py[1..($py.Length - 1)]
106:     }
107: 
108:     if ($py.Length -gt 1) {
109:         Write-Host "[setup] Using Python launcher: $($py -join ' ')"
110:     }
111:     else {
112:         Write-Host "[setup] Using Python launcher: $pyCmd"
113:     }
114: 
115:     Write-Host '[install] python -m pip install "graphifyy[mcp]"'
116:     & $pyCmd @pyArgs -m pip install "graphifyy[mcp]"
117: 
118:     if (-not (Test-PythonImport -PythonCommand $pyCmd -PythonArgs $pyArgs -Module 'graphify.serve')) {
119:         throw 'graphify.serve import failed after installation.'
120:     }
121: 
122:     if (-not (Test-PythonImport -PythonCommand $pyCmd -PythonArgs $pyArgs -Module 'mcp')) {
123:         throw 'mcp module import failed after graphify installation.'
124:     }
125: 
126:     if (-not (Test-Path 'context/graphify-out/graph.json')) {
127:         Write-Host '[setup] graphify extract scripts --no-cluster --out context'
128:         & $pyCmd @pyArgs -m graphify extract scripts --no-cluster --out context
129:     }
130:     else {
131:         Write-Host '[ok] context/graphify-out/graph.json already exists'
132:     }
133: }
134: 
135: Write-Host ''
136: Write-Host 'Setup complete. Recommended next checks:'
137: Write-Host '  1) .\scripts\setup\validate-context.ps1'
138: Write-Host '  2) .\scripts\intake\run-repo-intake.cmd'
139: Write-Host '  3) /mcp (in your agent) to verify servers are active'
</file>

<file path="specs/observability.spec.md">
