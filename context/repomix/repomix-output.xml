22187: 158:         $status = 'missing'
22188: 159:     }
22189: 160:     elseif ((Test-Path $repoPath) -and $repoLatest -gt $structureMtime) {
22190: 161:         $status = 'stale'
22191: 162:     }
22192: 163: 
22193: 164:     return [ordered]@{
22194: 165:         repo = $repoName
