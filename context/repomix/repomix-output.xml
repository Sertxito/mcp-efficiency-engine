27:     cps = float(kpis.get("cost_per_confirmed_success_usd", 0.0) or 0.0)
28:     has_value_signal = bool(assessment.get("has_value_signal", False))
29:     failures: list[str] = []
30:     if events_with_id < args.min_events_with_id:
31:         failures.append(f"events_with_event_id {events_with_id} < {args.min_events_with_id}")
32:     if confirmed < args.min_confirmed:
33:         failures.append(f"feedback_confirmed {confirmed} < {args.min_confirmed}")
34:     if metrics_cov < args.min_metrics_coverage:
35:         failures.append(f"metrics_coverage_rate {metrics_cov:.4f} < {args.min_metrics_coverage:.4f}")
36:     if feedback_cov < args.min_feedback_coverage:
37:         failures.append(f"confirmed_feedback_rate {feedback_cov:.4f} < {args.min_feedback_coverage:.4f}")
38:     if success_rate < args.min_success_rate:
39:         failures.append(f"confirmed_success_rate {success_rate:.4f} < {args.min_success_rate:.4f}")
40:     if has_value_signal and cps > args.max_cost_per_success:
41:         failures.append(f"cost_per_confirmed_success_usd {cps:.6f} > {args.max_cost_per_success:.6f}")
42:     print("AutoLearning Gate Summary")
43:     print(f"- events_with_event_id: {events_with_id}")
44:     print(f"- feedback_confirmed: {confirmed}")
45:     print(f"- metrics_coverage_rate: {metrics_cov:.4f}")
46:     print(f"- confirmed_feedback_rate: {feedback_cov:.4f}")
47:     print(f"- confirmed_success_rate: {success_rate:.4f}")
48:     print(f"- cost_per_confirmed_success_usd: {cps:.6f}")
49:     print(f"- has_value_signal: {has_value_signal}")
50:     if failures:
51:         print("AutoLearning Gate FAILED:")
52:         for f in failures:
53:             print(f"  - {f}")
54:         raise SystemExit(1)
