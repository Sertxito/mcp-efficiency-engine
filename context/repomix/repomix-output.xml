20:     kpis = data.get("kpis", {}) if isinstance(data.get("kpis", {}), dict) else {}
21:     assessment = data.get("assessment", {}) if isinstance(data.get("assessment", {}), dict) else {}
22:     events_with_id = int(totals.get("events_with_event_id", 0) or 0)
23:     confirmed = int(totals.get("feedback_confirmed", 0) or 0)
24:     metrics_cov = float(kpis.get("metrics_coverage_rate", 0.0) or 0.0)
25:     feedback_cov = float(kpis.get("confirmed_feedback_rate", 0.0) or 0.0)
