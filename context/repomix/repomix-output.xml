19685: <file path="scripts/discovery/discover-boost-repos.py">
19686:   1: from __future__ import annotations
19687:   2: import argparse
19688:   3: import json
19689:   4: import re
19690:   5: from datetime import datetime, timezone
19691:   6: from pathlib import Path
19692:   7: from typing import Any
19693:   8: def utc_now() -> str:
19694:   9:     return datetime.now(timezone.utc).isoformat()
19695:  10: def load_registry(path: Path) -> dict[str, Any]:
19696:  11:     content = path.read_text(encoding="utf-8")
19697:  12:     if content.lstrip().startswith("{"):
19698:  13:         return json.loads(content)
19699:  14:     raise ValueError("Registry must be JSON-first in current setup.")
19700:  15: def slug_name(folder_name: str) -> str:
19701:  16:     name = folder_name.lower().replace("-", "_")
19702:  17:     name = re.sub(r"[^a-z0-9_]+", "_", name)
19703:  18:     name = re.sub(r"_+", "_", name).strip("_")
19704:  19:     if not name.startswith("boost_"):
19705:  20:         name = f"boost_{name}"
19706:  21:     return name
19707:  22: def infer_domain(folder_name: str) -> str:
19708:  23:     token = folder_name.lower()
19709:  24:     if "dba" in token or "sql" in token or "db" in token:
19710:  25:         return "dba"
19711:  26:     if "iot" in token or "edge" in token:
19712:  27:         return "iot"
19713:  28:     if "rag" in token or "azure" in token:
19714:  29:         return "azure-rag"
19715:  30:     if "legacy" in token or "migration" in token:
19716:  31:         return "legacy"
19717:  32:     return "dev"
19718:  33: def default_engines(domain: str) -> dict[str, str]:
19719:  34:     if domain == "dba":
19720:  35:         return {"knowledge": "graphify", "execution": "none", "snapshot": "repomix"}
19721:  36:     if domain == "iot":
19722:  37:         return {"knowledge": "graphify", "execution": "gitnexus", "snapshot": "repomix"}
19723:  38:     if domain == "azure-rag":
19724:  39:         return {"knowledge": "azure-rag-builder", "execution": "none", "snapshot": "repomix"}
19725:  40:     if domain == "legacy":
19726:  41:         return {"knowledge": "gitnexus", "execution": "none", "snapshot": "repomix"}
19727:  42:     return {"knowledge": "codegraph", "execution": "none", "snapshot": "repomix"}
19728:  43: def build_candidate(folder: Path, review_ticket_prefix: str, idx: int) -> dict[str, Any]:
19729:  44:     folder_name = folder.name
19730:  45:     repo_name = slug_name(folder_name)
19731:  46:     domain = infer_domain(folder_name)
19732:  47:     return {
19733:  48:         "name": repo_name,
19734:  49:         "domain": domain,
19735:  50:         "version": "1.0.0",
19736:  51:         "location": f"../{folder_name}",
19737:  52:         "type": "local",
19738:  53:         "dependencies": [],
19739:  54:         "approval": {
19740:  55:             "status": "approved",
19741:  56:             "approved_by": "platform-team",
19742:  57:             "approved_date": datetime.now().date().isoformat(),
19743:  58:             "review_ticket": f"{review_ticket_prefix}-{1000 + idx}",
19744:  59:         },
19745:  60:         "engines": default_engines(domain),
19746:  61:     }
19747:  62: def main() -> int:
19748:  63:     parser = argparse.ArgumentParser(description="Discover sibling boost_* repos and generate onboarding proposal.")
19749:  64:     parser.add_argument("--root", default="C:/repo", help="Parent folder containing sibling repos")
19750:  65:     parser.add_argument("--registry", default="repo-registry/repos.yml", help="Registry file path")
19751:  66:     parser.add_argument("--output", default="repo-intake/generated/reports/boost-discovery-proposal.json")
19752:  67:     parser.add_argument("--apply", action="store_true", help="Apply candidates directly to registry")
19753:  68:     parser.add_argument("--review-ticket-prefix", default="PLATFORM", help="Prefix used for generated review tickets")
19754:  69:     args = parser.parse_args()
19755:  70:     repo_root = Path(__file__).resolve().parents[2]
19756:  71:     registry_path = (repo_root / args.registry).resolve()
19757:  72:     registry = load_registry(registry_path)
19758:  73:     prefix = str(registry.get("governance", {}).get("repo_name_prefix", "boost_"))
19759:  74:     root = Path(args.root)
19760:  75:     if not root.exists():
19761:  76:         print(f"Root path not found: {root}")
19762:  77:         return 1
19763:  78:     existing_names = {
19764:  79:         str(r.get("name", ""))
19765:  80:         for r in registry.get("repos", [])
19766:  81:         if isinstance(r, dict)
19767:  82:     }
19768:  83:     existing_locations = {
19769:  84:         str(r.get("location", ""))
19770:  85:         for r in registry.get("repos", [])
19771:  86:         if isinstance(r, dict)
19772:  87:     }
19773:  88:     siblings = [
19774:  89:         p for p in root.iterdir()
19775:  90:         if p.is_dir() and p.name.startswith(prefix) and p.name != repo_root.name
19776:  91:     ]
19777:  92:     candidates: list[dict[str, Any]] = []
19778:  93:     skipped: list[dict[str, str]] = []
19779:  94:     idx = 1
19780:  95:     for folder in sorted(siblings, key=lambda x: x.name.lower()):
19781:  96:         candidate = build_candidate(folder=folder, review_ticket_prefix=args.review_ticket_prefix, idx=idx)
19782:  97:         idx += 1
19783:  98:         if candidate["name"] in existing_names:
19784:  99:             skipped.append({"folder": folder.name, "reason": "already_registered_name"})
19785: 100:             continue
19786: 101:         if candidate["location"] in existing_locations:
19787: 102:             skipped.append({"folder": folder.name, "reason": "already_registered_location"})
19788: 103:             continue
19789: 104:         candidates.append(candidate)
19790: 105:     proposal = {
19791: 106:         "timestamp": utc_now(),
19792: 107:         "root": str(root).replace("\\", "/"),
19793: 108:         "prefix": prefix,
19794: 109:         "registry": str(registry_path).replace("\\", "/"),
19795: 110:         "existing_count": len(existing_names),
19796: 111:         "candidates_count": len(candidates),
19797: 112:         "skipped_count": len(skipped),
19798: 113:         "candidates": candidates,
19799: 114:         "skipped": skipped,
19800: 115:         "apply_mode": bool(args.apply),
19801: 116:     }
19802: 117:     out_path = (repo_root / args.output).resolve()
19803: 118:     out_path.parent.mkdir(parents=True, exist_ok=True)
19804: 119:     out_path.write_text(json.dumps(proposal, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
19805: 120:     md_path = out_path.with_suffix(".md")
19806: 121:     lines = [
19807: 122:         "# Boost Discovery Proposal",
19808: 123:         "",
19809: 124:         f"- timestamp: {proposal['timestamp']}",
19810: 125:         f"- candidates: {proposal['candidates_count']}",
19811: 126:         f"- skipped: {proposal['skipped_count']}",
19812: 127:         "",
19813: 128:         "## Candidates",
19814: 129:         "",
19815: 130:     ]
19816: 131:     if candidates:
19817: 132:         for c in candidates:
