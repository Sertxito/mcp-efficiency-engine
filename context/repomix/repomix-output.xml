255:   Write-Host "  first repo: $($firstRepo.name) [$($firstRepo.domain)] -> $($firstRepo.location)"
256:   Write-Host "  engines: knowledge=$($firstRepo.engines.knowledge), execution=$($firstRepo.engines.execution), snapshot=$($firstRepo.engines.snapshot)"
257: }
