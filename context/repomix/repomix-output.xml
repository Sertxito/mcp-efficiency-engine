 5979: 112: function Get-StructureSnapshot {
 5980: 113:     param(
 5981: 114:         [string]$RepoRoot,
 5982: 115:         [object]$Repo
 5983: 116:     )
 5984: 117: 
 5985: 118:     $repoName = [string]$Repo.name
 5986: 119:     $slug = $repoName.ToLower() -replace '[^a-z0-9_-]+', '-'
 5987: 120:     $repoPath = Resolve-RepoPath -Root $RepoRoot -RelativePath ([string]$Repo.location)
 5988: 121:     $structurePath = Join-Path $RepoRoot ("repo-intake/generated/{0}/context-manifests/structure-min.json" -f $slug)
 5989: 122: 
 5990: 123:     $repoLatest = [datetime]::MinValue
 5991: 124:     if (Test-Path $repoPath) {
 5992: 125:         $pathsToCheck = @(
 5993: 126:             $repoPath,
 5994: 127:             (Join-Path $repoPath 'AGENTS.md'),
 5995: 128:             (Join-Path $repoPath 'README.md'),
 5996: 129:             (Join-Path $repoPath 'ARCHITECTURE.md'),
 5997: 130:             (Join-Path $repoPath '.github/skills'),
 5998: 131:             (Join-Path $repoPath '.github/prompts'),
 5999: 132:             (Join-Path $repoPath 'scripts'),
 6000: 133:             (Join-Path $repoPath 'specs')
 6001: 134:         )
 6002: 135: 
 6003: 136:         foreach ($path in $pathsToCheck) {
 6004: 137:             $lastWrite = Get-PathLastWriteUtc -Path $path
 6005: 138:             if ($lastWrite -gt $repoLatest) {
 6006: 139:                 $repoLatest = $lastWrite
 6007: 140:             }
 6008: 141:         }
 6009: 142:     }
 6010: 143: 
 6011: 144:     $exists = Test-Path $structurePath
 6012: 145:     $structureMtime = [datetime]::MinValue
 6013: 146:     $cacheFingerprint = ''
 6014: 147:     $structureRepoExists = $false
 6015: 148: 
 6016: 149:     if ($exists) {
 6017: 150:         $structureMtime = (Get-Item $structurePath).LastWriteTimeUtc
 6018: 151:         $structureData = Get-Content $structurePath -Raw | ConvertFrom-Json -Depth 20
 6019: 152:         $cacheFingerprint = [string]$structureData.cache_fingerprint
 6020: 153:         $structureRepoExists = [bool]$structureData.exists
 6021: 154:     }
 6022: 155: 
 6023: 156:     $status = 'fresh'
 6024: 157:     if (-not $exists) {
 6025: 158:         $status = 'missing'
 6026: 159:     }
 6027: 160:     elseif ((Test-Path $repoPath) -and $repoLatest -gt $structureMtime) {
 6028: 161:         $status = 'stale'
 6029: 162:     }
 6030: 163: 
 6031: 164:     return [ordered]@{
 6032: 165:         repo = $repoName
 6033: 166:         slug = $slug
 6034: 167:         version = '0'
 6035: 168:         repo_path = $repoPath
 6036: 169:         structure_path = $structurePath
 6037: 170:         structure_exists = $exists
 6038: 171:         structure_reports_repo_exists = $structureRepoExists
 6039: 172:         cache_fingerprint = $cacheFingerprint
 6040: 173:         repo_latest_change_utc = if ($repoLatest -eq [datetime]::MinValue) { '' } else { $repoLatest.ToString('o') }
 6041: 174:         structure_mtime_utc = if ($structureMtime -eq [datetime]::MinValue) { '' } else { $structureMtime.ToString('o') }
 6042: 175:         status = $status
 6043: 176:     }
 6044: 177: }
