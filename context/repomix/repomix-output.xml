  775: 70: .\scripts\ops\bye.ps1 -SkipGraphRefresh -SkipIntakeRefresh -SkipSiblingDiscoveryRefresh
  776: 71: .\scripts\ops\bye.ps1 -SkipRepomixRefresh
  777: 72: .\scripts\ops\bye.ps1 -SkipProjectNotesRefresh
