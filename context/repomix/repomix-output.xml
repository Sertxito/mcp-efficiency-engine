176: 
177: if ((Test-Path $targetPath) -and -not $Force) {
178:   $currentRaw = Get-Content -Raw -Path $targetPath
179:   $currentRegistry = $null
180:   try {
181:     $currentRegistry = $currentRaw | ConvertFrom-Json -Depth 20
182:   }
183:   catch {
