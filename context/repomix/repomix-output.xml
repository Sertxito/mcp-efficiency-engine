185:     )
186: 
187:     $outFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.out" -f $Name, ([guid]::NewGuid().ToString('N')))
188:     $errFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.err" -f $Name, ([guid]::NewGuid().ToString('N')))
189: 
190:     $proc = Start-Process -FilePath 'pwsh' -ArgumentList @('-NoProfile', '-ExecutionPolicy', 'Bypass', '-Command', $Command) -PassThru -RedirectStandardOutput $outFile -RedirectStandardError $errFile
191:     $start = Get-Date
192:     $deadline = $start.AddSeconds($TimeoutSec)
193:     $isReady = $false
194: 
195:     while ((Get-Date) -lt $deadline) {
196:         if ($proc.HasExited) {
197:             if ($proc.ExitCode -eq 0) {
198:                 $isReady = $true
199:                 break
200:             }
201: 
202:             $errText = ''
203:             if (Test-Path $errFile) {
204:                 $errText = (Get-Content $errFile -Raw)
205:             }
206:             throw "$Name failed to start. ExitCode=$($proc.ExitCode). $errText"
207:         }
208: 
209:         if (((Get-Date) - $start).TotalSeconds -ge $WarmupSec) {
210:             $isReady = $true
211:             break
212:         }
213: 
214:         Start-Sleep -Milliseconds 250
215:     }
216: 
217:     if (-not $isReady) {
218:         throw "$Name did not become ready within ${TimeoutSec}s"
219:     }
220: 
221:     if (-not $proc.HasExited) {
222:         Stop-Process -Id $proc.Id -Force
223:     }
224: 
225:     Remove-Item $outFile, $errFile -ErrorAction SilentlyContinue
226: }
227: 
