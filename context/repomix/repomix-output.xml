<file path="scripts/setup/validate-context.ps1">
  1: Set-StrictMode -Version Latest
  2: $ErrorActionPreference = 'Stop'
  3: 
  4: $repoRoot = (Resolve-Path (Join-Path $PSScriptRoot '..\..')).Path
  5: Set-Location $repoRoot
  6: 
  7: Write-Host "Validating full v7 always-on..."
  8: $required = @(
  9:   ".vscode/mcp.json",
 10:   "AGENTS.md",
 11:   "FINAL_USAGE_GUIDE.md",
 12:   "ARCHITECTURE.md",
 13:   ".github/copilot-instructions.md",
 14:   ".github/instructions/always-on-optimization.instructions.md",
 15:   ".github/skills/token-saver/SKILL.md",
 16:   ".github/skills/ahorro-tokens/SKILL.md",
 17:   ".github/skills/caveman-mode/SKILL.md",
 18:   ".github/skills/caveman/SKILL.md",
 19:   ".github/skills/caveman-help/SKILL.md",
 20:   ".github/skills/caveman-review/SKILL.md",
 21:   ".github/skills/caveman-commit/SKILL.md",
 22:   ".github/skills/caveman-stats/SKILL.md",
 23:   ".github/skills/caveman-compress/SKILL.md",
 24:   ".github/skills/cavecrew/SKILL.md",
 25:   ".github/prompts/caveman.prompt.md",
 26:   ".github/prompts/caveman-help.prompt.md",
 27:   ".github/prompts/caveman-review.prompt.md",
 28:   ".github/prompts/caveman-commit.prompt.md",
 29:   ".github/prompts/caveman-stats.prompt.md",
 30:   ".github/prompts/caveman-compress.prompt.md",
 31:   ".github/prompts/cavecrew.prompt.md",
 32:   "optimization/ALWAYS_ON_OPTIMIZATION.md",
 33:   "docs/00-Ahorro_Tokens.md",
 34:   "optimization/token-saver.md",
 35:   "optimization/caveman-mode.md",
 36:   "optimization/optimization-routing.md",
 37:   "docs/02-always-on-optimization-guide.md",
 38:   "repo-registry/repos.schema.json",
 39:   "scripts/intake/validate-repo-registry.ps1",
 40:   "scripts/intake/validate-repo-registry.py",
 41:   "scripts/intake/run-repo-intake.cmd",
 42:   "observability/logs.schema.json",
 43:   "scripts/intake/resolve-routing.py",
 44:   "scripts/intake/run-routing-evals.py",
 45:   "observability/evals/routing-eval-cases.json",
 46:   "scripts/discovery/discover-boost-repos.py",
 47:   "scripts/discovery/discover-boost-repos.cmd",
 48:   "specs/architecture.spec.md",
 49:   "specs/azure-rag.spec.md",
 50:   "specs/coding-standards.spec.md",
 51:   "specs/database.spec.md",
 52:   "specs/migration.spec.md",
 53:   "specs/observability.spec.md",
 54:   "specs/optimization.spec.md",
 55:   "specs/repo-intake.spec.md",
 56:   "specs/rag.spec.md",
 57:   "specs/routing.spec.md",
 58:   "specs/security.spec.md"
 59: )
 60: $errors=@()
 61: foreach($i in $required){ if(!(Test-Path $i)){ $errors += "Missing $i" } }
 62: 
 63: try {
 64:   $mcpRaw = Get-Content -Raw -Path '.vscode/mcp.json' | ConvertFrom-Json -Depth 20
 65:   if ($mcpRaw.servers.gitnexus.command -ne 'gitnexus') {
 66:     $errors += 'MCP gitnexus command should be local `gitnexus` (avoid npx startup latency).'
 67:   }
 68:   $scanLimit = 0
 69:   $gitnexusHasEnv = ($mcpRaw.servers.gitnexus.PSObject.Properties.Name -contains 'env')
 70:   if ($gitnexusHasEnv -and $mcpRaw.servers.gitnexus.env) {
 71:     $gitnexusEnv = $mcpRaw.servers.gitnexus.env
 72:     $hasScanProp = ($gitnexusEnv.PSObject.Properties.Name -contains 'GITNEXUS_SEMANTIC_EXACT_SCAN_LIMIT')
 73:     if ($hasScanProp) {
 74:       [void][int]::TryParse([string]$gitnexusEnv.GITNEXUS_SEMANTIC_EXACT_SCAN_LIMIT, [ref]$scanLimit)
 75:     }
 76:   }
 77:   if ($scanLimit -lt 20000) {
 78:     $errors += 'MCP gitnexus env.GITNEXUS_SEMANTIC_EXACT_SCAN_LIMIT should be >= 20000 for better semantic fallback on Windows.'
 79:   }
 80:   if ($mcpRaw.servers.repomix.command -ne 'repomix') {
 81:     $errors += 'MCP repomix command should be local `repomix` (avoid npx startup latency).'
 82:   }
 83: }
 84: catch {
 85:   $errors += "Unable to parse .vscode/mcp.json: $($_.Exception.Message)"
 86: }
 87: 
 88: $specFiles = @(
 89:   "specs/architecture.spec.md",
 90:   "specs/azure-rag.spec.md",
 91:   "specs/coding-standards.spec.md",
 92:   "specs/database.spec.md",
 93:   "specs/migration.spec.md",
 94:   "specs/observability.spec.md",
 95:   "specs/optimization.spec.md",
 96:   "specs/repo-intake.spec.md",
 97:   "specs/rag.spec.md",
 98:   "specs/routing.spec.md",
 99:   "specs/security.spec.md"
100: )
101: 
102: $specContracts = @{
103:   "specs/architecture.spec.md"      = @("## Objetivo", "## Reglas", "## Validacion minima")
104:   "specs/azure-rag.spec.md"         = @("## Objetivo", "## Reglas", "## Validacion minima")
105:   "specs/coding-standards.spec.md"  = @("## Objetivo", "## Reglas", "## Validacion minima")
106:   "specs/database.spec.md"          = @("## Objetivo", "## Reglas", "## Validacion minima")
107:   "specs/migration.spec.md"         = @("## Objetivo", "## Reglas", "## Validacion minima")
108:   "specs/observability.spec.md"     = @("## Objetivo", "## Reglas", "## Validacion minima")
109:   "specs/optimization.spec.md"      = @("## Routing Robustness Contract (Production)", "## Token Efficiency Contract (Ahorro de Tokens)", "## Enforcement")
110:   "specs/repo-intake.spec.md"       = @("## Objetivo", "## Reglas", "## Validacion minima")
111:   "specs/rag.spec.md"               = @("## Objetivo", "## Reglas", "## Validacion minima")
112:   "specs/routing.spec.md"           = @("## Objetivo", "## Reglas", "## Validacion minima")
113:   "specs/security.spec.md"          = @("## Objetivo", "## Reglas", "## Validacion minima")
114: }
115: 
116: foreach ($spec in $specFiles) {
117:   if (-not (Test-Path $spec)) {
118:     continue
119:   }
120: 
121:   $raw = Get-Content -Raw -Path $spec
122:   $lineCount = (Get-Content -Path $spec | Measure-Object -Line).Lines
123: 
124:   if ($lineCount -lt 8) {
125:     $errors += "Spec too short (possible placeholder): $spec"
126:     continue
127:   }
128: 
129:   if ($raw -match "Reglas base del dominio") {
130:     $errors += "Spec still contains placeholder text: $spec"
131:   }
132: 
133:   foreach ($requiredHeading in $specContracts[$spec]) {
134:     if ($raw -notmatch [regex]::Escape($requiredHeading)) {
135:       $errors += "Spec missing required section '$requiredHeading': $spec"
136:     }
137:   }
138: 
139:   if ($spec -eq "specs/optimization.spec.md" -and $raw -notmatch [regex]::Escape("scripts\\intake\\run-routing-evals.py")) {
140:     $errors += "Spec enforcement command drift detected: $spec"
141:   }
142: 
143:   if ($raw -match [regex]::Escape("scripts\\learning\\run-routing-evals.py")) {
144:     $errors += "Deprecated routing-evals path referenced in spec: $spec"
145:   }
146: }
147: 
148: if (-not (Get-Command codegraph -ErrorAction SilentlyContinue)) {
149:   $errors += "Missing command codegraph"
150: }
151: elseif (-not (Test-Path ".codegraph")) {
152:   $errors += "Missing .codegraph index. Run: codegraph init -i"
153: }
154: 
155: if (-not (Get-Command repomix -ErrorAction SilentlyContinue)) {
156:   $errors += "Missing command repomix. Run: npm install -g repomix@latest"
157: }
158: 
159: if (Get-Command codebase-memory-mcp -ErrorAction SilentlyContinue) {
160:   try {
161:     $cbmCfg = codebase-memory-mcp config list | Out-String
162:     if ($cbmCfg -notmatch 'auto_index\s*=\s*true') {
163:       $errors += 'codebase-memory-mcp auto_index must be true. Run: codebase-memory-mcp config set auto_index true'
164:     }
165:   }
166:   catch {
167:     $errors += "Unable to read codebase-memory-mcp config: $($_.Exception.Message)"
168:   }
169: }
170: 
171: if (-not (Get-Command py -ErrorAction SilentlyContinue) -and -not (Get-Command python -ErrorAction SilentlyContinue)) {
172:   $errors += "Missing Python launcher (py/python) required for graphify MCP"
173: }
174: else {
175:   $pythonCmd = "python"
176:   $pythonArgs = @("-c", "import graphify.serve, mcp; print('ok')")
177:   if (Get-Command py -ErrorAction SilentlyContinue) {
178:     $pythonCmd = "py"
179:     $pythonArgs = @("-3.14", "-c", "import graphify.serve, mcp; print('ok')")
180:   }
181: 
182:   & $pythonCmd @pythonArgs *> $null
183:   if ($LASTEXITCODE -ne 0) {
184:     $errors += 'Graphify MCP runtime missing. Run: py -3.14 -m pip install graphifyy and mcp'
185:   }
186: }
187: 
188: if (-not (Test-Path "context/graphify-out/graph.json")) {
189:   $errors += "Missing context/graphify-out/graph.json. Run: py -3.14 -m graphify extract scripts --no-cluster --out context"
190: }
191: 
192: if($errors.Count -eq 0){
193:   Write-Host "Validation OK. Always-on optimization documented."
194:   Write-Host "Running strict repo registry validation..."
195:   pwsh -NoProfile -File .\scripts\intake\validate-repo-registry.ps1 -Strict
196: }
197: else {
198:   $errors | ForEach-Object { Write-Host $_ }
199: }
</file>

<file path="specs/architecture.spec.md">
 1: # architecture spec
 2: 
 3: ## Objetivo
 4: 
 5: Definir la arquitectura operativa del repo y el contrato entre orquestacion, agentes, motores de contexto y observabilidad.
 6: 
 7: ## Componentes canonicos
 8: 
 9: 1. Orquestacion: `orchestrator/`.
10: 2. Agentes: `AGENTS.md` y `.github/agents/`.
11: 3. Motores: CodeGraph, GitNexus, Graphify, Azure RAG Builder, Repomix.
12: 4. Politicas: `policies/` y `optimization/policies/`.
13: 5. Observabilidad: `observability/`.
14: 
15: ## Reglas
16: 
17: 1. Un evento de routing debe tener un motor principal.
18: 2. Si hay mezcla de motores, el secundario se justifica en `notes`.
19: 3. No se usa discovery amplio cuando hay evidencia estructurada suficiente.
20: 4. En ausencia de grounding, se declara gap explicito.
21: 
22: ## Flujo de ejecucion
23: 
24: 1. Memory-first.
25: 2. Resolucion de routing.
26: 3. Ejecucion de agente/motor.
27: 4. Registro en logs y evaluacion.
28: 
29: ## Validacion minima
30: 
31: 1. `python .\scripts\intake\resolve-routing.py --input "test" --intent info --domain dev --source-type code` emite evento valido.
32: 2. `python .\scripts\intake\run-routing-evals.py` mantiene casos en verde.
</file>

<file path="specs/azure-rag.spec.md">
 1: # azure-rag spec
 2: 
 3: ## Objetivo
 4: 
 5: Definir cuando usar Azure RAG Builder para conocimiento corporativo y como evitar respuestas sin fuente.
 6: 
 7: ## Alcance
 8: 
 9: 1. Contratos, SLA, politicas y documentacion corporativa no contenida en el repo.
10: 2. Consultas donde la fuente oficial debe citarse.
11: 
12: ## Reglas
13: 
14: 1. Azure RAG no se usa para modificar codigo del repo.
15: 2. Si no hay fuente recuperada, se declara gap en lugar de inferir.
16: 3. La respuesta debe separar claramente evidencia recuperada y recomendacion.
17: 4. En tareas mixtas codigo + corporativo, usar motor principal y secundario justificado.
18: 
19: ## Entradas esperadas
20: 
21: 1. Intencion de consulta clara.
22: 2. Contexto de dominio (seguridad, compliance, contrato, operaciones).
23: 
24: ## Validacion minima
25: 
26: 1. El evento de routing debe seleccionar `rag-azure-agent` cuando `source_type=corporate-docs`.
27: 2. Debe existir traza en `observability/logs/routing-decisions.jsonl` con `grounded=true` solo si hay fuentes.
</file>

<file path="specs/coding-standards.spec.md">
 1: # coding-standards spec
 2: 
 3: ## Objetivo
 4: 
 5: Establecer reglas de cambio seguro y minimo para scripts, docs operativas y artefactos de soporte.
 6: 
 7: ## Reglas
 8: 
 9: 1. Cambios minimos y acotados al alcance de la tarea.
10: 2. Sin refactor amplio fuera de scope.
11: 3. Mantener rutas canonicas en `scripts/setup|intake|ops|discovery|context|learning`.
12: 4. Priorizar JSON-first en artefactos operativos.
13: 5. Evitar duplicar logica entre wrappers y scripts canonicos.
14: 
15: ## Estilo por tecnologia
16: 
17: 1. Python: repo root correcto para scripts en subcarpetas (`parents[2]` en utilidades bajo `scripts/*/*`).
18: 2. PowerShell: resolver root con `Join-Path $PSScriptRoot '..\\..'` cuando el script vive en subcarpeta.
19: 3. Markdown: contratos claros, accionables y verificables.
20: 
21: ## Validacion minima
22: 
23: 1. `py -3 -m compileall -q .\scripts` sin errores.
