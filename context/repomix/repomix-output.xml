 8968:  38:     if domain == "azure-rag":
 8969:  39:         return {"knowledge": "azure-rag-builder", "execution": "none", "snapshot": "repomix"}
 8970:  40:     if domain == "legacy":
 8971:  41:         return {"knowledge": "gitnexus", "execution": "none", "snapshot": "repomix"}
 8972:  42:     return {"knowledge": "codegraph", "execution": "none", "snapshot": "repomix"}
