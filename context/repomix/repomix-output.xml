23447: 10505:  6046: 179: function Test-LongRunningCommand {
23448: 10506:  6047: 180:     param(
23449: 10507:  6048: 181:         [string]$Name,
23450: 10508:  6049: 182:         [string]$Command,
23451: 10509:  6050: 183:         [int]$WarmupSec = 4,
23452: 10510:  6051: 184:         [int]$TimeoutSec = 25
23453: 10511:  6052: 185:     )
23454: 10512:  6053: 186: 
23455: 10513:  6054: 187:     $outFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.out" -f $Name, ([guid]::NewGuid().ToString('N')))
23456: 10514:  6055: 188:     $errFile = Join-Path $env:TEMP ("hi-mcp-{0}-{1}.err" -f $Name, ([guid]::NewGuid().ToString('N')))
23457: 10515:  6056: 189: 
23458: 10516:  6057: 190:     $proc = Start-Process -FilePath 'pwsh' -ArgumentList @('-NoProfile', '-ExecutionPolicy', 'Bypass', '-Command', $Command) -PassThru -RedirectStandardOutput $outFile -RedirectStandardError $errFile
23459: 10517:  6058: 191:     $start = Get-Date
23460: 10518:  6059: 192:     $deadline = $start.AddSeconds($TimeoutSec)
23461: 10519:  6060: 193:     $isReady = $false
23462: 10520:  6061: 194: 
23463: 10521:  6062: 195:     while ((Get-Date) -lt $deadline) {
23464: 10522:  6063: 196:         if ($proc.HasExited) {
23465: 10523:  6064: 197:             if ($proc.ExitCode -eq 0) {
23466: 10524:  6065: 198:                 $isReady = $true
23467: 10525:  6066: 199:                 break
23468: 10526:  6067: 200:             }
23469: 10527:  6068: 201: 
23470: 10528:  6069: 202:             $errText = ''
23471: 10529:  6070: 203:             if (Test-Path $errFile) {
23472: 10530:  6071: 204:                 $errText = (Get-Content $errFile -Raw)
23473: 10531:  6072: 205:             }
23474: 10532:  6073: 206:             throw "$Name failed to start. ExitCode=$($proc.ExitCode). $errText"
23475: 10533:  6074: 207:         }
23476: 10534:  6075: 208: 
23477: 10535:  6076: 209:         if (((Get-Date) - $start).TotalSeconds -ge $WarmupSec) {
23478: 10536:  6077: 210:             $isReady = $true
23479: 10537:  6078: 211:             break
23480: 10538:  6079: 212:         }
23481: 10539:  6080: 213: 
23482: 10540:  6081: 214:         Start-Sleep -Milliseconds 250
23483: 10541:  6082: 215:     }
23484: 10542:  6083: 216: 
23485: 10543:  6084: 217:     if (-not $isReady) {
23486: 10544:  6085: 218:         throw "$Name did not become ready within ${TimeoutSec}s"
23487: 10545:  6086: 219:     }
23488: 10546:  6087: 220: 
23489: 10547:  6088: 221:     if (-not $proc.HasExited) {
23490: 10548:  6089: 222:         Stop-Process -Id $proc.Id -Force
23491: 10549:  6090: 223:     }
23492: 10550:  6091: 224: 
23493: 10551:  6092: 225:     Remove-Item $outFile, $errFile -ErrorAction SilentlyContinue
23494: 10552:  6093: 226: }
