440: 
441:         & codegraph sync
442:         if ($LASTEXITCODE -ne 0) {
443:             throw "codegraph sync failed with exit code $LASTEXITCODE"
444:         }
445:     } -Required $false
446: }
447: else {
448:     Write-Host '[skip] Refresh codegraph index sync'
449: }
450: 
451: if (-not $SkipIntake) {
452:     Invoke-Step -Name 'Run repo intake' -Action {
453:         & .\scripts\intake\run-repo-intake.cmd
454:         if ($LASTEXITCODE -ne 0) {
455:             throw "run-repo-intake failed with exit code $LASTEXITCODE"
456:         }
457:     } -Required $true
458: }
459: else {
460:     Write-Host '[skip] Run repo intake'
461: }
462: 
463: if (-not $SkipRoutingEvals) {
464:     Invoke-Step -Name 'Run routing evals' -Action {
465:         $py = Get-PythonCommand
466:         $cmd = $py[0]
467:         $pyParts = @()
468:         if ($py.Length -gt 1) {
469:             $pyParts = $py[1..($py.Length - 1)]
470:         }
471: 
472:         & $cmd @pyParts .\scripts\intake\run-routing-evals.py
473:         if ($LASTEXITCODE -ne 0) {
474:             throw "run-routing-evals failed with exit code $LASTEXITCODE"
475:         }
476:     } -Required $true
477: }
478: else {
479:     Write-Host '[skip] Run routing evals'
480: }
481: 
482: if (-not $SkipProjectNotesRefresh) {
483:     Invoke-Step -Name 'Refresh project notes from observability' -Action {
484:         $py = Get-PythonCommand
485:         $cmd = $py[0]
486:         $pyParts = @()
487:         if ($py.Length -gt 1) {
488:             $pyParts = $py[1..($py.Length - 1)]
489:         }
490: 
491:         & $cmd @pyParts .\scripts\discovery\refresh-project-notes.py
492:         if ($LASTEXITCODE -ne 0) {
493:             throw "refresh-project-notes failed with exit code $LASTEXITCODE"
494:         }
495:     } -Required $false
496: }
497: else {
498:     Write-Host '[skip] Refresh project notes from observability'
499: }
500: 
501: if (-not $SkipCodegraphStatus) {
502:     Invoke-Step -Name 'Check codegraph status' -Action {
503:         if (-not (Get-Command codegraph -ErrorAction SilentlyContinue)) {
504:             throw 'codegraph command not found'
505:         }
506: 
507:         & codegraph status
508:         if ($LASTEXITCODE -ne 0) {
509:             throw "codegraph status failed with exit code $LASTEXITCODE"
510:         }
511:     } -Required $false
512: }
513: else {
514:     Write-Host '[skip] Check codegraph status'
515: }
516: 
517: $endedAt = Get-Date
518: $report = [ordered]@{
519:     session = 'hi'
520:     started_at = $startedAt.ToString('o')
521:     ended_at = $endedAt.ToString('o')
522:     duration_sec = [math]::Round((($endedAt - $startedAt).TotalSeconds), 2)
523:     repo = $repoRoot
524:     success = (-not $script:HasFailures)
525:     structure_cache = $script:StructureCacheReport
526:     steps = $script:Steps
527: }
528: 
529: $reportDir = Join-Path $repoRoot 'observability/logs/session'
530: New-Item -ItemType Directory -Path $reportDir -Force | Out-Null
531: $stamp = Get-Date -Format 'yyyyMMdd-HHmmss'
532: $reportPath = Join-Path $reportDir "hi-$stamp.json"
533: $report | ConvertTo-Json -Depth 8 | Set-Content -Path $reportPath -Encoding UTF8
534: 
535: Write-Host "Report: $reportPath"
536: 
537: if ($script:HasFailures) {
538:     Write-Host 'HI startup finished with errors.' -ForegroundColor Red
539:     exit 1
540: }
541: 
542: Write-Host 'HI startup completed successfully.' -ForegroundColor Green
543: exit 0
