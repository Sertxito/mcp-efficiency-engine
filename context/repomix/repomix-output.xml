57:     if not event_id:
58:         print("No event_id provided and no eligible routing events found.")
59:         return 1
60:     exists = any(str(e.get("event_id", "")).strip() == event_id for e in events)
61:     if not exists:
62:         print(f"event_id not found in routing log: {event_id}")
63:         return 1
64:     total_tokens = args.input_tokens + args.output_tokens
65:     if args.local_tools > 0 and args.remote_tools == 0:
66:         tool_mode = "local-only"
67:     elif args.local_tools == 0 and args.remote_tools > 0:
68:         tool_mode = "remote-only"
69:     elif args.local_tools > 0 and args.remote_tools > 0:
70:         tool_mode = "hybrid"
71:     else:
72:         tool_mode = "model-only"
73:     metric = {
74:         "timestamp": utc_now(),
75:         "event_id": event_id,
76:         "model": args.model,
77:         "cost": {
78:             "input_tokens": args.input_tokens,
79:             "output_tokens": args.output_tokens,
80:             "total_tokens": total_tokens,
81:             "estimated_cost_usd": round(float(args.estimated_cost_usd), 6),
82:         },
83:         "execution": {
