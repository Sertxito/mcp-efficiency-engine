35087: 22145: 116:     )
35088: 22146: 117: 
35089: 22147: 118:     $repoName = [string]$Repo.name
35090: 22148: 119:     $slug = $repoName.ToLower() -replace '[^a-z0-9_-]+', '-'
35091: 22149: 120:     $repoPath = Resolve-RepoPath -Root $RepoRoot -RelativePath ([string]$Repo.location)
35092: 22150: 121:     $structurePath = Join-Path $RepoRoot ("repo-intake/generated/{0}/context-manifests/structure-min.json" -f $slug)
35093: 22151: 122: 
35094: 22152: 123:     $repoLatest = [datetime]::MinValue
35095: 22153: 124:     if (Test-Path $repoPath) {
35096: 22154: 125:         $pathsToCheck = @(
35097: 22155: 126:             $repoPath,
35098: 22156: 127:             (Join-Path $repoPath 'AGENTS.md'),
35099: 22157: 128:             (Join-Path $repoPath 'README.md'),
35100: 22158: 129:             (Join-Path $repoPath 'ARCHITECTURE.md'),
35101: 22159: 130:             (Join-Path $repoPath '.github/skills'),
35102: 22160: 131:             (Join-Path $repoPath '.github/prompts'),
35103: 22161: 132:             (Join-Path $repoPath 'scripts'),
35104: 22162: 133:             (Join-Path $repoPath 'specs')
35105: 22163: 134:         )
35106: 22164: 135: 
35107: 22165: 136:         foreach ($path in $pathsToCheck) {
35108: 22166: 137:             $lastWrite = Get-PathLastWriteUtc -Path $path
35109: 22167: 138:             if ($lastWrite -gt $repoLatest) {
35110: 22168: 139:                 $repoLatest = $lastWrite
35111: 22169: 140:             }
35112: 22170: 141:         }
35113: 22171: 142:     }
35114: 22172: 143: 
35115: 22173: 144:     $exists = Test-Path $structurePath
35116: 22174: 145:     $structureMtime = [datetime]::MinValue
35117: 22175: 146:     $cacheFingerprint = ''
35118: 22176: 147:     $structureRepoExists = $false
35119: 22177: 148: 
35120: 22178: 149:     if ($exists) {
35121: 22179: 150:         $structureMtime = (Get-Item $structurePath).LastWriteTimeUtc
35122: 22180: 151:         $structureData = Get-Content $structurePath -Raw | ConvertFrom-Json -Depth 20
35123: 22181: 152:         $cacheFingerprint = [string]$structureData.cache_fingerprint
35124: 22182: 153:         $structureRepoExists = [bool]$structureData.exists
35125: 22183: 154:     }
35126: 22184: 155: 
35127: 22185: 156:     $status = 'fresh'
35128: 22186: 157:     if (-not $exists) {
35129: 22187: 158:         $status = 'missing'
35130: 22188: 159:     }
35131: 22189: 160:     elseif ((Test-Path $repoPath) -and $repoLatest -gt $structureMtime) {
35132: 22190: 161:         $status = 'stale'
35133: 22191: 162:     }
35134: 22192: 163: 
35135: 22193: 164:     return [ordered]@{
35136: 22194: 165:         repo = $repoName
35137: 22195: 166:         slug = $slug
35138: 22196: 167:         version = '0'
35139: 22197: 168:         repo_path = $repoPath
35140: 22198: 169:         structure_path = $structurePath
35141: 22199: 170:         structure_exists = $exists
35142: 22200: 171:         structure_reports_repo_exists = $structureRepoExists
35143: 22201: 172:         cache_fingerprint = $cacheFingerprint
35144: 22202: 173:         repo_latest_change_utc = if ($repoLatest -eq [datetime]::MinValue) { '' } else { $repoLatest.ToString('o') }
35145: 22203: 174:         structure_mtime_utc = if ($structureMtime -eq [datetime]::MinValue) { '' } else { $structureMtime.ToString('o') }
35146: 22204: 175:         status = $status
35147: 22205: 176:     }
35148: 22206: 177: }
