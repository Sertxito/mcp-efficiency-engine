22171: 142:     }
22172: 143: 
22173: 144:     $exists = Test-Path $structurePath
22174: 145:     $structureMtime = [datetime]::MinValue
22175: 146:     $cacheFingerprint = ''
22176: 147:     $structureRepoExists = $false
