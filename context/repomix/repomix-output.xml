 8956:  26:     if "iot" in token or "edge" in token:
 8957:  27:         return "iot"
 8958:  28:     if "rag" in token or "azure" in token:
 8959:  29:         return "azure-rag"
 8960:  30:     if "legacy" in token or "migration" in token:
 8961:  31:         return "legacy"
 8962:  32:     return "dev"
