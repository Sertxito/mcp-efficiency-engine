20935:  7993:  3534:  10: def load_registry(path: Path) -> dict[str, Any]:
20936:  7994:  3535:  11:     content = path.read_text(encoding="utf-8")
20937:  7995:  3536:  12:     if content.lstrip().startswith("{"):
20938:  7996:  3537:  13:         return json.loads(content)
20939:  7997:  3538:  14:     raise ValueError("Registry must be JSON-first in current setup.")
20940:  7998:  3539:  15: def slug_name(folder_name: str) -> str:
20941:  7999:  3540:  16:     name = folder_name.lower().replace("-", "_")
20942:  8000:  3541:  17:     name = re.sub(r"[^a-z0-9_]+", "_", name)
