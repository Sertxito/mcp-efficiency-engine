<file path="scripts/intake/run-repo-intake.ps1">
 1: Set-StrictMode -Version Latest
 2: $ErrorActionPreference = "Stop"
 3: 
 4: $repoRoot = (Resolve-Path (Join-Path $PSScriptRoot '..\..')).Path
 5: Set-Location $repoRoot
 6: 
 7: $registryPath = Join-Path $repoRoot 'repo-registry\repos.yml'
 8: if (-not (Test-Path $registryPath)) {
 9: 	Write-Error "Missing repo registry: $registryPath. Run .\\scripts\\intake\\init-template-registry.cmd first."
10: 	exit 1
11: }
12: 
13: $registryRaw = Get-Content -Raw -Path $registryPath
14: $registry = $registryRaw | ConvertFrom-Json -Depth 20
15: $registryMode = 'enterprise'
16: if (($registry.PSObject.Properties.Name -contains 'registry_mode') -and [string]::IsNullOrWhiteSpace([string]$registry.registry_mode) -eq $false) {
17: 	$registryMode = [string]$registry.registry_mode
18: }
19: 
20: $repos = @()
21: if (($registry.PSObject.Properties.Name -contains 'repos') -and $null -ne $registry.repos) {
22: 	$repos = @($registry.repos)
23: }
24: 
25: if ($registryMode -eq 'template') {
26: 	Write-Host "Validating repo registry (template mode)..."
27: 	pwsh -NoProfile -ExecutionPolicy Bypass -File .\scripts\intake\validate-repo-registry.ps1
28: }
29: else {
30: 	Write-Host "Validating repo registry (strict mode)..."
31: 	pwsh -NoProfile -ExecutionPolicy Bypass -File .\scripts\intake\validate-repo-registry.ps1 -Strict
32: }
33: if ($LASTEXITCODE -ne 0) {
34: 	Write-Error "Repo registry validation failed. Aborting intake generation."
35: 	exit $LASTEXITCODE
36: }
37: 
38: Write-Host "Running repo intake generation..."
39: python .\scripts\intake\repo-intake.py
40: 
41: if ($registryMode -eq 'template' -and $repos.Count -eq 0) {
42: 	Write-Host "Template registry is empty. Intake reports were generated with 0 repositories."
43: 	Write-Host "Edit repo-registry\\repos.yml and rerun .\\scripts\\intake\\run-repo-intake.cmd when you add repos."
44: }
45: 
46: Write-Host "Repo intake completed."
</file>

<file path="scripts/intake/run-routing-evals.py">
 1: from __future__ import annotations
 2: import argparse
 3: import json
 4: import subprocess
 5: import sys
 6: from datetime import datetime, timezone
 7: from pathlib import Path
 8: from typing import Any
 9: def utc_now() -> str:
10:     return datetime.now(timezone.utc).isoformat()
11: def load_cases(path: Path) -> list[dict[str, Any]]:
12:     data = json.loads(path.read_text(encoding="utf-8"))
13:     cases = data.get("cases", [])
14:     if not isinstance(cases, list):
15:         return []
16:     return [c for c in cases if isinstance(c, dict)]
17: def run_case(repo_root: Path, case: dict[str, Any]) -> tuple[bool, str]:
18:     cmd = [
19:         sys.executable,
20:         str((repo_root / "scripts/intake/resolve-routing.py").resolve()),
21:         "--input",
22:         str(case.get("input", "")),
23:         "--intent",
24:         str(case.get("intent", "")),
25:         "--domain",
26:         str(case.get("domain", "")),
27:         "--source-type",
28:         str(case.get("source_type", "technical-docs")),
29:         "--capability",
30:         str(case.get("capability", "")),
31:     ]
32:     proc = subprocess.run(cmd, cwd=str(repo_root), capture_output=True, text=True)
33:     return proc.returncode == 0, (proc.stdout or "") + (proc.stderr or "")
34: def main() -> int:
35:     parser = argparse.ArgumentParser(description="Run routing eval cases and write JSON report.")
36:     parser.add_argument("--cases", default="observability/evals/routing-eval-cases.json")
37:     parser.add_argument("--report", default="observability/evals/routing-eval-report.json")
38:     args = parser.parse_args()
39:     repo_root = Path(__file__).resolve().parents[2]
40:     cases_path = (repo_root / args.cases).resolve()
41:     if not cases_path.exists():
42:         print(f"Missing eval cases file: {cases_path}")
43:         return 1
44:     cases = load_cases(cases_path)
45:     results: list[dict[str, Any]] = []
46:     passed = 0
47:     for case in cases:
48:         ok, output = run_case(repo_root, case)
49:         if ok:
50:             passed += 1
51:         results.append(
52:             {
53:                 "id": case.get("id", "unknown"),
54:                 "ok": ok,
55:                 "output": output,
56:             }
57:         )
58:     report = {
59:         "timestamp": utc_now(),
60:         "cases_total": len(cases),
61:         "cases_passed": passed,
62:         "cases_failed": len(cases) - passed,
63:         "results": results,
64:     }
65:     report_path = (repo_root / args.report).resolve()
66:     report_path.parent.mkdir(parents=True, exist_ok=True)
67:     report_path.write_text(json.dumps(report, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
68:     print(f"Routing evals completed: {passed}/{len(cases)} passed")
69:     print(f"Report: {report_path}")
70:     return 0 if passed == len(cases) else 1
71: if __name__ == "__main__":
72:     raise SystemExit(main())
</file>

