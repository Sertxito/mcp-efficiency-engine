 5954:  87: function Get-PathLastWriteUtc {
 5955:  88:     param(
 5956:  89:         [string]$Path
 5957:  90:     )
 5958:  91: 
 5959:  92:     if (-not (Test-Path $Path)) {
 5960:  93:         return [datetime]::MinValue
 5961:  94:     }
 5962:  95: 
 5963:  96:     $item = Get-Item $Path -ErrorAction Stop
 5964:  97:     if (-not $item.PSIsContainer) {
 5965:  98:         return $item.LastWriteTimeUtc
 5966:  99:     }
 5967: 100: 
 5968: 101:     $max = $item.LastWriteTimeUtc
 5969: 102:     $children = Get-ChildItem -Path $Path -Recurse -File -ErrorAction SilentlyContinue
 5970: 103:     foreach ($child in $children) {
 5971: 104:         if ($child.LastWriteTimeUtc -gt $max) {
 5972: 105:             $max = $child.LastWriteTimeUtc
 5973: 106:         }
 5974: 107:     }
 5975: 108: 
 5976: 109:     return $max
 5977: 110: }
