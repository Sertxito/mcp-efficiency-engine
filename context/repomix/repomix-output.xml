23373: 10431:  5972: 105:             $max = $child.LastWriteTimeUtc
23374: 10432:  5973: 106:         }
23375: 10433:  5974: 107:     }
23376: 10434:  5975: 108: 
23377: 10435:  5976: 109:     return $max
23378: 10436:  5977: 110: }
