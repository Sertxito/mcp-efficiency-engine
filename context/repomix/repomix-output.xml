 9047:  4588: 17: def run_case(repo_root: Path, case: dict[str, Any]) -> tuple[bool, str]:
 9048:  4589: 18:     cmd = [
 9049:  4590: 19:         sys.executable,
 9050:  4591: 20:         str((repo_root / "scripts/intake/resolve-routing.py").resolve()),
