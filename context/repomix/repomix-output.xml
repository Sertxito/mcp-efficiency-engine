17982:  5040:   581: 110:                   f'- failed: {failed}',
17983:  5041:   582: 111:                   ''
17984:  5042:   583: 112:               ])
17985:  5043:   584: 113:           else:
17986:  5044:   585: 114:               lines.extend(['## Routing Gate', '- report missing', ''])
17987:  5045:   586: 115:           if learning.exists():
17988:  5046:   587: 116:               data = json.loads(learning.read_text(encoding='utf-8'))
17989:  5047:   588: 117:               kpis = data.get('kpis', {}) if isinstance(data.get('kpis', {}), dict) else {}
17990:  5048:   589: 118:               lines.extend([
17991:  5049:   590: 119:                   '## Learning Loop',
