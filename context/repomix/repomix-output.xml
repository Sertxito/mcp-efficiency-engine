 87: function Get-PathLastWriteUtc {
 88:     param(
 89:         [string]$Path
 90:     )
 91: 
 92:     if (-not (Test-Path $Path)) {
 93:         return [datetime]::MinValue
 94:     }
 95: 
 96:     $item = Get-Item $Path -ErrorAction Stop
 97:     if (-not $item.PSIsContainer) {
 98:         return $item.LastWriteTimeUtc
 99:     }
100: 
101:     $max = $item.LastWriteTimeUtc
102:     $children = Get-ChildItem -Path $Path -Recurse -File -ErrorAction SilentlyContinue
103:     foreach ($child in $children) {
104:         if ($child.LastWriteTimeUtc -gt $max) {
105:             $max = $child.LastWriteTimeUtc
106:         }
107:     }
108: 
109:     return $max
110: }
