 16: function Get-PythonCommand {
 17:     if (Get-Command py -ErrorAction SilentlyContinue) {
 18:         return @('py', '-3')
 19:     }
 20:     if (Get-Command python -ErrorAction SilentlyContinue) {
 21:         return @('python')
