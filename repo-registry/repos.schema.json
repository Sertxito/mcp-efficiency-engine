{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-first-enterprise/repo-registry/repos.schema.json",
  "title": "Repo Registry Schema",
  "description": "Schema for hybrid repo registry with local and GitHub-backed sources.",
  "type": "object",
  "required": ["repos"],
  "properties": {
    "registry_mode": {
      "type": "string",
      "enum": ["enterprise", "template"]
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "governance": {
      "type": "object",
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "approval_required": { "type": "boolean" },
        "repo_name_prefix": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "repos": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["name", "domain", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "domain": {
            "type": "string",
            "enum": ["backend", "frontend", "community-content", "legacy", "dba", "iot", "ux-ui", "azure-rag", "rag"]
          },
          "location": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["local", "github"] },
          "repo_url": { "type": "string", "minLength": 1 },
          "branch": { "type": "string", "minLength": 1 },
          "cache_location": { "type": "string", "minLength": 1 },
          "optional": { "type": "boolean" },
          "engines": {
            "type": "object",
            "properties": {
              "knowledge": { "type": "string" },
              "execution": { "type": "string" },
              "snapshot": { "type": "string" }
            },
            "additionalProperties": true
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ref"],
              "properties": {
                "ref": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": true
            }
          },
          "approval": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "enum": ["approved", "pending", "rejected"] },
              "approved_by": { "type": "string" },
              "approved_date": { "type": "string" },
              "review_ticket": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "local" }
              }
            },
            "then": {
              "required": ["location"]
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "github" }
              }
            },
            "then": {
              "required": ["repo_url"]
            }
          }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}