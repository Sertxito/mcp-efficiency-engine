{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-efficiency-engine.local/autodocs/wiki-node.schema.json",
  "title": "AutoDocs Wiki Node",
  "type": "object",
  "required": [
    "node_id",
    "title",
    "slug",
    "kind",
    "summary",
    "source_refs",
    "navigation"
  ],
  "properties": {
    "node_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["agent", "skill", "prompt", "policy", "project", "spec", "report", "capability"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "type"],
        "properties": {
          "target": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    },
    "navigation": {
      "type": "object",
      "required": ["section"],
      "properties": {
        "section": {
          "type": "string",
          "enum": ["capabilities", "agents", "skills", "routing", "projects", "policies", "specs", "observability", "reports", "misc"]
        },
        "weight": { "type": "number" },
        "parent": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}